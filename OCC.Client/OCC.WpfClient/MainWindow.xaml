<Window x:Class="OCC.WpfClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:auth="clr-namespace:OCC.WpfClient.Features.AuthHub.Views"
        xmlns:authVm="clr-namespace:OCC.WpfClient.Features.AuthHub.ViewModels"
        xmlns:main="clr-namespace:OCC.WpfClient.Features.Main.Views"
        xmlns:mainVm="clr-namespace:OCC.WpfClient.Features.Main.ViewModels"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Width="1024" Height="700"
        MinWidth="1024" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="Transparent"
        Icon="/Assets/Images/occ_logo_transparent.png"
        AllowsTransparency="False"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="Auto"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" 
                      ResizeBorderThickness="8" 
                      CornerRadius="0"                      
                      GlassFrameThickness="-1" />
    </WindowChrome.WindowChrome>
    
    <Window.Resources>
        <!-- Moved feature DataTemplates to Styles/FeatureTemplates.xaml -->
    </Window.Resources>

    <!-- The Root Border provides the visible border and background -->
    <Border x:Name="RootBorder" 
            Background="{StaticResource BackgroundDark}">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="CornerRadius" Value="0"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Normal">
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="BorderBrush" Value="{StaticResource OrangeBrush}"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Maximized">
                        <Setter Property="Padding" Value="10,5,10,10"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <!-- The Content Grid handles clipping of all child elements -->
        <Grid x:Name="ContentGrid">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="32" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Root Content Switcher -->
                <ContentControl Grid.RowSpan="2" 
                                Content="{Binding Navigation.CurrentView}" 
                                HorizontalContentAlignment="Stretch" 
                                VerticalContentAlignment="Stretch"/>

                <!-- Title Bar -->
                <Grid VerticalAlignment="Top" Height="32" Panel.ZIndex="10">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Content="&#xE108;" Style="{StaticResource WindowControlButton}" Click="OnMinimizeClick"/>
                        <Button x:Name="BtnMaximize" Content="&#xE922;" Style="{StaticResource WindowControlButton}" Click="OnMaximizeRestoreClick"/>
                        <Button Content="&#xE10A;" Style="{StaticResource WindowCloseButton}" Click="OnCloseClick"/>
                    </StackPanel>
                </Grid>

                <!-- Global Progress Overlay (for transitions) -->

                <!-- Global Progress Overlay (for transitions) -->
                <Border Grid.RowSpan="2" Background="#99000000" Visibility="Collapsed" x:Name="GlobalLoadingOverlay">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Optimizing Experience..." Foreground="White" FontSize="16" Margin="0,0,0,10"/>
                        <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#33FFFFFF" Foreground="{StaticResource AccentBlue}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>

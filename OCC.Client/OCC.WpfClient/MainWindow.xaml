<Window x:Class="OCC.WpfClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:auth="clr-namespace:OCC.WpfClient.Features.AuthHub.Views"
        xmlns:authVm="clr-namespace:OCC.WpfClient.Features.AuthHub.ViewModels"
        xmlns:main="clr-namespace:OCC.WpfClient.Features.Main.Views"
        xmlns:mainVm="clr-namespace:OCC.WpfClient.Features.Main.ViewModels"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Width="1024" Height="700"
        MinWidth="1024" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="{StaticResource BackgroundDark}"
        AllowsTransparency="False">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" 
                      ResizeBorderThickness="8" 
                      CornerRadius="0" 
                      GlassFrameThickness="0" />
    </WindowChrome.WindowChrome>
    
    <Window.Resources>
        <DataTemplate DataType="{x:Type authVm:AuthViewModel}">
            <auth:AuthView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type mainVm:MainViewModel}">
            <main:MainView />
        </DataTemplate>
    </Window.Resources>

    <Border Background="{StaticResource BackgroundDark}" CornerRadius="0" BorderThickness="0">
        <Grid>
            <!-- Title Bar -->
            <Grid VerticalAlignment="Top" Height="32" Panel.ZIndex="10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Content="" Style="{StaticResource WindowControlButton}" Click="OnMinimizeClick"/>
                    <Button x:Name="BtnMaximize" Content="" Style="{StaticResource WindowControlButton}" Click="OnMaximizeRestoreClick"/>
                    <Button Content="" Style="{StaticResource WindowCloseButton}" Click="OnCloseClick"/>
                </StackPanel>
            </Grid>

            <!-- Root Content Switcher -->
            <ContentControl Content="{Binding Navigation.CurrentView}" />

            <!-- Global Progress Overlay (for transitions) -->
            <Border Background="#99000000" Visibility="Collapsed" x:Name="GlobalLoadingOverlay">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Optimizing Experience..." Foreground="White" FontSize="16" Margin="0,0,0,10"/>
                    <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#33FFFFFF" Foreground="{StaticResource AccentBlue}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>

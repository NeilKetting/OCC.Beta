<Application x:Class="OCC.WpfClient.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:OCC.WpfClient"
             xmlns:conv="clr-namespace:OCC.WpfClient.Infrastructure.Converters"
             xmlns:userViews="clr-namespace:OCC.WpfClient.Features.Admin.Users.Views"
             xmlns:userVm="clr-namespace:OCC.WpfClient.Features.Admin.Users.ViewModels">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/Colors.xaml"/>
                <ResourceDictionary Source="/Styles/Common.xaml"/>
                <ResourceDictionary Source="/Styles/Typography.xaml"/>
                <ResourceDictionary Source="/Styles/Inputs.xaml"/>
                <ResourceDictionary Source="/Styles/Buttons.xaml"/>
                <ResourceDictionary Source="/Styles/ShellStyles.xaml"/>
                <ResourceDictionary Source="/Styles/ScrollStyles.xaml"/>
                <ResourceDictionary Source="/Styles/Validation.xaml"/>
                <ResourceDictionary Source="/Styles/Icons.xaml"/>
                <ResourceDictionary Source="/Styles/DataGrid.xaml"/>
                <ResourceDictionary Source="/Styles/Modals.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <conv:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
            <conv:VisibilityConverter x:Key="VisibilityConverter" />
            <conv:FriendlyEnumConverter x:Key="FriendlyEnumConverter" />
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

            <!-- Global Feature View Mapping -->
            <DataTemplate DataType="{x:Type userVm:UserListViewModel}">
                <userViews:UserListView />
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>

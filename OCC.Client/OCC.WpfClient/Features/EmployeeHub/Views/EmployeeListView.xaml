<UserControl x:Class="OCC.WpfClient.Features.EmployeeHub.Views.EmployeeListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:OCC.WpfClient.Features.EmployeeHub.ViewModels"
             xmlns:infra="clr-namespace:OCC.WpfClient.Infrastructure.Converters"
             xmlns:utils="clr-namespace:OCC.WpfClient.Infrastructure"
             xmlns:views="clr-namespace:OCC.WpfClient.Features.EmployeeHub.Views"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200"
             d:DataContext="{d:DesignInstance Type=vm:EmployeeListViewModel}">

    <UserControl.Resources>
        <infra:VisibilityConverter x:Key="VisibilityConverter" />
        <utils:BindingProxy x:Key="BindingProxy" Data="{Binding}" />
        
        <DataTemplate DataType="{x:Type vm:EmployeeDetailViewModel}">
            <views:EmployeeDetailView />
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="0" Background="{StaticResource AppBackground}">
        <!-- Main Background Content (will be blurred/dimmed) -->
        <Grid>
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsOverlayActive}" Value="True">
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <BlurEffect Radius="15"/>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Opacity" Value="0.4"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <!-- Header -->
                <RowDefinition Height="Auto" />
                <!-- Compact Filters & Stats -->
                <RowDefinition Height="*" />
                <!-- Grid -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="10">
                <StackPanel>
                    <TextBlock Text="Employee Overview" FontSize="26" FontWeight="Bold" Foreground="White" />
                    <TextBlock Text="Manage staff records and teams." Style="{StaticResource FormLabelText}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">

                    <Button Style="{StaticResource PrimaryButton}" Command="{Binding AddEmployeeCommand}" Width="140" Height="36" Cursor="Hand">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconPlus}" Fill="White" Width="12" Height="12" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Add Employee" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Compact Filters & Stats Line -->
            <Border Grid.Row="1" Style="{StaticResource GlassCard}" Padding="15,10" Margin="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <!-- Search Icon -->
                        <ColumnDefinition Width="200" />
                        <!-- Search Box -->
                        <ColumnDefinition Width="Auto" />
                        <!-- Divider -->
                        <ColumnDefinition Width="Auto" />
                        <!-- Status Filter -->
                        <ColumnDefinition Width="Auto" />
                        <!-- Branch Filter -->
                        <ColumnDefinition Width="Auto" />
                        <!-- Columns Button -->
                        <ColumnDefinition Width="*" />
                        <!-- Spacer -->
                        <ColumnDefinition Width="Auto" />
                        <!-- Subtle Stats -->
                    </Grid.ColumnDefinitions>

                    <!-- Search -->
                    <Path Grid.Column="0" Data="{StaticResource IconSearch}" Fill="{StaticResource TextSub}" Width="14" Height="14" Margin="5,0,10,0" VerticalAlignment="Center" Stretch="Uniform"/>
                    <TextBox Grid.Column="1" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" Tag="Search staff..." Style="{StaticResource ModernInput}" Height="32" Padding="8,0" BorderThickness="0" Background="Transparent"/>

                    <Border Grid.Column="2" Width="1" Height="20" Background="{StaticResource GlassBorder}" Margin="15,0" VerticalAlignment="Center"/>

                    <!-- Employment Type -->
                    <ComboBox Grid.Column="3" SelectedIndex="{Binding SelectedFilterIndex}" Width="130" Height="32" Style="{StaticResource ModernComboBox}" Margin="0,0,10,0">
                        <ComboBoxItem Content="All Types" />
                        <ComboBoxItem Content="Permanent" />
                        <ComboBoxItem Content="Contract" />
                    </ComboBox>

                    <!-- Branch -->
                    <ComboBox Grid.Column="4" SelectedIndex="{Binding SelectedBranchFilterIndex}" Width="140" Height="32" Style="{StaticResource ModernComboBox}" Margin="0,0,10,0">
                        <ComboBoxItem Content="All Branches" />
                        <ComboBoxItem Content="Johannesburg" />
                        <ComboBoxItem Content="Cape Town" />
                    </ComboBox>

                    <!-- Columns Selection -->
                    <Grid Grid.Column="5">
                        <ToggleButton x:Name="ColumnsBtn" Style="{StaticResource {x:Type ToggleButton}}" 
                                      Width="120" Height="32" Background="Transparent" Foreground="{StaticResource TextSub}" BorderThickness="1" BorderBrush="{StaticResource GlassBorder}">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock Text="" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="COLUMNS" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Border>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>

                        <Popup IsOpen="{Binding IsChecked, ElementName=ColumnsBtn}" StaysOpen="False" PlacementTarget="{Binding ElementName=ColumnsBtn}" Placement="Bottom" AllowsTransparency="True">
                            <Border Background="{StaticResource BackgroundDarker}" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,5,0,0" Width="200">
                                <ScrollViewer MaxHeight="400">
                                    <StackPanel>
                                        <TextBlock Text="DISPLAY COLUMNS" FontSize="10" FontWeight="Bold" Foreground="{StaticResource AccentBlue}" Margin="0,0,0,8"/>

                                        <TextBlock Text="Core" Style="{StaticResource FormLabelText}"/>
                                        <CheckBox Content="Number" IsChecked="{Binding IsNumberVisible}" Command="{Binding SaveLayoutCommand}" Foreground="White" Margin="0,2"/>
                                        <CheckBox Content="Position" IsChecked="{Binding IsPositionVisible}" Command="{Binding SaveLayoutCommand}" Foreground="White" Margin="0,2"/>
                                        <CheckBox Content="Type" IsChecked="{Binding IsTypeVisible}" Command="{Binding SaveLayoutCommand}" Foreground="White" Margin="0,2"/>
                                        <CheckBox Content="Branch" IsChecked="{Binding IsBranchVisible}" Command="{Binding SaveLayoutCommand}" Foreground="White" Margin="0,2"/>

                                        <TextBlock Text="Personal" Style="{StaticResource FormLabelText}"/>
                                        <CheckBox Content="Phone" IsChecked="{Binding IsPhoneVisible}" Command="{Binding SaveLayoutCommand}" Foreground="White" Margin="0,2"/>
                                        <CheckBox Content="Email" IsChecked="{Binding IsEmailVisible}" Command="{Binding SaveLayoutCommand}" Foreground="White" Margin="0,2"/>
                                        <CheckBox Content="ID Number" IsChecked="{Binding IsIdNumberVisible}" Command="{Binding SaveLayoutCommand}" Foreground="White" Margin="0,2"/>

                                        <TextBlock Text="Finance" Style="{StaticResource FormLabelText}"/>
                                        <CheckBox Content="Rate Type" IsChecked="{Binding IsRateTypeVisible}" Command="{Binding SaveLayoutCommand}" Foreground="White" Margin="0,2"/>
                                        <CheckBox Content="Hourly Rate" IsChecked="{Binding IsHourlyRateVisible}" Command="{Binding SaveLayoutCommand}" Foreground="White" Margin="0,2"/>
                                        <CheckBox Content="Tax Number" IsChecked="{Binding IsTaxNumberVisible}" Command="{Binding SaveLayoutCommand}" Foreground="White" Margin="0,2"/>
                                        <CheckBox Content="Bank" IsChecked="{Binding IsBankNameVisible}" Command="{Binding SaveLayoutCommand}" Foreground="White" Margin="0,2"/>

                                        <TextBlock Text="Status &amp; Dates" Style="{StaticResource FormLabelText}"/>
                                        <CheckBox Content="Leave" IsChecked="{Binding IsLeaveBalanceVisible}" Command="{Binding SaveLayoutCommand}" Foreground="White" Margin="0,2"/>
                                        <CheckBox Content="Start Date" IsChecked="{Binding IsEmploymentDateVisible}" Command="{Binding SaveLayoutCommand}" Foreground="White" Margin="0,2"/>
                                        <CheckBox Content="Shift Start" IsChecked="{Binding IsShiftStartVisible}" Command="{Binding SaveLayoutCommand}" Foreground="White" Margin="0,2"/>
                                        <CheckBox Content="Shift End" IsChecked="{Binding IsShiftEndVisible}" Command="{Binding SaveLayoutCommand}" Foreground="White" Margin="0,2"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>

                    <!-- Subtle Stats -->
                    <StackPanel Grid.Column="7" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="#20FFFFFF" CornerRadius="12" Padding="10,4" Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="TOTAL: " FontSize="10" Foreground="{StaticResource TextSub}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding TotalCount}" FontSize="12" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#204099FF" CornerRadius="12" Padding="10,4" Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="PERM: " FontSize="10" Foreground="{StaticResource TextSub}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding PermanentCount}" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AccentBlue}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Employee Grid -->
            <Border Grid.Row="2" Style="{StaticResource GlassCard}" Padding="2" ClipToBounds="True"
                    Margin="10,0,10,10" CornerRadius="0">
                <DataGrid ItemsSource="{Binding Employees}" 
                          SelectedItem="{Binding SelectedEmployee}"
                          AutoGenerateColumns="False" 
                          IsReadOnly="True"
                          ColumnReordered="DataGrid_ColumnReordered"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <DataGrid.Style>
                        <Style TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
                            <!-- Implicit styles -->
                        </Style>
                    </DataGrid.Style>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                            <Setter Property="Cursor" Value="Hand" />
                            <Setter Property="Background" Value="Transparent" />
                            <!-- MouseBinding at row level via Style is tricky in pure XAML; using a simpler approach -->
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.InputBindings>
                        <MouseBinding MouseAction="LeftDoubleClick" 
                                      Command="{Binding EditEmployeeCommand}"
                                      CommandParameter="{Binding SelectedEmployee}" />
                    </DataGrid.InputBindings>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="NUMBER" Binding="{Binding EmployeeNumber}" Width="Auto" Visibility="{Binding Data.IsNumberVisible, Source={StaticResource BindingProxy}, Converter={StaticResource VisibilityConverter}}" />
                        <DataGridTextColumn Header="EMPLOYEE" Binding="{Binding DisplayName}" Width="Auto" />
                        <DataGridTextColumn Header="POSITION" Binding="{Binding Role}" Width="Auto" Visibility="{Binding Data.IsPositionVisible, Source={StaticResource BindingProxy}, Converter={StaticResource VisibilityConverter}}" />
                        <DataGridTextColumn Header="TYPE" Binding="{Binding EmploymentType}" Width="Auto" Visibility="{Binding Data.IsTypeVisible, Source={StaticResource BindingProxy}, Converter={StaticResource VisibilityConverter}}" />
                        <DataGridTextColumn Header="BRANCH" Binding="{Binding Branch}" Width="Auto" Visibility="{Binding Data.IsBranchVisible, Source={StaticResource BindingProxy}, Converter={StaticResource VisibilityConverter}}" />

                        <!-- New Columns -->
                        <DataGridTextColumn Header="PHONE" Binding="{Binding Phone}" Width="Auto" Visibility="{Binding Data.IsPhoneVisible, Source={StaticResource BindingProxy}, Converter={StaticResource VisibilityConverter}}" />
                        <DataGridTextColumn Header="EMAIL" Binding="{Binding Email}" Width="Auto" Visibility="{Binding Data.IsEmailVisible, Source={StaticResource BindingProxy}, Converter={StaticResource VisibilityConverter}}" />
                        <DataGridTextColumn Header="ID NUMBER" Binding="{Binding IdNumber}" Width="Auto" Visibility="{Binding Data.IsIdNumberVisible, Source={StaticResource BindingProxy}, Converter={StaticResource VisibilityConverter}}" />

                        <DataGridTextColumn Header="RATE TYPE" Binding="{Binding RateType}" Width="Auto" Visibility="{Binding Data.IsRateTypeVisible, Source={StaticResource BindingProxy}, Converter={StaticResource VisibilityConverter}}" />
                        <DataGridTextColumn Header="RATE" Binding="{Binding HourlyRate, StringFormat=C}" Width="Auto" Visibility="{Binding Data.IsHourlyRateVisible, Source={StaticResource BindingProxy}, Converter={StaticResource VisibilityConverter}}" />
                        <DataGridTextColumn Header="TAX #" Binding="{Binding TaxNumber}" Width="Auto" Visibility="{Binding Data.IsTaxNumberVisible, Source={StaticResource BindingProxy}, Converter={StaticResource VisibilityConverter}}" />
                        <DataGridTextColumn Header="BANK" Binding="{Binding BankName}" Width="Auto" Visibility="{Binding Data.IsBankNameVisible, Source={StaticResource BindingProxy}, Converter={StaticResource VisibilityConverter}}" />

                        <DataGridTextColumn Header="LEAVE" Binding="{Binding LeaveBalance, StringFormat=\{0:N1\}}" Width="Auto" Visibility="{Binding Data.IsLeaveBalanceVisible, Source={StaticResource BindingProxy}, Converter={StaticResource VisibilityConverter}}" />
                        <DataGridTextColumn Header="START DATE" Binding="{Binding EmploymentDate, StringFormat=d}" Width="Auto" Visibility="{Binding Data.IsEmploymentDateVisible, Source={StaticResource BindingProxy}, Converter={StaticResource VisibilityConverter}}" />
                        <DataGridTextColumn Header="SHIFT START" Binding="{Binding ShiftStartTime, StringFormat={}{0:hh\:mm}}" Width="Auto" Visibility="{Binding Data.IsShiftStartVisible, Source={StaticResource BindingProxy}, Converter={StaticResource VisibilityConverter}}" />
                        <DataGridTextColumn Header="SHIFT END" Binding="{Binding ShiftEndTime, StringFormat={}{0:hh\:mm}}" Width="Auto" Visibility="{Binding Data.IsShiftEndVisible, Source={StaticResource BindingProxy}, Converter={StaticResource VisibilityConverter}}" />

                        <DataGridTemplateColumn Header="ACTIONS" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="" FontFamily="Segoe MDL2 Assets" 
                                                Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextSub}" Margin="0,0,15,0"
                                                Command="{Binding DataContext.EditEmployeeCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}" Cursor="Hand" ToolTip="Edit Employee" />

                                        <Button Content="" FontFamily="Segoe MDL2 Assets" 
                                                Background="Transparent" BorderThickness="0" Foreground="#80FF4B4B"
                                                Command="{Binding DataContext.DeleteEmployeeCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}" Cursor="Hand" ToolTip="Delete Employee" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Loading Overlay -->
            <ContentControl Grid.Row="2" Style="{StaticResource StandardLoadingOverlay}"
                            Visibility="{Binding IsBusy, Converter={StaticResource VisibilityConverter}}"/>
        </Grid>

        <!-- Detail View Overlay (ContentControl automatically selects the DataTemplate based on DataContext type) -->
        <ContentControl Content="{Binding OverlayViewModel}" />
    </Grid>
</UserControl>

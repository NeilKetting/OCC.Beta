<UserControl x:Class="OCC.WpfClient.Features.Admin.Users.Views.UserListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:OCC.WpfClient.Features.Admin.Users.ViewModels"
             xmlns:views="clr-namespace:OCC.WpfClient.Features.Admin.Users.Views"
             xmlns:infra="clr-namespace:OCC.WpfClient.Infrastructure.Converters"
             xmlns:utils="clr-namespace:OCC.WpfClient.Infrastructure"
             xmlns:ap="clr-namespace:OCC.WpfClient.Infrastructure.AttachedProperties"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200"
             d:DataContext="{d:DesignInstance Type=vm:UserListViewModel}">

    <UserControl.Resources>
        <!-- No local VisibilityConverter needed as it's in App.xaml -->
        <DataTemplate DataType="{x:Type vm:UserDetailViewModel}">
            <views:UserDetailView />
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="5,10,5,5" Background="{StaticResource AppBackground}">
        <!-- Main Background Content -->
        <Grid>
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsOverlayActive}" Value="True">
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <BlurEffect Radius="15"/>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Opacity" Value="0.4"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- Header -->
                <RowDefinition Height="Auto" /> <!-- Stats & Search -->
                <RowDefinition Height="*" />    <!-- Grid -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="5,0,5,20">
                <StackPanel>
                    <TextBlock Text="User Management" FontSize="26" FontWeight="Bold" Foreground="White" />
                    <TextBlock Text="Manage system access, roles and approvals." Style="{StaticResource FormLabelText}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Style="{StaticResource PrimaryButton}" Command="{Binding AddUserCommand}" Width="140" Height="36" Cursor="Hand">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconPlus}" Fill="White" Width="12" Height="12" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Add User" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Stats & Search Line -->
            <Border Grid.Row="1" Background="{StaticResource GlassBackground}" BorderBrush="{StaticResource GlassBorder}" 
                    BorderThickness="1" CornerRadius="10" Padding="15,10" Margin="5,0,5,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" /> <!-- Search Icon -->
                        <ColumnDefinition Width="200" />  <!-- Search Box -->
                        <ColumnDefinition Width="*" />    <!-- Spacer -->
                        <ColumnDefinition Width="Auto" /> <!-- Stats -->
                    </Grid.ColumnDefinitions>

                    <!-- Search -->
                    <Path Grid.Column="0" Data="{StaticResource IconSearch}" Fill="{StaticResource TextSub}" Width="14" Height="14" Margin="5,0,10,0" VerticalAlignment="Center" Stretch="Uniform"/>
                    <TextBox Grid.Column="1" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource ModernInput}" Height="32" Padding="8,0" BorderThickness="0" Background="Transparent"
                             ap:WatermarkProperties.Watermark="Search users..."/>

                    <!-- Stats -->
                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel Margin="0,0,30,0">
                            <TextBlock Text="TOTAL USERS" FontSize="10" Foreground="{StaticResource TextSub}" FontWeight="Bold"/>
                            <TextBlock Text="{Binding TotalCount}" FontSize="18" Foreground="White" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,30,0">
                            <TextBlock Text="PENDING APPROVAL" FontSize="10" Foreground="{StaticResource SecondaryGold}" FontWeight="Bold"/>
                            <TextBlock Text="{Binding PendingApprovalCount}" FontSize="18" Foreground="{StaticResource SecondaryGold}" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="ADMINS" FontSize="10" Foreground="{StaticResource AccentBlue}" FontWeight="Bold"/>
                            <TextBlock Text="{Binding AdminCount}" FontSize="18" Foreground="{StaticResource AccentBlue}" FontWeight="SemiBold"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- User Grid -->
            <Border Grid.Row="2" Background="{StaticResource GlassBackground}" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1" CornerRadius="12" Padding="2" ClipToBounds="True">
                <DataGrid ItemsSource="{Binding Users}" 
                          SelectedItem="{Binding SelectedUser}"
                          AutoGenerateColumns="False" 
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          CanUserAddRows="False">
                    <DataGrid.InputBindings>
                        <MouseBinding MouseAction="LeftDoubleClick" 
                                      Command="{Binding EditUserCommand}"
                                      CommandParameter="{Binding SelectedUser}" />
                    </DataGrid.InputBindings>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="NAME" Binding="{Binding DisplayName}" Width="*" FontWeight="SemiBold" />
                        <DataGridTextColumn Header="EMAIL" Binding="{Binding Email}" Width="*" Foreground="{StaticResource TextSub}" />
                        <DataGridTextColumn Header="ROLE" Binding="{Binding UserRole}" Width="150" />
                        
                        <DataGridTemplateColumn Header="STATUS" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border HorizontalAlignment="Left" CornerRadius="4" Padding="8,3" Margin="4">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#20FFAB00"/> <!-- Yellow-ish for pending -->
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsApproved}" Value="True">
                                                        <Setter Property="Background" Value="#2000C853"/> <!-- Green for approved -->
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock TextAlignment="Center" FontSize="10" FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="PENDING"/>
                                                    <Setter Property="Foreground" Value="{StaticResource SecondaryGold}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsApproved}" Value="True">
                                                            <Setter Property="Text" Value="APPROVED"/>
                                                            <Setter Property="Foreground" Value="#00C853"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="" Width="50">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button x:Name="ActionBtn" 
                                            Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextSub}"
                                            Cursor="Hand" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="10">
                                        <Path Data="{StaticResource IconEllipseVertical}" Fill="{StaticResource TextSub}" Width="16" Height="16" Stretch="Uniform"/>
                                        <Button.ContextMenu>
                                            <ContextMenu Style="{StaticResource ModernContextMenu}">
                                                <MenuItem Header="Edit User" Command="{Binding DataContext.EditUserCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}"/>
                                                <MenuItem Header="Delete User" Command="{Binding DataContext.DeleteUserCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" Foreground="{StaticResource ErrorRed}"/>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Loading Overlay -->
            <Border Grid.Row="2" Background="#80000000" CornerRadius="12" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="200" Height="4" Foreground="{StaticResource AccentBlue}" Background="#20FFFFFF"/>
                    <TextBlock Text="{Binding BusyText}" Foreground="White" Margin="0,15,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Detail View Overlay -->
        <ContentControl Content="{Binding OverlayViewModel}" />
    </Grid>
</UserControl>


<UserControl x:Class="OCC.WpfClient.Features.ProjectHub.Views.ProjectsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:OCC.WpfClient.Features.ProjectHub.ViewModels"
             xmlns:ap="clr-namespace:OCC.WpfClient.Infrastructure.AttachedProperties"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200"
             d:DataContext="{d:DesignInstance Type=vm:ProjectsViewModel}">

    <Grid Background="{StaticResource AppBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Toolbar -->
            <RowDefinition Height="*"/>    <!-- Grid -->
        </Grid.RowDefinitions>

        <!-- Toolbar Section -->
        <Border Grid.Row="0" Style="{StaticResource ToolbarBorder}" Margin="20,20,20,0">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <TextBlock Text="Projects" VerticalAlignment="Center" Margin="0,0,30,0" 
                               FontSize="22" FontWeight="Bold" Foreground="White" />

                    <!-- Search Box -->
                    <Border Background="{StaticResource InputBackground}" CornerRadius="20" Width="300" Height="36" Margin="0,0,20,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Path Data="{StaticResource IconSearch}" Fill="{StaticResource TextSub}" 
                                  Width="14" Height="14" Stretch="Uniform" HorizontalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                                     Background="Transparent" BorderThickness="0" Foreground="White" 
                                     VerticalContentAlignment="Center" CaretBrush="White" 
                                     ap:WatermarkProperties.Watermark="Search projects..."/>
                        </Grid>
                    </Border>

                    <Button Command="{Binding LoadDataAsyncCommand}" Style="{StaticResource ToolbarIconButton}" ToolTip="Refresh Data">
                        <Path Data="{StaticResource IconRefresh}" Fill="White" Width="18" Height="18" Stretch="Uniform"/>
                    </Button>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Command="{Binding AddProjectCommand}" Style="{StaticResource PrimaryButton}" Height="36" Padding="20,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconPlus}" Fill="White" Width="12" Height="12" Stretch="Uniform" Margin="0,0,10,0"/>
                            <TextBlock Text="Create New Project"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Data Grid -->
        <Border Grid.Row="1" Margin="20" Background="{StaticResource CardBackground}" CornerRadius="16" Padding="1">
            <Grid>
                <!-- Empty State -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" 
                            Visibility="{Binding Projects.Count, Converter={StaticResource VisibilityConverter}, ConverterParameter=Invert}">
                    <Path Data="{StaticResource IconDatabase}" Fill="{StaticResource TextSub}" Opacity="0.1" Width="80" Height="80" Stretch="Uniform" Margin="0,0,0,20"/>
                    <TextBlock Text="No Projects Found" FontSize="18" Foreground="{StaticResource TextSub}" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Grid -->
                <DataGrid ItemsSource="{Binding Projects}" SelectedItem="{Binding SelectedProject}" 
                          AutoGenerateColumns="False" IsReadOnly="True" 
                          Style="{StaticResource ModernDataGrid}" 
                          Visibility="{Binding Projects.Count, Converter={StaticResource VisibilityConverter}}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="NAME" Binding="{Binding Name}" Width="1.5*" MinWidth="200" />
                        
                        <DataGridTemplateColumn Header="PROGRESS" Width="*" MinWidth="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid VerticalAlignment="Center" Margin="10,0">
                                        <ProgressBar Value="{Binding Progress}" Maximum="100" Height="6" 
                                                     Background="#1AFFFFFF" BorderThickness="0" 
                                                     Foreground="{StaticResource AccentBlue}"/>
                                        <TextBlock Text="{Binding Progress, StringFormat='{}{0}%'}" 
                                                   FontSize="10" Foreground="White" 
                                                   HorizontalAlignment="Right" VerticalAlignment="Top" 
                                                   Margin="0,-12,0,0"/>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="SITE MANAGER" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Width="30" Height="30" CornerRadius="15" Margin="20,0"
                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Background="{Binding ProjectManager, Converter={StaticResource UserColorConverter}}"
                                            ToolTip="{Binding ProjectManager}">
                                        <TextBlock Text="{Binding ProjectManager, Converter={StaticResource UserInitialsConverter}}" 
                                                   VerticalAlignment="Center" HorizontalAlignment="Center" 
                                                   Foreground="White" FontSize="11" FontWeight="Bold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="LATEST UPDATE" Binding="{Binding LatestFinish, StringFormat='{}{0:d}'}" Width="Auto" />
                        
                        <DataGridTemplateColumn Header="STATUS" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="#1AFFFFFF" Padding="8,4" CornerRadius="4" HorizontalAlignment="Left" Margin="10,0">
                                        <TextBlock Text="{Binding Status}" Foreground="White" FontSize="12"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="ACTIONS" Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Command="{Binding DataContext.OpenProjectCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                    CommandParameter="{Binding}" Style="{StaticResource ToolbarIconButton}" Margin="5" ToolTip="Open Project Dashboard">
                                                <Path Data="{StaticResource IconExternalLink}" Fill="White" Width="14" Height="14" Stretch="Uniform" Opacity="0.8"/>
                                            </Button>
                                            <Button Command="{Binding DataContext.EditProjectCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                    CommandParameter="{Binding}" Style="{StaticResource ToolbarIconButton}" Margin="5" ToolTip="Edit">
                                                <Path Data="{StaticResource IconEdit}" Fill="{StaticResource AccentBlue}" Width="14" Height="14" Stretch="Uniform"/>
                                            </Button>
                                            <Button Command="{Binding DataContext.DeleteProjectCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                    CommandParameter="{Binding}" Style="{StaticResource ToolbarIconButton}" Margin="5" ToolTip="Delete">
                                                <Path Data="{StaticResource IconTrash}" Fill="{StaticResource ErrorRed}" Width="14" Height="14" Stretch="Uniform"/>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                <Setter Property="ap:CommandProperties.DoubleClickCommand" 
                                        Value="{Binding DataContext.OpenProjectCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                                <Setter Property="ap:CommandProperties.CommandParameter" Value="{Binding}"/>
                            </Style>
                        </DataGrid.RowStyle>
                    </DataGrid>

                <!-- Loading Overlay -->
                <Border Background="#40000000" Visibility="{Binding IsBusy, Converter={StaticResource VisibilityConverter}}" CornerRadius="15">
                    <ProgressBar IsIndeterminate="True" Width="200" Height="4" Foreground="{StaticResource AccentBlue}"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>

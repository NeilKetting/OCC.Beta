<UserControl x:Class="OCC.WpfClient.Features.ProjectHub.Views.ProjectDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OCC.WpfClient.Features.ProjectHub.Views"
             xmlns:vm="clr-namespace:OCC.WpfClient.Features.ProjectHub.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200"
             d:DataContext="{d:DesignInstance vm:ProjectDetailViewModel}">
    <Grid Background="{StaticResource BackgroundDarker}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <!-- Project Sub-Sidebar (Expanded for readability) -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Project Sub-Sidebar (Integrated) -->
        <Border Grid.Column="0" Background="#10FFFFFF" BorderBrush="{StaticResource GlassBorderUltraLight}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Project Info Mini -->
                    <RowDefinition Height="*"/>
                    <!-- Nav Items -->
                </Grid.RowDefinitions>

                <!-- Project Info Header -->
                <StackPanel Grid.Row="0" Margin="20,30,20,20">
                    <TextBlock Text="PROJECT" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSub}"/>
                    <TextBlock Text="{Binding Project.Name}" FontSize="16" FontWeight="SemiBold" Foreground="White" TextWrapping="Wrap" Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Navigation List -->
                <StackPanel Grid.Row="1" Margin="10,0">
                    <RadioButton Style="{StaticResource SidebarNavItem}" 
                                 IsChecked="{Binding CurrentView, Converter={StaticResource TypeToBooleanConverter}, ConverterParameter={x:Type vm:ProjectSpecificDashboardViewModel}}"
                                 Command="{Binding ShowDashboardCommand}"
                                 Margin="0,2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Path Data="{StaticResource IconDashboard}" Fill="White" Width="16" Height="16" Stretch="Uniform" Opacity="0.7"/>
                            <TextBlock Grid.Column="1" Text="Dashboard" VerticalAlignment="Center" Margin="5,0,0,0"/>
                        </Grid>
                    </RadioButton>

                    <RadioButton Style="{StaticResource SidebarNavItem}" 
                                 IsChecked="{Binding CurrentView, Converter={StaticResource TypeToBooleanConverter}, ConverterParameter={x:Type vm:ProjectTasksViewModel}}"
                                 Command="{Binding ShowTasksCommand}"
                                 Margin="0,2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Path Data="{StaticResource IconList}" Fill="White" Width="16" Height="16" Stretch="Uniform" Opacity="0.7"/>
                            <TextBlock Grid.Column="1" Text="Tasks" VerticalAlignment="Center" Margin="5,0,0,0"/>
                        </Grid>
                    </RadioButton>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Top Info Bar -->
                <RowDefinition Height="*"/>
                <!-- View Hosted Here -->
            </Grid.RowDefinitions>

            <!-- Top Project Banner -->
            <Border Grid.Row="0" Height="80" Padding="30,0" Background="#05FFFFFF" BorderBrush="{StaticResource GlassBorderUltraLight}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" 
                                VerticalAlignment="Center" Margin="0,0,10,0">
                        <TextBlock Text="{Binding Project.Name}" FontSize="24" FontWeight="Bold" Foreground="White" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding Project.Description}" FontSize="12" Foreground="{StaticResource TextSub}" Margin="0,2,0,0"/>
                    </StackPanel>

                    <!-- Site Manager Mini Profile -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border Width="36" Height="36" CornerRadius="18" Background="{StaticResource AccentBlue}">
                            <TextBlock Text="PM" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="12,0,0,0">
                            <TextBlock Text="Project Manager" FontSize="11" Foreground="{StaticResource TextSub}"/>
                            <TextBlock Text="Unassigned" FontSize="13" Foreground="White" FontWeight="SemiBold"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Sub View Content -->
            <ContentControl Grid.Row="1" Content="{Binding CurrentView}" Margin="0"/>
        </Grid>
    </Grid>
</UserControl>

<UserControl x:Class="OCC.WpfClient.Features.AuthHub.Views.AuthView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             xmlns:infra="clr-namespace:OCC.WpfClient.Infrastructure.Converters"
             xmlns:ap="clr-namespace:OCC.WpfClient.Infrastructure.AttachedProperties"
             Loaded="OnAuthViewLoaded">
    <UserControl.Resources>
        <Storyboard x:Key="FlipToRegister">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleX">
                <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="0">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <PowerEase EasingMode="EaseIn" Power="2"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:0.6" Value="1">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <PowerEase EasingMode="EaseOut" Power="2"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="LoginSide" Storyboard.TargetProperty="Visibility" BeginTime="0:0:0.3">
                <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Collapsed}"/>
            </ObjectAnimationUsingKeyFrames>
            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RegisterSide" Storyboard.TargetProperty="Visibility" BeginTime="0:0:0.3">
                <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Visible}"/>
            </ObjectAnimationUsingKeyFrames>
        </Storyboard>
        <Storyboard x:Key="FlipToLogin">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleX">
                <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="0">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <PowerEase EasingMode="EaseIn" Power="2"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:0.6" Value="1">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <PowerEase EasingMode="EaseOut" Power="2"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RegisterSide" Storyboard.TargetProperty="Visibility" BeginTime="0:0:0.3">
                <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Collapsed}"/>
            </ObjectAnimationUsingKeyFrames>
            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ForgotPasswordSide" Storyboard.TargetProperty="Visibility" BeginTime="0:0:0.3">
                <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Collapsed}"/>
            </ObjectAnimationUsingKeyFrames>
            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="LoginSide" Storyboard.TargetProperty="Visibility" BeginTime="0:0:0.3">
                <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Visible}"/>
            </ObjectAnimationUsingKeyFrames>
        </Storyboard>
        <Storyboard x:Key="FlipToForgotPassword">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleX">
                <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="0">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <PowerEase EasingMode="EaseIn" Power="2"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:0.6" Value="1">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <PowerEase EasingMode="EaseOut" Power="2"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="LoginSide" Storyboard.TargetProperty="Visibility" BeginTime="0:0:0.3">
                <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Collapsed}"/>
            </ObjectAnimationUsingKeyFrames>
            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RegisterSide" Storyboard.TargetProperty="Visibility" BeginTime="0:0:0.3">
                <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Collapsed}"/>
            </ObjectAnimationUsingKeyFrames>
            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ForgotPasswordSide" Storyboard.TargetProperty="Visibility" BeginTime="0:0:0.3">
                <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Visible}"/>
            </ObjectAnimationUsingKeyFrames>
        </Storyboard>
    </UserControl.Resources>
    <Grid>
        <!-- Background Image with Overlay -->
        <Grid Background="Black">
            <!-- Outer grid for Bottom Fade -->
            <Grid HorizontalAlignment="Left" VerticalAlignment="Top">
                <Grid.OpacityMask>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="Black" Offset="0.85" />
                        <GradientStop Color="Transparent" Offset="1" />
                    </LinearGradientBrush>
                </Grid.OpacityMask>

                <!-- Inner grid for Right Fade (User's preferred mask) -->
                <Grid>
                    <Grid.OpacityMask>
                        <RadialGradientBrush Center="0,0" GradientOrigin="0,0" RadiusX="1" RadiusY="3">
                            <GradientStop Color="Black" Offset="0.9" />
                            <GradientStop Color="Transparent" Offset="1" />
                        </RadialGradientBrush>
                    </Grid.OpacityMask>

                    <Image Source="/Assets/Images/occ_branded_background_final.png" 
                           Stretch="None"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </Grid>
            </Grid>
        </Grid>

        <!-- Main Layout -->
        <Grid Margin="40">

            <!-- Logo Hanging Top Left -->
            <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,-40,0,0" RenderTransformOrigin="0.5,0">
                <StackPanel.RenderTransform>
                    <RotateTransform x:Name="SwayTransform" />
                </StackPanel.RenderTransform>
                <StackPanel.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="SwayTransform"
                                                 Storyboard.TargetProperty="Angle"
                                                 From="-2" To="2" Duration="0:0:4"
                                                 AutoReverse="True" RepeatBehavior="Forever"
                                                 AccelerationRatio="0.5" DecelerationRatio="0.5"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </StackPanel.Triggers>

                <!-- Cables -->
                <Grid Height="80" Width="180" HorizontalAlignment="Center">
                    <!-- Left Cable -->
                    <Border Width="4" Background="#333" HorizontalAlignment="Left" Margin="20,0,0,0" BorderBrush="#333" BorderThickness="1"/>
                    <!-- Right Cable -->
                    <Border Width="4" Background="#333" HorizontalAlignment="Right" Margin="0,0,20,0" BorderBrush="#333" BorderThickness="1"/>
                </Grid>
                
                <!-- The Sign -->
                <Border Background="{StaticResource CardBackground}" 
                        BorderBrush="{StaticResource OrangeBrush}" 
                        BorderThickness="3"
                        Padding="25,20"
                        CornerRadius="25">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="1" Color="White" Opacity="0.9"/>
                    </Border.Effect>
                    <Image Source="/Assets/Images/occ_logo.png" 
                           Width="220" 
                           Stretch="Uniform" 
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </Border>
            </StackPanel>

            <!-- Building in Progress Sign -->
            <StackPanel HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="0,0,0,0">
                <!-- The Hanging Sign -->
                <Border x:Name="AuthHangingSign" Background="{StaticResource SecondaryGold}" BorderBrush="{DynamicResource AccentBlue}" BorderThickness="2" CornerRadius="4" Padding="10,5" RenderTransformOrigin="0.5,0">
                    <StackPanel>
                        <TextBlock Text="🚧 BUILDING IN PROGRESS" FontWeight="Bold" Foreground="#333" FontSize="11" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding CurrentDate}" Foreground="#333" FontSize="9" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        <TextBlock Text="{Binding CurrentTime}" Foreground="#333" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,0" FontFamily="{StaticResource MichromaFont}"/>
                    </StackPanel>
                </Border>

                <!-- The Pole -->
                <Grid HorizontalAlignment="Center" Margin="0,-2,0,0">
                    <Rectangle Width="6" Height="40" Fill="#333" RadiusX="3" RadiusY="3">
                        <Rectangle.Effect>
                            <DropShadowEffect BlurRadius="4" ShadowDepth="2" Opacity="0.5"/>
                        </Rectangle.Effect>
                    </Rectangle>
                    <Rectangle Width="2" Height="40" Fill="#333" HorizontalAlignment="Left" Margin="1,0,0,0"/>
                </Grid>
            </StackPanel>

            <!-- Login/Register Card (Right Aligned) -->
            <Viewbox HorizontalAlignment="Right" VerticalAlignment="Center" StretchDirection="DownOnly">
                <Grid Width="450" x:Name="CardContainer">
                    <Grid.RenderTransform>
                        <ScaleTransform x:Name="CardScale" ScaleX="1" CenterX="225" />
                    </Grid.RenderTransform>

                    <!-- Front Side (Login) -->
                    <Border x:Name="LoginSide" Style="{StaticResource GlassCard}" Padding="30,20" BorderThickness="2,3" 
                            BorderBrush="{StaticResource ChevronPatternBrush}" CornerRadius="0">
                        <StackPanel>
                            <!-- Header -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Border BorderBrush="{StaticResource AccentBlue}" BorderThickness="0,0,0,2" Padding="0,0,0,5">
                                    <TextBlock Text="Login" FontFamily="{StaticResource MichromaFont}" FontSize="{StaticResource FontSizeHeader}" Foreground="{StaticResource TextMain}" FontWeight="SemiBold"/>
                                </Border>
                                <Button Style="{StaticResource ModernTabButton}" Content="Register" Margin="40,0,0,7" 
                                        Foreground="{StaticResource TextSub}" FontFamily="{StaticResource MichromaFont}" FontSize="{StaticResource FontSizeHeader}" Cursor="Hand"
                                        Click="OnRegisterClick"/>
                            </StackPanel>

                            <TextBlock Text="Welcome back! Please login to your account" Foreground="{StaticResource TextMain}" FontSize="{StaticResource FontSizeLarge}" TextWrapping="Wrap" Margin="0,0,0,10"/>

                            <!-- Inputs -->
                            <StackPanel Margin="0,10,0,0">
                                <TextBox x:Name="EmailTextBox" Style="{StaticResource ModernInput}" 
                                         ap:WatermarkProperties.Watermark="Email"
                                         Text="{Binding LoginModel.Email, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                         KeyDown="OnLoginFieldKeyDown"/>
                            </StackPanel>

                            <StackPanel Margin="0,15,0,0">
                                <PasswordBox Name="LoginPasswordBox" 
                                             ap:WatermarkProperties.Watermark="Password"
                                             Style="{StaticResource ModernPasswordInput}"
                                             KeyDown="OnLoginFieldKeyDown"/>
                            </StackPanel>

                            <!-- Options -->
                            <Grid Margin="0,20,0,15">
                                <CheckBox Style="{StaticResource ModernCheckBox}" 
                                          Content="Remember Me" 
                                          IsChecked="{Binding LoginModel.RememberMe}" 
                                          Foreground="{StaticResource TextSub}"/>
                                <TextBlock Text="Forget Password?" 
                                           HorizontalAlignment="Right" 
                                           Foreground="{StaticResource TextSub}" 
                                           Cursor="Hand" 
                                           VerticalAlignment="Center" 
                                           FontSize="{StaticResource FontSizeSmall}"
                                           MouseLeftButtonUp="OnForgotPasswordClick"
                                           Background="Transparent"/>
                            </Grid>

                            <!-- Environment Selection (Dev Only) -->
                            <StackPanel Margin="0,15,0,0" Visibility="{Binding IsDevUser, Converter={StaticResource VisibilityConverter}}">
                                <TextBlock Text="Server Environment" Foreground="{StaticResource TextSub}" Margin="0,0,0,5" FontSize="{StaticResource FontSizeSmall}"/>
                                <ComboBox Style="{StaticResource ModernComboBox}"
                                          ItemsSource="{Binding Environments}"
                                          SelectedItem="{Binding SelectedEnvironment}"/>
                            </StackPanel>

                            <!-- Login Button -->
                            <Button Style="{StaticResource ModernPrimaryButton}" 
                                    Command="{Binding LoginCommand}"
                                    CommandParameter="{Binding ElementName=LoginPasswordBox}"
                                    Tag="{Binding IsBusy}"
                                    Content="Login" Margin="0,10,0,0" />

                            <TextBlock Text="Don't have an account? Register" Foreground="{StaticResource TextSub}" HorizontalAlignment="Center" Margin="0,20,0,0" FontSize="{StaticResource FontSizeSmall}" Cursor="Hand" MouseLeftButtonUp="OnRegisterClick" Background="Transparent" />
                            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorRed}" HorizontalAlignment="Center" Margin="0,10,0,0" TextWrapping="Wrap" TextAlignment="Center" Visibility="{Binding ErrorMessage, Converter={StaticResource VisibilityConverter}}"/>
                        </StackPanel>
                    </Border>

                    <!-- Register -->
                    <Border x:Name="RegisterSide" Style="{StaticResource GlassCard}" Visibility="Collapsed" Padding="30,20" BorderThickness="2,3" BorderBrush="{StaticResource ChevronPatternBrush}" CornerRadius="0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Button Style="{StaticResource ModernTabButton}" Content="Login" 
                                        Foreground="{StaticResource TextSub}" 
                                        FontFamily="{StaticResource MichromaFont}" 
                                        FontSize="{StaticResource FontSizeHeader}" Cursor="Hand"
                                        Click="OnLoginClick"/>
                                <Border BorderBrush="{StaticResource AccentBlue}" BorderThickness="0,0,0,2" 
                                        Padding="0,0,0,5" Margin="40,0,0,0">
                                    <TextBlock Text="Register" FontFamily="{StaticResource MichromaFont}" FontSize="{StaticResource FontSizeHeader}" Foreground="{StaticResource TextMain}" FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>

                            <TextBlock Text="Join us! Register your account" Foreground="{StaticResource TextMain}" FontSize="{StaticResource FontSizeLarge}" Margin="0,0,0,10"/>

                            <UniformGrid Columns="2">
                                <StackPanel Margin="0,0,5,0">
                                    <TextBox Style="{StaticResource ModernInput}" 
                                             ap:WatermarkProperties.Watermark="First Name"
                                             Text="{Binding RegisterModel.FirstName, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>
                                </StackPanel>
                                <StackPanel Margin="5,0,0,0">
                                    <TextBox Style="{StaticResource ModernInput}" 
                                             ap:WatermarkProperties.Watermark="Last Name"
                                             Text="{Binding RegisterModel.LastName, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>
                                </StackPanel>
                            </UniformGrid>

                            <StackPanel Margin="0,15,0,0">
                                <TextBox Style="{StaticResource ModernInput}" 
                                         ap:WatermarkProperties.Watermark="Email"
                                         Text="{Binding RegisterModel.Email, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>
                            </StackPanel>

                            <StackPanel Margin="0,15,0,0">
                                <PasswordBox Name="RegisterPasswordBox" 
                                             ap:WatermarkProperties.Watermark="Password"
                                             Style="{StaticResource ModernPasswordInput}"/>
                            </StackPanel>

                            <Button Style="{StaticResource ModernPrimaryButton}" 
                                    Command="{Binding RegisterCommand}"
                                    CommandParameter="{Binding ElementName=RegisterPasswordBox}"
                                    Tag="{Binding IsBusy}"
                                    Content="Create Account" Margin="0,15,0,0" />

                            <TextBlock Text="By registering, you agree to our Terms" Foreground="{StaticResource TextSub}" HorizontalAlignment="Center" Margin="0,10,0,0" FontSize="{StaticResource FontSizeSmall}"/>
                            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorRed}" HorizontalAlignment="Center" Margin="0,10,0,0" TextWrapping="Wrap" TextAlignment="Center" Visibility="{Binding ErrorMessage, Converter={StaticResource VisibilityConverter}}"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Forgot Password -->
                    <Border x:Name="ForgotPasswordSide" Style="{StaticResource GlassCard}" Visibility="Collapsed" Padding="30,20" BorderThickness="4,6" BorderBrush="{StaticResource ChevronPatternBrush}" CornerRadius="0">
                        <StackPanel>
                            <Border BorderBrush="{StaticResource AccentBlue}" BorderThickness="0,0,0,2" Padding="0,0,0,5" Margin="0,0,0,10">
                                <TextBlock Text="Forgot Password" FontFamily="{StaticResource MichromaFont}" FontSize="{StaticResource FontSizeHeader}" Foreground="{StaticResource TextMain}" FontWeight="SemiBold"/>
                            </Border>

                            <!-- Step 1: Request Reset -->
                            <StackPanel Visibility="{Binding IsResetCodeSent, Converter={StaticResource VisibilityConverter}, ConverterParameter=Invert}">
                                <TextBlock Text="Enter your email to receive a reset code." Foreground="{StaticResource TextMain}" FontSize="{StaticResource FontSizeLarge}" Margin="0,0,0,20" TextWrapping="Wrap"/>
                                <TextBox Style="{StaticResource ModernInput}" 
                                         ap:WatermarkProperties.Watermark="Email Address"
                                         Text="{Binding ForgotPasswordEmail, UpdateSourceTrigger=PropertyChanged}"/>
                                <Button Style="{StaticResource ModernPrimaryButton}" 
                                        Content="Send Reset Code" 
                                        Command="{Binding SendResetRequestCommand}"
                                        Margin="0,20,0,0"/>
                            </StackPanel>

                            <!-- Step 2: Set New Password -->
                            <StackPanel Visibility="{Binding IsResetCodeSent, Converter={StaticResource VisibilityConverter}}">
                                <TextBlock Text="Enter the code sent to your email and your new password." Foreground="{StaticResource TextMain}" FontSize="{StaticResource FontSizeLarge}" Margin="0,0,0,20" TextWrapping="Wrap"/>
                                <TextBox Style="{StaticResource ModernInput}" 
                                         ap:WatermarkProperties.Watermark="Reset Code"
                                         Text="{Binding ResetCode, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,0,15"/>
                                <PasswordBox Name="NewPasswordBox" 
                                             ap:WatermarkProperties.Watermark="New Password"
                                             Style="{StaticResource ModernPasswordInput}"/>
                                <Button Style="{StaticResource ModernPrimaryButton}" 
                                        Content="Update Password" 
                                        Command="{Binding VerifyResetAndSaveCommand}"
                                        CommandParameter="{Binding ElementName=NewPasswordBox}"
                                        Margin="0,20,0,0"/>
                            </StackPanel>

                            <TextBlock Text="Back to Login" Foreground="{StaticResource TextSub}" HorizontalAlignment="Center" Margin="0,20,0,0" FontSize="{StaticResource FontSizeSmall}" Cursor="Hand" MouseLeftButtonUp="OnLoginClick" Background="Transparent" />
                            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorRed}" HorizontalAlignment="Center" Margin="0,10,0,0" TextWrapping="Wrap" TextAlignment="Center" Visibility="{Binding ErrorMessage, Converter={StaticResource VisibilityConverter}}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Viewbox>
        </Grid>


    </Grid>
</UserControl>


<UserControl x:Class="OCC.WpfClient.Features.AuthHub.Views.AuthView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             xmlns:infra="clr-namespace:OCC.WpfClient.Infrastructure.Converters"
             d:DesignHeight="700" d:DesignWidth="1200">
    <UserControl.Resources>
        <Storyboard x:Key="FlipToRegister">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleX">
                <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="0">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <PowerEase EasingMode="EaseIn" Power="2"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:0.6" Value="1">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <PowerEase EasingMode="EaseOut" Power="2"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="LoginSide" Storyboard.TargetProperty="Visibility" BeginTime="0:0:0.3">
                <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Collapsed}"/>
            </ObjectAnimationUsingKeyFrames>
            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RegisterSide" Storyboard.TargetProperty="Visibility" BeginTime="0:0:0.3">
                <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Visible}"/>
            </ObjectAnimationUsingKeyFrames>
        </Storyboard>
        <Storyboard x:Key="FlipToLogin">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleX">
                <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="0">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <PowerEase EasingMode="EaseIn" Power="2"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:0.6" Value="1">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <PowerEase EasingMode="EaseOut" Power="2"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RegisterSide" Storyboard.TargetProperty="Visibility" BeginTime="0:0:0.3">
                <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Collapsed}"/>
            </ObjectAnimationUsingKeyFrames>
            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="LoginSide" Storyboard.TargetProperty="Visibility" BeginTime="0:0:0.3">
                <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Visible}"/>
            </ObjectAnimationUsingKeyFrames>
        </Storyboard>
    </UserControl.Resources>
    <Grid>
        <!-- Background Image with Overlay -->
        <Grid>
            <Image Source="/Assets/Images/occ_future_logo.png" Stretch="UniformToFill" />
            <Rectangle Opacity="0.9">
            </Rectangle>
        </Grid>

        <!-- Main Layout -->
        <Grid Margin="40">
            <!-- Logo Top Left -->
            <Image Source="/Assets/Images/occ_logo2.png" 
                   Width="250" HorizontalAlignment="Left" VerticalAlignment="Top" 
                   Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>

            <!-- Login/Register Card (Right Aligned) -->
            <Viewbox HorizontalAlignment="Right" VerticalAlignment="Center" StretchDirection="DownOnly">
                <Grid Width="450" x:Name="CardContainer">
                    <Grid.RenderTransform>
                        <ScaleTransform x:Name="CardScale" ScaleX="1" CenterX="225" />
                    </Grid.RenderTransform>

                    <!-- Front Side (Login) -->
                    <Border x:Name="LoginSide" Style="{StaticResource GlassCard}" Padding="40" BorderThickness="2" BorderBrush="{StaticResource OrangeBrush}">
                        <StackPanel>
                            <!-- Header -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Border BorderBrush="{StaticResource AccentBlue}" BorderThickness="0,0,0,2" Padding="0,0,0,5">
                                    <TextBlock Text="Login" FontFamily="{StaticResource MichromaFont}" FontSize="{StaticResource FontSizeHeader}" Foreground="White" FontWeight="SemiBold"/>
                                </Border>
                                <Button Style="{StaticResource ModernTabButton}" Content="Register" Margin="40,0,0,7" 
                                        Foreground="{StaticResource TextSub}" FontFamily="{StaticResource MichromaFont}" FontSize="{StaticResource FontSizeHeader}" Cursor="Hand"
                                        Click="OnRegisterClick"/>
                            </StackPanel>

                            <TextBlock Text="Welcome back! Please login to your account" Foreground="White" FontSize="{StaticResource FontSizeLarge}" TextWrapping="Wrap" Margin="0,0,0,10"/>

                            <!-- Inputs -->
                            <StackPanel Margin="0,10,0,0">
                                <TextBlock Text="Email" Foreground="{StaticResource TextSub}" Margin="0,0,0,5" FontSize="{StaticResource FontSizeSmall}"/>
                                <TextBox Style="{StaticResource ModernInput}" 
                                         Text="{Binding LoginModel.Email, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>
                            </StackPanel>

                            <StackPanel Margin="0,15,0,0">
                                <TextBlock Text="Password" Foreground="{StaticResource TextSub}" Margin="0,0,0,5" FontSize="{StaticResource FontSizeSmall}"/>
                                <PasswordBox Name="LoginPasswordBox" Padding="10" Style="{StaticResource ModernPasswordInput}"/>
                            </StackPanel>

                            <!-- Options -->
                            <Grid Margin="0,20,0,15">
                                <CheckBox Style="{StaticResource ModernCheckBox}" 
                                          Content="Remember Me" 
                                          IsChecked="{Binding LoginModel.RememberMe}" 
                                          Foreground="{StaticResource TextSub}"/>
                                <TextBlock Text="Forget Password?" 
                                           HorizontalAlignment="Right" 
                                           Foreground="{StaticResource TextSub}" 
                                           Cursor="Hand" 
                                           VerticalAlignment="Center" 
                                           FontSize="{StaticResource FontSizeSmall}"/>
                            </Grid>

                            <!-- Environment Selection (Dev Only) -->
                            <StackPanel Margin="0,15,0,0" Visibility="{Binding IsDevUser, Converter={StaticResource VisibilityConverter}}">
                                <TextBlock Text="Server Environment" Foreground="{StaticResource TextSub}" Margin="0,0,0,5" FontSize="{StaticResource FontSizeSmall}"/>
                                <ComboBox Style="{StaticResource ModernComboBox}"
                                          ItemsSource="{Binding Environments}"
                                          SelectedItem="{Binding SelectedEnvironment}"/>
                            </StackPanel>

                            <!-- Login Button -->
                            <Button Style="{StaticResource ModernPrimaryButton}" 
                                    Command="{Binding LoginCommand}"
                                    CommandParameter="{Binding ElementName=LoginPasswordBox}"
                                    Tag="{Binding IsBusy}"
                                    Content="Login" Margin="0,10,0,0" />

                            <TextBlock Text="Don't have an account? Register" Foreground="{StaticResource TextSub}" HorizontalAlignment="Center" Margin="0,20,0,0" FontSize="{StaticResource FontSizeSmall}" Cursor="Hand" MouseLeftButtonUp="OnRegisterClick" Background="Transparent" />
                            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorRed}" HorizontalAlignment="Center" Margin="0,10,0,0" Visibility="{Binding ErrorMessage, Converter={StaticResource VisibilityConverter}}"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="RegisterSide" Style="{StaticResource GlassCard}" Padding="40" 
                            Visibility="Collapsed" BorderThickness="2" BorderBrush="{StaticResource OrangeBrush}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Button Style="{StaticResource ModernTabButton}" Content="Login" 
                                        Foreground="{StaticResource TextSub}" 
                                        FontFamily="{StaticResource MichromaFont}" 
                                        FontSize="{StaticResource FontSizeHeader}" Cursor="Hand"
                                        Click="OnLoginClick"/>
                                <Border BorderBrush="{StaticResource AccentBlue}" BorderThickness="0,0,0,2" 
                                        Padding="0,0,0,5" Margin="40,0,0,0">
                                    <TextBlock Text="Register" FontFamily="{StaticResource MichromaFont}" FontSize="{StaticResource FontSizeHeader}" Foreground="White" FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>

                            <TextBlock Text="Join us! Register your account" Foreground="White" FontSize="{StaticResource FontSizeLarge}" Margin="0,0,0,10"/>

                            <UniformGrid Columns="2">
                                <StackPanel Margin="0,0,5,0">
                                    <TextBlock Text="First Name" Foreground="{StaticResource TextSub}" FontSize="{StaticResource FontSizeSmall}" Margin="0,0,0,3"/>
                                    <TextBox Style="{StaticResource ModernInput}" 
                                             Text="{Binding RegisterModel.FirstName, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>
                                </StackPanel>
                                <StackPanel Margin="5,0,0,0">
                                    <TextBlock Text="Last Name" Foreground="{StaticResource TextSub}" FontSize="{StaticResource FontSizeSmall}" Margin="0,0,0,3"/>
                                    <TextBox Style="{StaticResource ModernInput}" 
                                             Text="{Binding RegisterModel.LastName, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>
                                </StackPanel>
                            </UniformGrid>

                            <StackPanel Margin="0,15,0,0">
                                <TextBlock Text="Email" Foreground="{StaticResource TextSub}" FontSize="{StaticResource FontSizeSmall}" Margin="0,0,0,3"/>
                                <TextBox Style="{StaticResource ModernInput}" 
                                         Text="{Binding RegisterModel.Email, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>
                            </StackPanel>

                            <StackPanel Margin="0,15,0,0">
                                <TextBlock Text="Password" Foreground="{StaticResource TextSub}" FontSize="{StaticResource FontSizeSmall}" Margin="0,0,0,3"/>
                                <PasswordBox Name="RegisterPasswordBox" Padding="10" Style="{StaticResource ModernPasswordInput}"/>
                            </StackPanel>

                            <Button Style="{StaticResource ModernPrimaryButton}" 
                                    Command="{Binding RegisterCommand}"
                                    CommandParameter="{Binding ElementName=RegisterPasswordBox}"
                                    Tag="{Binding IsBusy}"
                                    Content="Create Account" Margin="0,15,0,0" />

                            <TextBlock Text="By registering, you agree to our Terms" Foreground="{StaticResource TextSub}" HorizontalAlignment="Center" Margin="0,10,0,0" FontSize="{StaticResource FontSizeSmall}"/>
                            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorRed}" HorizontalAlignment="Center" Margin="0,10,0,0" Visibility="{Binding ErrorMessage, Converter={StaticResource VisibilityConverter}}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Viewbox>
        </Grid>


    </Grid>
</UserControl>

<UserControl x:Class="OCC.WpfClient.Features.Main.Views.MainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:OCC.WpfClient.Features.Main.ViewModels"
             xmlns:views="clr-namespace:OCC.WpfClient.Features.Main.Views"
             xmlns:empViews="clr-namespace:OCC.WpfClient.Features.Employees.Views"
             xmlns:empVm="clr-namespace:OCC.WpfClient.Features.Employees.ViewModels"
             mc:Ignorable="d"
             d:Height="700" d:Width="1024">
    
    <UserControl.Resources>
        <Storyboard x:Key="ExpandSidebar">
            <DoubleAnimation Storyboard.TargetName="SidebarBorder" 
                             Storyboard.TargetProperty="Width" 
                             To="200" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="CollapseSidebar">
            <DoubleAnimation Storyboard.TargetName="SidebarBorder" 
                             Storyboard.TargetProperty="Width" 
                             To="72" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type empVm:EmployeeListViewModel}">
            <empViews:EmployeeListView />
        </DataTemplate>
    </UserControl.Resources>

    <Grid x:Name="ShellRoot" 
          Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ContentControl}}"
          Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=ContentControl}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Top Menu (File, etc.) -->
            <RowDefinition Height="*" />    <!-- Main Shell -->
        </Grid.RowDefinitions>

        <!-- Top Menu (File, Edit, etc.) -->
        <Menu Grid.Row="0" WindowChrome.IsHitTestVisibleInChrome="True">
            <MenuItem Header="File">
                <MenuItem Header="Exit" Command="{Binding LogoutCommand}">
                    <MenuItem.Icon>
                        <Path Data="{StaticResource IconLogout}" Fill="White" Stretch="Uniform" Width="14" Height="14"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="Edit">
                <MenuItem Header="Cut"/>
                <MenuItem Header="Copy"/>
                <MenuItem Header="Paste"/>
            </MenuItem>
            <MenuItem Header="Hubs">
                <MenuItem Header="Home">
                    <MenuItem.Icon>
                        <Path Data="{StaticResource IconSummary}" Fill="White" Stretch="Uniform" Width="14" Height="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Employees">
                    <MenuItem.Icon>
                        <Path Data="{StaticResource IconTeam}" Fill="White" Stretch="Uniform" Width="14" Height="14"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="Help">
                <MenuItem Header="About"/>
            </MenuItem>
        </Menu>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Full Window Background -->
            <Image Grid.ColumnSpan="2" Source="/Assets/Images/occ_future_logo.png" Stretch="UniformToFill" />
            <Rectangle Grid.ColumnSpan="2" Fill="{StaticResource BackgroundDark}" Opacity="0.85" />

            <!-- Sidebar -->
            <Border x:Name="SidebarBorder" Grid.Column="0" Width="72" Style="{StaticResource ModernSidebar}" Background="Transparent" MouseLeftButtonDown="OnSidebarClick">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" /> <!-- Logo/Brand -->
                        <RowDefinition Height="Auto" /> <!-- Workspace hubs -->
                        <RowDefinition Height="*" />    <!-- Nav Items -->
                        <RowDefinition Height="Auto" /> <!-- User Profile -->
                    </Grid.RowDefinitions>

                    <!-- Branding -->
                    <StackPanel Grid.Row="0" Margin="0,15,0,0">
                        <Grid Height="60">
                            <!-- Expanded State Brand -->
                            <Border Margin="15,0" 
                                    Visibility="{Binding IsSidebarMinimized, Converter={StaticResource VisibilityConverter}, ConverterParameter='Invert'}">
                                <Image Source="/Assets/Images/occ_logo.png" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>

                            <!-- Minimized State Brand Icon (Centered like Avalonia) -->
                            <Border Width="42" Height="42" HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Visibility="{Binding IsSidebarMinimized, Converter={StaticResource VisibilityConverter}}">
                                <Image Source="/Assets/Images/occ_logo.png" Stretch="Uniform" Margin="2"/>
                            </Border>
                        </Grid>
                        <Border Height="1" Background="{StaticResource GlassBorderUltraLight}" Margin="10,20,10,0" />
                    </StackPanel>

                    <!-- Workspace (Hubs) -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,20">
                        <Grid Margin="15,10,15,10">
                            <TextBlock Text="WORKSPACE" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSub}" Opacity="0.5"
                                       Visibility="{Binding IsSidebarMinimized, Converter={StaticResource VisibilityConverter}, ConverterParameter='Invert'}"/>
                            <Border Height="1" Background="{StaticResource GlassBorderUltraLight}" Opacity="0.3" VerticalAlignment="Center"
                                    Visibility="{Binding IsSidebarMinimized, Converter={StaticResource VisibilityConverter}}"/>
                        </Grid>
                        
                        <ItemsControl ItemsSource="{Binding OpenHubs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <RadioButton Style="{StaticResource SidebarNavItem}" 
                                                 IsChecked="{Binding IsActiveHub, Mode=TwoWay}"
                                                 GroupName="WorkspaceNav"
                                                 Command="{Binding DataContext.NavigateToHubCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                 CommandParameter="{Binding}"
                                                 ToolTip="{Binding Title}">
                                        <Grid HorizontalAlignment="Stretch">
                                            <Grid Width="40" Height="40" HorizontalAlignment="Center">
                                                <Path Data="{StaticResource IconSummary}" Fill="White" HorizontalAlignment="Center" VerticalAlignment="Center" Width="18" Height="18" Stretch="Uniform" Opacity="0.6"/>
                                            </Grid>
                                            
                                            <TextBlock Grid.Column="1" Text="{Binding Title}" VerticalAlignment="Center" FontSize="14" Margin="55,0,0,0"
                                                       Visibility="{Binding DataContext.IsSidebarMinimized, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource VisibilityConverter}, ConverterParameter='Invert'}"/>
                                        </Grid>
                                    </RadioButton>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Navigation -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding NavigationItems}" Margin="0,10">
                            <ItemsControl.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.HeaderTemplate>
                                        <DataTemplate>
                                            <Grid Margin="15,20,15,10">
                                                <TextBlock Text="{Binding Name}" 
                                                           Foreground="{StaticResource TextSub}" 
                                                           FontSize="11" 
                                                           FontWeight="Bold" 
                                                           Opacity="0.5"
                                                           Visibility="{Binding DataContext.IsSidebarMinimized, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource VisibilityConverter}, ConverterParameter='Invert'}"/>
                                                <Border Height="1" Background="{StaticResource GlassBorderUltraLight}" Opacity="0.3" VerticalAlignment="Center"
                                                        Visibility="{Binding DataContext.IsSidebarMinimized, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource VisibilityConverter}}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </GroupStyle.HeaderTemplate>
                                </GroupStyle>
                            </ItemsControl.GroupStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <RadioButton Style="{StaticResource SidebarNavItem}" 
                                                 IsChecked="{Binding IsActive, Mode=TwoWay}"
                                                 GroupName="PrimaryNav"
                                                 Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                 CommandParameter="{Binding}"
                                                 ToolTip="{Binding Label}">
                                        <Grid HorizontalAlignment="Stretch">
                                            <Grid x:Name="IconContainer" Width="40" Height="40" HorizontalAlignment="Center">
                                                <Ellipse x:Name="ActiveIndicator" Fill="{DynamicResource AccentBlue}" Opacity="0" Margin="-2">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect BlurRadius="10" Color="{StaticResource AccentBlueColor}" ShadowDepth="0" Opacity="0.5"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                                <Path x:Name="IconPath" Fill="White" Opacity="0.6" Width="18" Height="18" Stretch="Uniform">
                                                    <Path.Style>
                                                        <Style TargetType="Path">
                                                            <Setter Property="Fill" Value="White"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Label}" Value="Dashboard">
                                                                    <Setter Property="Data" Value="{StaticResource IconSummary}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Label}" Value="Global Calendar">
                                                                    <Setter Property="Data" Value="{StaticResource IconClock}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Label}" Value="Wages Hub">
                                                                    <Setter Property="Data" Value="{StaticResource IconDatabase}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Label}" Value="Inventory">
                                                                    <Setter Property="Data" Value="{StaticResource IconList}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Label}" Value="Projects">
                                                                    <Setter Property="Data" Value="{StaticResource IconPortfolio}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Label}" Value="Employees">
                                                                    <Setter Property="Data" Value="{StaticResource IconTeam}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Label}" Value="Settings">
                                                                    <Setter Property="Data" Value="{StaticResource IconBug}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Path.Style>
                                                </Path>
                                            </Grid>
                                            
                                            <TextBlock Grid.Column="1" Text="{Binding Label}" VerticalAlignment="Center" FontSize="15" Margin="55,0,0,0"
                                                       Visibility="{Binding DataContext.IsSidebarMinimized, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource VisibilityConverter}, ConverterParameter='Invert'}"/>
                                        </Grid>
                                    </RadioButton>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- User Profile -->
                    <Border Grid.Row="3" Background="{DynamicResource GlassBackgroundVibrant}" BorderBrush="{StaticResource GlassBorderUltraLight}" BorderThickness="0,1,0,0" Padding="5,15">
                        <Grid>
                            <!-- NK Circle (Centered when collapsed) -->
                            <Border x:Name="ProfileCircle" Width="42" Height="42" HorizontalAlignment="Center" CornerRadius="21" Background="{StaticResource AccentBlue}">
                                <TextBlock Text="NK" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                            </Border>
                            
                            <StackPanel Orientation="Horizontal" Margin="55,0,0,0" VerticalAlignment="Center"
                                          Visibility="{Binding IsSidebarMinimized, Converter={StaticResource VisibilityConverter}, ConverterParameter='Invert'}">
                                <TextBlock Text="{Binding UserName}" Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock Text="{Binding UserEmail}" Foreground="{StaticResource TextSub}" FontSize="11"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Content Area -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" /> <!-- Top Bar (Title + Nav icons) -->
                    <RowDefinition Height="*" />    <!-- Main Content -->
                    <RowDefinition Height="32" />   <!-- Status Bar -->
                </Grid.RowDefinitions>

                <!-- Top Bar -->
                <Border Grid.Row="0" Height="50" Padding="30,0" BorderBrush="{StaticResource GlassBorderUltraLight}" BorderThickness="0,0,0,1">
                    <Grid>
                        <TextBlock Text="{Binding ActiveHub.Title}" VerticalAlignment="Center" 
                                 FontFamily="{StaticResource MichromaFont}" FontSize="14" Foreground="White" Opacity="0.9"/>
                        
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button Background="Transparent" BorderThickness="0" Foreground="White" Margin="0,0,20,0" Opacity="0.6"
                                    Command="{Binding LogoutCommand}">
                                <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="18"/>
                            </Button>
                            <Button Background="Transparent" BorderThickness="0" Foreground="White" Opacity="0.6">
                                <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="18"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>


                <!-- Active Content -->
                <ContentControl Grid.Row="1" Content="{Binding ActiveHub}" Margin="10"/>

                <!-- Status Bar (Complete Parity) -->
                <Border Grid.Row="2" Background="#1A000000" BorderBrush="{StaticResource GlassBorderUltraLight}" BorderThickness="0,1,0,0" Padding="15,0">
                    <Grid>
                        <!-- Left Section -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                                <Path Data="{DynamicResource IconClock}" Fill="{DynamicResource TextSub}" Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center" Stretch="Uniform"/>
                                <TextBlock Text="{Binding UserActivityStatus}" Foreground="{StaticResource TextSub}" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                            
                            <Border Width="1" Height="12" Background="{StaticResource GlassBorderUltraLight}" VerticalAlignment="Center" Margin="0,0,20,0"/>
                            
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconDatabase}" Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center" Stretch="Uniform">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Setter Property="Fill" Value="{StaticResource ErrorRed}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDbConnected}" Value="True">
                                                    <Setter Property="Fill" Value="#10B981"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                                <TextBlock Text="{Binding DbStatusText}" Foreground="{StaticResource TextSub}" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Right Section -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button Background="Transparent" BorderThickness="0" Margin="0,0,15,0">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{DynamicResource IconBug}" Fill="{DynamicResource SecondaryGold}" Width="12" Height="12" Margin="0,1,8,0" VerticalAlignment="Center" Stretch="Uniform"/>
                                    <TextBlock Text="Report Bug" Foreground="{StaticResource TextSub}" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Border Width="1" Height="12" Background="{StaticResource GlassBorderUltraLight}" VerticalAlignment="Center" Margin="0,0,15,0"/>

                            <StackPanel Orientation="Horizontal">
                                <Path Data="{DynamicResource IconUserOnline}" Fill="{DynamicResource AccentBlue}" Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center" Stretch="Uniform"/>
                                <TextBlock Text="Online: " Foreground="{StaticResource TextSub}" FontSize="11" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding OnlineCount}" Foreground="White" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>

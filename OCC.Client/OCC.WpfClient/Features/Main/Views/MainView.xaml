<UserControl x:Class="OCC.WpfClient.Features.Main.Views.MainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:vm="clr-namespace:OCC.WpfClient.Features.Main.ViewModels"
             xmlns:views="clr-namespace:OCC.WpfClient.Features.Main.Views"
             xmlns:empViews="clr-namespace:OCC.WpfClient.Features.EmployeeHub.Views"
             xmlns:empVm="clr-namespace:OCC.WpfClient.Features.EmployeeHub.ViewModels"
             xmlns:chatViews="clr-namespace:OCC.WpfClient.Features.ChatHub.Views"
             xmlns:chatVm="clr-namespace:OCC.WpfClient.Features.ChatHub.ViewModels"
             xmlns:shViews="clr-namespace:OCC.WpfClient.Features.SupportHub.Views"
             xmlns:shVm="clr-namespace:OCC.WpfClient.Features.SupportHub.ViewModels"
             mc:Ignorable="d"
             d:Height="700" d:Width="1024">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/FeatureTemplates.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Storyboard x:Key="ExpandSidebar">
                <DoubleAnimation Storyboard.TargetName="SidebarBorder" 
                                 Storyboard.TargetProperty="Width" 
                                 To="280" Duration="0:0:0.6"
                                 BeginTime="0:0:0.3">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>
            <Storyboard x:Key="CollapseSidebar">
                <DoubleAnimation Storyboard.TargetName="SidebarBorder" 
                                 Storyboard.TargetProperty="Width" 
                                 To="72" Duration="0:0:0.8">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>

            <Storyboard x:Key="BusySpinnerAnimation">
                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                 From="0" To="360" Duration="0:0:1"
                                 RepeatBehavior="Forever" />
            </Storyboard>

            <Style x:Key="OverlayCloseButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#25FFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#40FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid x:Name="ShellRoot">
        <!-- Full Window Background (No row constraints) -->
        <Image Source="/Assets/Images/occ_future_logo.png" Stretch="UniformToFill" />
        <Rectangle Fill="{StaticResource BackgroundDark}" Opacity="0.75" />
        
        <!-- Dynamic Hub Backdrop -->
        <Rectangle Fill="Black" Opacity="0" IsHitTestVisible="False">
            <Rectangle.Style>
                <Style TargetType="Rectangle">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ActiveHub, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter='Invert'}" Value="Visible">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0.35" Duration="0:0:0.4"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.6"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Rectangle.Style>
        </Rectangle>

        <!-- Top Menu (File, Edit, etc.) -->
        <!-- Floating at the top, matching the MainWindow's height, but not using Panel.ZIndex to avoid blocking window buttons -->
        <Grid VerticalAlignment="Top" Height="32" Background="Transparent">
            <Menu HorizontalAlignment="Left" Background="Transparent" WindowChrome.IsHitTestVisibleInChrome="True">
                <MenuItem Header="File">
                    <MenuItem Header="Exit" Command="{Binding ExitAppCommand}">
                        <MenuItem.Icon>
                            <Path Data="{StaticResource IconLogout}" Fill="White" Stretch="Uniform" Width="14" Height="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuItem>
                <MenuItem Header="Edit">
                    <MenuItem Header="Cut"/>
                    <MenuItem Header="Copy"/>
                    <MenuItem Header="Paste"/>
                    <MenuItem Header="Delete"/>
                </MenuItem>
                <MenuItem Header="Hubs">
                    <MenuItem Header="Chat" Command="{Binding NavigateCommand}" CommandParameter="Chat">
                        <MenuItem.Icon>
                            <Path Data="{StaticResource IconChat}" Fill="White" Stretch="Uniform" Width="14" Height="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Customers" Command="{Binding NavigateCommand}" CommandParameter="Customers">
                        <MenuItem.Icon>
                            <Path Data="{StaticResource IconAddUser}" Fill="White" Stretch="Uniform" Width="14" Height="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Procurement" Command="{Binding NavigateCommand}" CommandParameter="Procurement">
                        <MenuItem.Icon>
                            <Path Data="{StaticResource IconDatabase}" Fill="White" Stretch="Uniform" Width="14" Height="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Admin">
                        <MenuItem.Icon>
                            <Path Data="{StaticResource IconGear}" Fill="White" Stretch="Uniform" Width="14" Height="14"/>
                        </MenuItem.Icon>
                        <MenuItem Header="User Management" Command="{Binding NavigateCommand}" CommandParameter="UserManagement">
                            <MenuItem.Icon>
                                <Path Data="{StaticResource IconTeam}" Fill="White" Stretch="Uniform" Width="14" Height="14"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Employee Management" Command="{Binding NavigateCommand}" CommandParameter="Team">
                            <MenuItem.Icon>
                                <Path Data="{StaticResource IconTeam}" Fill="White" Stretch="Uniform" Width="14" Height="14"/>
                            </MenuItem.Icon>
                        </MenuItem>
                    </MenuItem>
                </MenuItem>
                <MenuItem Header="Window">
                    <MenuItem Header="Close All Tabs" Command="{Binding CloseAllTabsCommand}"/>
                    <MenuItem Header="Close Other" Command="{Binding CloseOtherTabsCommand}" CommandParameter="{Binding ActiveHub}"/>
                    <MenuItem Header="Close to the Right" Command="{Binding CloseTabsToRightCommand}" CommandParameter="{Binding ActiveHub}"/>
                </MenuItem>
                    <MenuItem Header="Help">
                    <MenuItem Header="Support Hub" Command="{Binding ShowSupportHubCommand}">
                        <MenuItem.Icon>
                            <Path Data="{StaticResource IconBug}" Fill="White" Stretch="Uniform" Width="14" Height="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator Background="{StaticResource GlassBorderUltraLight}"/>
                    <MenuItem Header="Check for Updates"/>
                    <MenuItem Header="Release Notes"/>
                    <MenuItem Header="About" Command="{Binding ShowAboutCommand}"/>
                </MenuItem>
            </Menu>
        </Grid>

        <!-- Main Shell (Displaced by the menu/title bar height) -->
        <Grid Margin="0,32,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border x:Name="SidebarBorder" Grid.Column="0" Width="72" Style="{StaticResource ModernSidebar}" Background="Transparent" 
                    MouseLeftButtonDown="OnSidebarClick"
                    MouseEnter="OnSidebarMouseEnter"
                    MouseLeave="OnSidebarMouseLeave">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <!-- Logo/Brand -->
                        <RowDefinition Height="Auto" />
                        <!-- Workspace hubs -->
                        <RowDefinition Height="*" />
                        <!-- Nav Items -->
                        <RowDefinition Height="Auto" />
                        <!-- User Profile -->
                    </Grid.RowDefinitions>

                    <!-- Branding & Search Container (Optimized height and spacing) -->
                    <Grid Grid.Row="0" Grid.RowSpan="2" Height="150" VerticalAlignment="Top">
                        <StackPanel VerticalAlignment="Top">
                            <!-- Logo -->
                            <Grid Margin="0,0,0,0">
                                <!-- Expanded State Brand (Original Image) -->
                                <Border Margin="15,10,15,5" Height="60"
                                        Visibility="{Binding IsSidebarMinimized, Converter={StaticResource VisibilityConverter}, ConverterParameter='Invert'}">
                                    <Image Source="/Assets/Images/occ_logo.png" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>

                                <!-- Minimized State Brand Icon (Original Image) -->
                                    <Border Margin="15,10,15,5" Height="60"
                                        Visibility="{Binding IsSidebarMinimized, Converter={StaticResource VisibilityConverter}}">
                                        <Image Source="/Assets/Images/occ_logo.png" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>
                            </Grid>

                            <!-- Futuristic Search Box -->
                            <Border Margin="15,5" 
                                    BorderBrush="#00FF88" BorderThickness="1" CornerRadius="6"
                                    Background="#0800FF88"
                                    Visibility="{Binding IsSidebarMinimized, Converter={StaticResource VisibilityConverter}, ConverterParameter='Invert'}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#1500FF88"/>
                                                <Setter Property="BorderBrush" Value="#00FFAA"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid Height="36">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Search Icon -->
                                    <Path Data="{StaticResource IconSearch}" Fill="#00FF88" Width="14" Height="14" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.8"/>

                                    <!-- Search Input -->
                                    <TextBox x:Name="SearchTextBox" Grid.Column="1" Background="Transparent" BorderThickness="0" Foreground="White" 
                                             Text="{Binding FeatureSearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                             VerticalContentAlignment="Center" CaretBrush="#00FF88" FontSize="13" Padding="0,0,10,0" />

                                    <!-- Placeholder Text -->
                                    <TextBlock Grid.Column="1" Text="Search..." Foreground="#00FF88" Opacity="0.5" 
                                               VerticalAlignment="Center" IsHitTestVisible="False" Margin="3,0,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Hidden"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Navigation -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding FilteredNavigationItems}" Margin="0,10">
                            <!-- Removed the flat GroupStyle grouping, as we are now hierarchical -->
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <!-- PARENT NODE TEMPLATE (Only visible if IsParent = True) -->
                                        <ToggleButton Style="{StaticResource SidebarParentItemStyle}"
                                                      IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                                                      Visibility="{Binding IsParent, Converter={StaticResource VisibilityConverter}}">
                                            <Grid HorizontalAlignment="Stretch">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="52" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Grid Grid.Column="0" Width="40" Height="40" HorizontalAlignment="Center">
                                                    <Path Data="{Binding Icon, FallbackValue={StaticResource IconSummary}}" Fill="White" Opacity="0.6" Width="18" Height="18" Stretch="Uniform"/>
                                                </Grid>

                                                <TextBlock Grid.Column="1" Text="{Binding Label}" VerticalAlignment="Center" FontSize="15" Margin="0,0,0,0"
                                                           Visibility="{Binding DataContext.IsSidebarMinimized, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource VisibilityConverter}, ConverterParameter='Invert'}"/>

                                                <!-- Expand/Collapse Chevron -->
                                                <Path Grid.Column="2" Data="M0.5,0.5 L4.5,4.5 L8.5,0.5" Stroke="White" StrokeThickness="1.5"
                                                      Opacity="0.5" VerticalAlignment="Center" Margin="0,0,15,0"
                                                      RenderTransformOrigin="0.5,0.5" Width="9" Height="5" Stretch="Uniform"
                                                      Visibility="{Binding DataContext.IsSidebarMinimized, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource VisibilityConverter}, ConverterParameter='Invert'}">
                                                    <Path.Style>
                                                        <Style TargetType="Path">
                                                            <Setter Property="RenderTransform">
                                                                <Setter.Value>
                                                                    <RotateTransform Angle="0" />
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                    <Setter Property="RenderTransform">
                                                                        <Setter.Value>
                                                                            <RotateTransform Angle="180" />
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Path.Style>
                                                </Path>
                                            </Grid>
                                        </ToggleButton>

                                        <!-- SINGLE NODE TEMPLATE (Only visible if IsParent = False) -->
                                        <RadioButton Style="{StaticResource SidebarNavItem}" 
                                                     IsChecked="{Binding IsActive, Mode=TwoWay}"
                                                     GroupName="PrimaryNav"
                                                     Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                     CommandParameter="{Binding}"
                                                     ToolTip="{Binding Label}"
                                                     Visibility="{Binding IsParent, Converter={StaticResource VisibilityConverter}, ConverterParameter='Invert'}">
                                            <Grid HorizontalAlignment="Stretch">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="52" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid Grid.Column="0" Width="40" Height="40" HorizontalAlignment="Center">
                                                    <Ellipse Fill="{DynamicResource AccentBlue}" Opacity="0" Margin="-2" x:Name="ActiveIndicator">
                                                        <Ellipse.Effect>
                                                            <DropShadowEffect BlurRadius="10" Color="{StaticResource AccentBlueColor}" ShadowDepth="0" Opacity="0.5"/>
                                                        </Ellipse.Effect>
                                                    </Ellipse>
                                                    <Path Data="{Binding Icon, FallbackValue={StaticResource IconSummary}}" Fill="White" Opacity="0.6" Width="18" Height="18" Stretch="Uniform"/>
                                                </Grid>

                                                <TextBlock Grid.Column="1" Text="{Binding Label}" VerticalAlignment="Center" FontSize="15" Margin="0,0,0,0"
                                                           Visibility="{Binding DataContext.IsSidebarMinimized, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource VisibilityConverter}, ConverterParameter='Invert'}"/>
                                            </Grid>
                                        </RadioButton>

                                        <!-- CHILD ITEMS CONTAINER (Visible if IsExpanded = True and Sidebar is open) -->
                                        <Border Visibility="{Binding DataContext.IsSidebarMinimized, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource VisibilityConverter}, ConverterParameter='Invert'}">
                                            <ItemsControl ItemsSource="{Binding Children}" Margin="0,0,0,5">
                                                <ItemsControl.Style>
                                                    <Style TargetType="ItemsControl">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ItemsControl.Style>
                                                <!-- Slide down animation wrapper -->
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <!-- CHILD NODE TEMPLATE -->
                                                        <RadioButton Style="{StaticResource SidebarChildItemStyle}" 
                                                                     IsChecked="{Binding IsActive, Mode=TwoWay}"
                                                                     GroupName="PrimaryNav"
                                                                     Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                     CommandParameter="{Binding}"
                                                                     ToolTip="{Binding Label}">
                                                            <Grid HorizontalAlignment="Stretch">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="15" />
                                                                    <!-- Spacing for trace -->
                                                                    <ColumnDefinition Width="20" />
                                                                    <!-- Icon -->
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>
                                                                <Grid Grid.Column="1" Width="16" Height="16" HorizontalAlignment="Center">
                                                                    <Path Data="{Binding Icon, FallbackValue={StaticResource IconSummary}}" Fill="White" Opacity="0.4" Stretch="Uniform"/>
                                                                </Grid>
                                                                <TextBlock Grid.Column="2" Text="{Binding Label}" VerticalAlignment="Center" FontSize="13" Margin="10,0,0,0" Opacity="0.8"/>
                                                            </Grid>
                                                        </RadioButton>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Border>

                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- User Profile -->
                    <Border Grid.Row="3" Background="{DynamicResource GlassBackgroundVibrant}" BorderBrush="{StaticResource GlassBorderUltraLight}" BorderThickness="0,1,0,0" Padding="5,15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="52" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- NK Circle -->
                            <Border Grid.Column="0" x:Name="ProfileCircle" Width="42" Height="42" 
                                    HorizontalAlignment="Center" CornerRadius="21" Background="{StaticResource AccentBlue}"
                                    Cursor="Hand" MouseLeftButtonDown="OnProfileCircleClick">
                                <TextBlock Text="{Binding UserInitials}" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" FontSize="14" IsHitTestVisible="False"/>
                            </Border>

                            <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center" Margin="5,0,0,0"
                                          Visibility="{Binding IsSidebarMinimized, Converter={StaticResource VisibilityConverter}, ConverterParameter='Invert'}">
                                <TextBlock Text="{Binding UserName}" Foreground="White" FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding UserEmail}" Foreground="{StaticResource TextSub}" FontSize="11" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Content Area -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <!-- Top Bar (Title + Nav icons) -->
                    <RowDefinition Height="*" />
                    <!-- Main Content -->
                    <RowDefinition Height="32" />
                    <!-- Status Bar -->
                </Grid.RowDefinitions>

                <!-- Top Bar -->
                <Border Grid.Row="0" Height="50" Padding="30,0" BorderBrush="{StaticResource GlassBorderUltraLight}" BorderThickness="0,0,0,1">
                    <Grid>
                        <!-- Workspace Tabs -->
                        <ListBox x:Name="TabsListBox" ItemsSource="{Binding OpenHubs}" SelectedItem="{Binding ActiveHub}" 
                                 Background="Transparent" BorderThickness="0" 
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                 VerticalAlignment="Bottom" Margin="0,0,40,0"
                                 PreviewMouseWheel="TabsListBox_PreviewMouseWheel">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                 <Border x:Name="TabBorder" Height="40" MinWidth="120" Margin="0,0,4,0" 
                                                        Background="#66000000" BorderBrush="#20FFFFFF" BorderThickness="1,1,1,0" CornerRadius="8,8,0,0">
                                                    <Grid Margin="15,0,10,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        
                                                        <TextBlock Text="{Binding Title}" Foreground="White" Opacity="0.5" x:Name="TabText"
                                                                   FontFamily="{StaticResource MichromaFont}" VerticalAlignment="Center" FontSize="11" TextTrimming="CharacterEllipsis" Margin="0,0,15,0"/>
                                                                   
                                                        <Button Grid.Column="1" Command="{Binding DataContext.CloseHubCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Width="20" Height="20" Background="Transparent" BorderThickness="0" VerticalAlignment="Center" x:Name="CloseButton">
                                                            <Path Data="M0,0 L8,8 M8,0 L0,8" Stroke="White" StrokeThickness="1.5" Opacity="0.3" x:Name="CloseIcon"
                                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            <Button.Style>
                                                                <Style TargetType="Button">
                                                                    <Setter Property="Template">
                                                                        <Setter.Value>
                                                                            <ControlTemplate TargetType="Button">
                                                                                <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                                </Border>
                                                                            </ControlTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                    <Style.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter Property="Background" Value="#40FF3b30"/>
                                                                        </Trigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="TabBorder" Property="Background" Value="#1500FF88"/>
                                                        <Setter TargetName="TabBorder" Property="BorderBrush" Value="#00FF88"/>
                                                        <Setter TargetName="TabBorder" Property="BorderThickness" Value="1,1,1,2"/>
                                                        <Setter TargetName="TabText" Property="Opacity" Value="1.0"/>
                                                        <Setter TargetName="TabText" Property="Foreground" Value="#00FF88"/>
                                                    </Trigger>
                                                    <Trigger SourceName="CloseButton" Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="CloseIcon" Property="Opacity" Value="1.0" />
                                                        <Setter TargetName="CloseIcon" Property="Stroke" Value="#FF3b30" />
                                                    </Trigger>
                                                    <MultiTrigger>
                                                        <MultiTrigger.Conditions>
                                                            <Condition Property="IsMouseOver" Value="True"/>
                                                            <Condition Property="IsSelected" Value="False"/>
                                                        </MultiTrigger.Conditions>
                                                        <Setter TargetName="TabBorder" Property="Background" Value="#15FFFFFF"/>
                                                        <Setter TargetName="TabText" Property="Opacity" Value="0.8"/>
                                                    </MultiTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>                       
                    </Grid>
                </Border>


                <!-- Active Content -->
                <ContentControl Grid.Row="1" Content="{Binding ActiveHub}" Margin="0"/>

                <!-- Status Bar (Complete Parity) -->
                <Border Grid.Row="2" Background="#1A000000" BorderBrush="{StaticResource GlassBorderUltraLight}" BorderThickness="0,1,0,0" Padding="30,0">
                    <Grid>
                        <!-- Left Section -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- Busy Indicator -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,20,0" Visibility="{Binding IsAppBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Path Data="{StaticResource IconClock}" Fill="{StaticResource SecondaryGold}" Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center" Stretch="Uniform" RenderTransformOrigin="0.5,0.5">
                                    <Path.RenderTransform>
                                        <RotateTransform x:Name="BusySpinnerTransform" Angle="0" />
                                    </Path.RenderTransform>
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAppBusy}" Value="True">
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard Storyboard="{StaticResource BusySpinnerAnimation}" Name="BeginBusySpinner" />
                                                    </DataTrigger.EnterActions>
                                                    <DataTrigger.ExitActions>
                                                        <StopStoryboard BeginStoryboardName="BeginBusySpinner" />
                                                    </DataTrigger.ExitActions>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                                <TextBlock Text="{Binding BusyMessage}" Foreground="White" FontSize="11" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                <Border Width="1" Height="12" Background="{StaticResource GlassBorderUltraLight}" VerticalAlignment="Center" Margin="20,0,0,0"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                                <Path Data="{DynamicResource IconClock}" Fill="{DynamicResource TextSub}" Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center" Stretch="Uniform"/>
                                <TextBlock Text="{Binding UserActivityStatus}" Foreground="{StaticResource TextSub}" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>

                            <Border Width="1" Height="12" Background="{StaticResource GlassBorderUltraLight}" VerticalAlignment="Center" Margin="0,0,20,0"/>

                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconDatabase}" Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center" Stretch="Uniform">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Setter Property="Fill" Value="{StaticResource ErrorRed}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDbConnected}" Value="True">
                                                    <Setter Property="Fill" Value="#10B981"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                                <TextBlock Text="{Binding DbStatusText}" Foreground="{StaticResource TextSub}" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Right Section -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button Command="{Binding ShowReportBugCommand}" Margin="0,0,15,0">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Padding" Value="8,4"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="#15FFFFFF"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="#25FFFFFF"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{DynamicResource IconBug}" Fill="{DynamicResource SecondaryGold}" Width="12" Height="12" Margin="0,1,8,0" VerticalAlignment="Center" Stretch="Uniform"/>
                                    <TextBlock Text="Report Bug" Foreground="{StaticResource TextSub}" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Border Width="1" Height="12" Background="{StaticResource GlassBorderUltraLight}" VerticalAlignment="Center" Margin="0,0,15,0"/>

                            <StackPanel Orientation="Horizontal" Cursor="Hand" Background="Transparent" MouseLeftButtonDown="OnOnlineStatusClick">
                                <Path Data="{DynamicResource IconUserOnline}" Fill="{DynamicResource AccentBlue}" Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center" Stretch="Uniform"/>
                                <TextBlock Text="Online: " Foreground="{StaticResource TextSub}" FontSize="11" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding OnlineCount}" Foreground="White" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Toast Notifications Overlay (Bottom Right) -->
        <ItemsControl ItemsSource="{Binding Toasts}" 
                      Style="{StaticResource ToastContainerStyle}"
                      Margin="0,0,20,50" 
                      Panel.ZIndex="200"/>

        <Border x:Name="UserListOverlay" HorizontalAlignment="Right" VerticalAlignment="Bottom" 
                Margin="0,0,20,50" Width="220"
                Background="{StaticResource BackgroundDark}" 
                BorderBrush="{StaticResource GlassBorder}" 
                BorderThickness="1" CornerRadius="8"
                Panel.ZIndex="250"
                Visibility="{Binding IsUserListVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                MouseLeave="OnOverlayMouseLeave">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Opacity" Value="1"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsUserListVisible}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
            </Border.Effect>
            <StackPanel Margin="15,12">
                <Grid Margin="0,0,0,10">
                    <TextBlock Text="Active Users" FontWeight="Bold" Foreground="White" FontSize="13"/>
                    <Button HorizontalAlignment="Right" Command="{Binding ToggleUserListCommand}" Style="{StaticResource OverlayCloseButtonStyle}" Width="24" Height="24">
                        <Path Data="M0,0 L8,8 M8,0 L0,8" Stroke="{StaticResource TextSub}" StrokeThickness="1.5" Width="8" Height="8" Stretch="Uniform"/>
                    </Button>
                </Grid>
                <ItemsControl ItemsSource="{Binding ConnectedUsers}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Ellipse Grid.Column="0" Width="8" Height="8" Fill="{Binding StatusColor}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="{StaticResource TextMain}" VerticalAlignment="Center" FontSize="12"/>
                                <TextBlock Grid.Column="2" Text="{Binding TimeOnline}" Foreground="{StaticResource TextSub}" VerticalAlignment="Center" FontSize="10" Margin="15,0,0,0"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <Border x:Name="ProfileMenuOverlay" HorizontalAlignment="Left" VerticalAlignment="Bottom" 
                Margin="15,0,0,80" Width="180"
                Background="{StaticResource BackgroundDark}" 
                BorderBrush="{StaticResource GlassBorder}" 
                BorderThickness="1" CornerRadius="8"
                Panel.ZIndex="250"
                Visibility="{Binding IsProfileMenuVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                MouseLeave="OnOverlayMouseLeave">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Opacity" Value="1"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsProfileMenuVisible}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
            </Border.Effect>
            <StackPanel Margin="5">
                <Button Style="{StaticResource ModernMenuButton}" Command="{Binding ShowProfileCommand}">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IconProfile}" Fill="White" Width="14" Height="14" Margin="0,0,12,0" Stretch="Uniform" VerticalAlignment="Center"/>
                        <TextBlock Text="Profile"/>
                    </StackPanel>
                </Button>
                <Border Height="1" Background="{StaticResource GlassBorderUltraLight}" Margin="10,2"/>
                <Button Style="{StaticResource ModernMenuButton}" Command="{Binding LogoutCommand}">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IconLogout}" Fill="White" Width="14" Height="14" Margin="0,0,12,0" Stretch="Uniform" VerticalAlignment="Center"/>
                        <TextBlock Text="Log out" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- Support Hub Modal Overlay -->
        <Grid x:Name="SupportHubOverlay" Panel.ZIndex="1000">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CurrentReportBug}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding CurrentReportBug, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter='Invert'}" Value="Visible">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <!-- Backdrop -->
            <Border Background="#80000000">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding CloseHubCommand}" CommandParameter="{Binding CurrentReportBug}"/>
                </Border.InputBindings>
            </Border>

            <!-- Modal Content (Host for SupportHubView) -->
            <ContentControl Content="{Binding CurrentReportBug}" 
                            HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>

        <!-- Profile Modal Overlay -->
        <Grid x:Name="ProfileOverlay" Panel.ZIndex="1100">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CurrentProfile}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding CurrentProfile, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter='Invert'}" Value="Visible">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <!-- Backdrop -->
            <Border Background="#80000000">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding CloseProfileCommand}"/>
                </Border.InputBindings>
            </Border>

            <!-- Modal Content (Host for ProfileView) -->
            <ContentControl Content="{Binding CurrentProfile}" 
                            HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>

        <!-- About Modal Overlay -->
        <Grid x:Name="AboutOverlay" Panel.ZIndex="1200" Visibility="{Binding IsAboutVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <!-- Backdrop -->
            <Border Background="#80000000">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding CloseAboutCommand}"/>
                </Border.InputBindings>
            </Border>
            
            <!-- Modal Content -->
            <Border HorizontalAlignment="Center" VerticalAlignment="Center" Width="480" Background="{StaticResource BackgroundDark}" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1" CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
                </Border.Effect>
                <StackPanel Margin="25">
                    <Grid Margin="0,0,0,15">
                        <TextBlock Text="About" FontFamily="{StaticResource MichromaFont}" FontSize="18" Foreground="White" FontWeight="SemiBold"/>
                        <Button HorizontalAlignment="Right" Command="{Binding CloseAboutCommand}" Style="{StaticResource OverlayCloseButtonStyle}" Width="28" Height="28">
                            <Path Data="M0,0 L10,10 M10,0 L0,10" Stroke="{StaticResource TextSub}" StrokeThickness="2" Width="10" Height="10" Stretch="Uniform"/>
                        </Button>
                    </Grid>

                    <TextBlock Text="OCC ERP" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,5"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                        <TextBlock Text="Version: " Foreground="{StaticResource TextSub}" FontSize="13"/>
                        <TextBlock Text="{Binding AppVersion}" Foreground="{DynamicResource AccentBlue}" FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>

                    <TextBlock Text="License" Foreground="White" FontSize="15" FontWeight="Bold" Margin="0,0,0,8"/>
                    <TextBlock Foreground="{StaticResource TextSub}" FontSize="12" TextWrapping="Wrap" LineHeight="18" Margin="0,0,0,10">
                        <Run Text="This computer program is protected by copyright law and international treaties. Unauthorized reproduction or distribution of this program, or any portion of it, may result in severe civil and criminal penalties, and will be prosecuted to the maximum extent possible under the law." />
                        <LineBreak/>
                        <LineBreak/>
                        <Run Text="© 2026 Orange Circle Construction. All rights reserved." />
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>


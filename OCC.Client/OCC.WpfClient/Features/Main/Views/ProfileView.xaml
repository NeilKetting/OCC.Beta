<UserControl x:Class="OCC.WpfClient.Features.Main.Views.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OCC.WpfClient.Features.Main.Views"
             xmlns:vm="clr-namespace:OCC.WpfClient.Features.Main.ViewModels"
             xmlns:infra="clr-namespace:OCC.WpfClient.Infrastructure"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="500">
    
    <Border Background="{StaticResource GlassBackgroundVibrant}" 
            BorderBrush="{StaticResource GlassBorderLight}" 
            BorderThickness="1" 
            CornerRadius="20" 
            Width="450" 
            Padding="30">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.5"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="Auto"/> <!-- Avatar Section -->
                <RowDefinition Height="*"/>    <!-- Form content -->
                <RowDefinition Height="Auto"/> <!-- Footer Buttons -->
            </Grid.RowDefinitions>

            <!-- Close Button -->
            <Button HorizontalAlignment="Right" VerticalAlignment="Top" 
                    Style="{StaticResource WindowCloseButton}" 
                    Command="{Binding DataContext.CloseProfileCommand, RelativeSource={RelativeSource AncestorType=ContentControl, AncestorLevel=2}}"
                    Margin="0,-10,-10,0">
            </Button>
            
            <StackPanel Grid.Row="0" Margin="0,0,0,25">
                <TextBlock Text="User Profile" Foreground="White" FontSize="20" FontWeight="Bold" FontFamily="{StaticResource MichromaFont}"/>
                <TextBlock Text="Manage your account settings and security" Style="{StaticResource FormLabelText}"/>
            </StackPanel>

            <!-- Avatar Section -->
            <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,30">
                <Grid>
                    <Border Width="100" Height="100" CornerRadius="50" BorderBrush="{StaticResource AccentBlue}" BorderThickness="3" Padding="3">
                        <Border x:Name="AvatarContainer" CornerRadius="47" Background="#10FFFFFF" ClipToBounds="True">
                            <!-- Image or Initials -->
                            <Grid>
                                <TextBlock Text="{Binding User.FirstName, StringFormat='\{0:1\}'}" Foreground="White" Opacity="0.1" FontSize="40" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                <!-- In a real app we'd bind to an Image Source using a converter for Base64 -->
                                <Image Stretch="UniformToFill">
                                    <!-- Simplified: Just initials for now if no image -->
                                </Image>
                            </Grid>
                        </Border>
                    </Border>
                    <Button Command="{Binding UploadProfilePictureCommand}" Width="32" Height="32" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,0,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{StaticResource AccentBlue}" CornerRadius="16">
                                    <Path Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z" Fill="White" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </StackPanel>

            <!-- Form Content -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" MaxHeight="350">
                <StackPanel>
                    <!-- Personal Info -->
                    <TextBlock Text="PERSONAL INFORMATION" Foreground="{StaticResource AccentBlue}" FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>
                    
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="First Name" Style="{StaticResource LabelText}"/>
                            <TextBox Text="{Binding User.FirstName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernInput}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Last Name" Style="{StaticResource LabelText}"/>
                            <TextBox Text="{Binding User.LastName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernInput}"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Email Address" Style="{StaticResource LabelText}"/>
                    <TextBox Text="{Binding User.Email, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernInput}" IsReadOnly="True" Opacity="0.7" Margin="0,0,0,15"/>

                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Phone" Style="{StaticResource LabelText}"/>
                            <TextBox Text="{Binding User.Phone, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernInput}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Location" Style="{StaticResource LabelText}"/>
                            <TextBox Text="{Binding User.Location, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernInput}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Security Section -->
                    <Border BorderBrush="{StaticResource GlassBorderUltraLight}" BorderThickness="0,1,0,0" Margin="0,5,0,20" Padding="0,20,0,0">
                        <StackPanel>
                            <Grid>
                                <TextBlock Text="SECURITY" Foreground="{StaticResource AccentBlue}" FontSize="11" FontWeight="Bold"/>
                                <Button Command="{Binding TogglePasswordChangeCommand}"
                                        HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextSub}" FontSize="11" Cursor="Hand">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Content" Value="Change Password"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsChangingPassword}" Value="True">
                                                    <Setter Property="Content" Value="Cancel"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                            
                            <StackPanel Visibility="{Binding IsChangingPassword, Converter={StaticResource VisibilityConverter}}" Margin="0,15,0,0">
                                <TextBlock Text="Current Password" Style="{StaticResource LabelText}"/>
                                <PasswordBox x:Name="CurrentPwd" Style="{StaticResource ModernPasswordInput}" Margin="0,0,0,10"
                                             infra:PasswordHelper.Attach="True"
                                             infra:PasswordHelper.Password="{Binding OldPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                
                                <TextBlock Text="New Password" Style="{StaticResource LabelText}"/>
                                <PasswordBox x:Name="NewPwd" Style="{StaticResource ModernPasswordInput}" Margin="0,0,0,10"
                                             infra:PasswordHelper.Attach="True"
                                             infra:PasswordHelper.Password="{Binding NewPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                
                                <TextBlock Text="Confirm New Password" Style="{StaticResource LabelText}"/>
                                <PasswordBox x:Name="ConfirmPwd" Style="{StaticResource ModernPasswordInput}" Margin="0,0,0,15"
                                             infra:PasswordHelper.Attach="True"
                                             infra:PasswordHelper.Password="{Binding ConfirmPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                
                                <Button Content="Update Password" Command="{Binding ChangePasswordCommand}" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Stretch" Height="35"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer Buttons -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Discard Changes" Command="{Binding DataContext.CloseProfileCommand, RelativeSource={RelativeSource AncestorType=ContentControl, AncestorLevel=2}}" Style="{StaticResource SecondaryButton}" Width="140" Margin="0,0,10,0"/>
                <Button Content="Save Profile" Command="{Binding SaveProfileCommand}" Style="{StaticResource PrimaryButton}" Width="140"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>


<UserControl x:Class="OCC.WpfClient.Features.Employees.Views.EmployeeDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:OCC.WpfClient.Features.Employees.ViewModels"
             xmlns:ap="clr-namespace:OCC.WpfClient.Infrastructure.AttachedProperties"
             xmlns:infra="clr-namespace:OCC.WpfClient.Infrastructure.Converters"
             xmlns:models="clr-namespace:OCC.Shared.Models;assembly=OCC.Shared"
             mc:Ignorable="d" 
             d:DesignHeight="1200" d:DesignWidth="1000"
             d:DataContext="{d:DesignInstance Type=vm:EmployeeDetailViewModel}">
    
    <UserControl.Resources>
        <infra:VisibilityConverter x:Key="VisibilityConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid>
        <!-- Overlay Background -->
        <Border Background="#90000000" IsHitTestVisible="True" />
        
        <!-- Detail Card -->
        <Border Background="{StaticResource GlassBackground}" 
                BorderBrush="{StaticResource GlassBorder}" 
                BorderThickness="1" 
                CornerRadius="20" 
                Width="700" 
                VerticalAlignment="Center" 
                HorizontalAlignment="Center" 
                MaxHeight="950"
                Margin="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="50" ShadowDepth="0" Opacity="0.9"/>
            </Border.Effect>
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" /> <!-- Header -->
                    <RowDefinition Height="*" />    <!-- Content -->
                    <RowDefinition Height="Auto" /> <!-- Footer -->
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Background="#10FFFFFF" CornerRadius="20,20,0,0" Padding="30,20">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="{Binding Title}" FontSize="24" FontWeight="Bold" Foreground="White" />
                            <TextBlock Text="Comprehensive staff record management." Foreground="{StaticResource TextSub}" FontSize="13" Margin="0,5,0,0"/>
                        </StackPanel>
                        
                        <Button Content="" FontFamily="Segoe MDL2 Assets" 
                                Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextSub}"
                                FontSize="18" HorizontalAlignment="Right" VerticalAlignment="Top"
                                Command="{Binding CancelCommand}" />
                    </Grid>
                </Border>

                <!-- Content -->
                <ScrollViewer Grid.Row="1" Margin="30,20" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        
                        <!-- SECTION: Personal & Identity -->
                        <Border Background="#05FFFFFF" BorderBrush="#15FFFFFF" BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="PERSONAL &amp; IDENTITY" FontSize="11" FontWeight="Bold" Foreground="{StaticResource AccentBlue}" Margin="0,0,0,20" />
                                
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="30" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0">
                                        <StackPanel Margin="0,0,0,15">
                                            <TextBlock Text="First Name" FontSize="11" Foreground="{StaticResource TextSub}" Margin="0,0,0,8"/>
                                            <TextBox Text="{Binding Employee.FirstName, UpdateSourceTrigger=PropertyChanged}" Tag="e.g. John" Style="{StaticResource ModernInput}" />
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,15">
                                            <TextBlock Text="Last Name" FontSize="11" Foreground="{StaticResource TextSub}" Margin="0,0,0,8"/>
                                            <TextBox Text="{Binding Employee.LastName, UpdateSourceTrigger=PropertyChanged}" Tag="e.g. Doe" Style="{StaticResource ModernInput}" />
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,15">
                                            <TextBlock Text="Identity Type" FontSize="11" Foreground="{StaticResource TextSub}" Margin="0,0,0,8"/>
                                            <ComboBox ItemsSource="{Binding IdTypes}" SelectedItem="{Binding Employee.IdType}" Style="{StaticResource ModernComboBox}" Height="35" />
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <StackPanel Margin="0,0,0,15">
                                            <TextBlock Text="ID / Passport Number" FontSize="11" Foreground="{StaticResource TextSub}" Margin="0,0,0,8"/>
                                            <TextBox Text="{Binding Employee.IdNumber, UpdateSourceTrigger=PropertyChanged}" Tag="RSA ID or Passport" Style="{StaticResource ModernInput}" />
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,15">
                                            <TextBlock Text="Date of Birth" FontSize="11" Foreground="{StaticResource TextSub}" Margin="0,0,0,8"/>
                                            <DatePicker SelectedDate="{Binding Employee.DoB}" />
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,15">
                                            <TextBlock Text="Tax Number" FontSize="11" Foreground="{StaticResource TextSub}" Margin="0,0,0,8"/>
                                            <TextBox Text="{Binding Employee.TaxNumber}" Tag="SARS Tax Reference" Style="{StaticResource ModernInput}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- SECTION: Employment & Access -->
                        <Border Background="#05FFFFFF" BorderBrush="#15FFFFFF" BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="EMPLOYMENT &amp; SYSTEM ACCESS" FontSize="11" FontWeight="Bold" Foreground="{StaticResource AccentBlue}" Margin="0,0,0,20" />
                                
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="30" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0">
                                        <StackPanel Margin="0,0,0,15">
                                            <TextBlock Text="Employee Number" FontSize="11" Foreground="{StaticResource TextSub}" Margin="0,0,0,8"/>
                                            <TextBox Text="{Binding Employee.EmployeeNumber, UpdateSourceTrigger=PropertyChanged}" Tag="EMP001" Style="{StaticResource ModernInput}" />
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,15">
                                            <TextBlock Text="Position / Role" FontSize="11" Foreground="{StaticResource TextSub}" Margin="0,0,0,8"/>
                                            <ComboBox ItemsSource="{Binding Roles}" SelectedValue="{Binding Employee.Role}" Style="{StaticResource ModernComboBox}" Height="35" />
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,15">
                                            <TextBlock Text="Linked User Account" FontSize="11" Foreground="{StaticResource TextSub}" Margin="0,0,0,8"/>
                                            <ComboBox ItemsSource="{Binding AvailableUsers}" 
                                                      SelectedValue="{Binding Employee.LinkedUserId}" 
                                                      SelectedValuePath="Id"
                                                      DisplayMemberPath="DisplayName"
                                                      Style="{StaticResource ModernComboBox}" Height="35" />
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <StackPanel Margin="0,0,0,15">
                                            <TextBlock Text="Employment Type" FontSize="11" Foreground="{StaticResource TextSub}" Margin="0,0,0,8"/>
                                            <ComboBox ItemsSource="{Binding EmploymentTypes}" SelectedValue="{Binding Employee.EmploymentType}" Style="{StaticResource ModernComboBox}" Height="35" />
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,15">
                                            <TextBlock Text="Branch" FontSize="11" Foreground="{StaticResource TextSub}" Margin="0,0,0,8"/>
                                            <ComboBox ItemsSource="{Binding Branches}" SelectedValue="{Binding Employee.Branch}" Style="{StaticResource ModernComboBox}" Height="35" />
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,15">
                                            <TextBlock Text="Status" FontSize="11" Foreground="{StaticResource TextSub}" Margin="0,0,0,8"/>
                                            <ComboBox SelectedValue="{Binding Employee.Status}" SelectedValuePath="Tag" Style="{StaticResource ModernComboBox}" Height="35">
                                                <ComboBoxItem Content="Active" Tag="{x:Static models:EmployeeStatus.Active}" />
                                                <ComboBoxItem Content="Inactive" Tag="{x:Static models:EmployeeStatus.Inactive}" />
                                                <ComboBoxItem Content="Terminated" Tag="{x:Static models:EmployeeStatus.Terminated}" />
                                            </ComboBox>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- SECTION: Compensation & Shifts -->
                        <Border Background="#05FFFFFF" BorderBrush="#15FFFFFF" BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="COMPENSATION &amp; SHIFTS" FontSize="11" FontWeight="Bold" Foreground="{StaticResource SecondaryGold}" Margin="0,0,0,20" />
                                
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="30" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="15" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Rate Type" FontSize="11" Foreground="{StaticResource TextSub}" Margin="0,0,0,8"/>
                                                <ComboBox SelectedValue="{Binding Employee.RateType}" SelectedValuePath="Tag" Style="{StaticResource ModernComboBox}" Height="35">
                                                    <ComboBoxItem Content="Hourly" Tag="{x:Static models:RateType.Hourly}" />
                                                    <ComboBoxItem Content="Monthly Salary" Tag="{x:Static models:RateType.MonthlySalary}" />
                                                </ComboBox>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Rate (R)" FontSize="11" Foreground="{StaticResource TextSub}" Margin="0,0,0,8"/>
                                                <TextBox Text="{Binding Employee.HourlyRate}" Style="{StaticResource ModernInput}" />
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="15" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Shift Start" FontSize="11" Foreground="{StaticResource TextSub}" Margin="0,0,0,8"/>
                                                <TextBox Text="{Binding Employee.ShiftStartTime}" Tag="07:00" Style="{StaticResource ModernInput}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Shift End" FontSize="11" Foreground="{StaticResource TextSub}" Margin="0,0,0,8"/>
                                                <TextBox Text="{Binding Employee.ShiftEndTime}" Tag="16:45" Style="{StaticResource ModernInput}" />
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- SECTION: Banking Details -->
                        <Border Background="#05FFFFFF" BorderBrush="#15FFFFFF" BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="BANKING DETAILS" FontSize="11" FontWeight="Bold" Foreground="{StaticResource SecondaryGold}" Margin="0,0,0,20" />
                                
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="30" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0">
                                        <StackPanel Margin="0,0,0,15">
                                            <TextBlock Text="Bank Name" FontSize="11" Foreground="{StaticResource TextSub}" Margin="0,0,0,8"/>
                                            <ComboBox ItemsSource="{Binding Banks}" SelectedItem="{Binding Employee.BankName}" Style="{StaticResource ModernComboBox}" Height="35" />
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,15">
                                            <TextBlock Text="Account Number" FontSize="11" Foreground="{StaticResource TextSub}" Margin="0,0,0,8"/>
                                            <TextBox Text="{Binding Employee.AccountNumber}" Style="{StaticResource ModernInput}" />
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <StackPanel Margin="0,0,0,15">
                                            <TextBlock Text="Account Type" FontSize="11" Foreground="{StaticResource TextSub}" Margin="0,0,0,8"/>
                                            <ComboBox ItemsSource="{Binding AccountTypes}" SelectedValue="{Binding Employee.AccountType}" Style="{StaticResource ModernComboBox}" Height="35" />
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,15">
                                            <TextBlock Text="Branch Code" FontSize="11" Foreground="{StaticResource TextSub}" Margin="0,0,0,8"/>
                                            <TextBox Text="{Binding Employee.BranchCode}" Tag="e.g. 632005" Style="{StaticResource ModernInput}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- SECTION: Contact & Address -->
                        <Border Background="#05FFFFFF" BorderBrush="#15FFFFFF" BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="CONTACT &amp; ADDRESS" FontSize="11" FontWeight="Bold" Foreground="{StaticResource AccentBlue}" Margin="0,0,0,20" />
                                
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="30" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0">
                                        <StackPanel Margin="0,0,0,15">
                                            <TextBlock Text="Phone Number" FontSize="11" Foreground="{StaticResource TextSub}" Margin="0,0,0,8"/>
                                            <TextBox Text="{Binding Employee.Phone}" Style="{StaticResource ModernInput}" />
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,15">
                                            <TextBlock Text="Physical Address" FontSize="11" Foreground="{StaticResource TextSub}" Margin="0,0,0,8"/>
                                            <TextBox Text="{Binding Employee.PhysicalAddress}" Style="{StaticResource ModernInput}" AcceptsReturn="True" Height="70" />
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <StackPanel Margin="0,0,0,15">
                                            <TextBlock Text="Next of Kin Name" FontSize="11" Foreground="{StaticResource TextSub}" Margin="0,0,0,8"/>
                                            <TextBox Text="{Binding Employee.NextOfKinName}" Style="{StaticResource ModernInput}" />
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,15">
                                            <TextBlock Text="Next of Kin Phone" FontSize="11" Foreground="{StaticResource TextSub}" Margin="0,0,0,8"/>
                                            <TextBox Text="{Binding Employee.NextOfKinPhone}" Style="{StaticResource ModernInput}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- Footer -->
                <Border Grid.Row="2" Background="#10FFFFFF" CornerRadius="0,0,20,20" Padding="30,20">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Style="{StaticResource SecondaryButton}" Width="100" Height="40" Command="{Binding CancelCommand}" />
                        <Button Content="Save Staff Record" Style="{StaticResource PrimaryButton}" Width="180" Height="40" Margin="15,0,0,0" Command="{Binding SaveCommand}" />
                    </StackPanel>
                </Border>

            </Grid>
        </Border>
    </Grid>
</UserControl>

<UserControl x:Class="OCC.WpfClient.Features.Employees.Views.EmployeeListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:OCC.WpfClient.Features.Employees.ViewModels"
             xmlns:views="clr-namespace:OCC.WpfClient.Features.Employees.Views"
             xmlns:infra="clr-namespace:OCC.WpfClient.Infrastructure.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200"
             d:DataContext="{d:DesignInstance Type=vm:EmployeeListViewModel}">

    <UserControl.Resources>
        <infra:VisibilityConverter x:Key="VisibilityConverter" />
    </UserControl.Resources>
    
    <Grid Margin="30,20,30,30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Header -->
            <RowDefinition Height="Auto" /> <!-- Compact Filters & Stats -->
            <RowDefinition Height="*" />    <!-- Grid -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Employee Overview" FontSize="26" FontWeight="Bold" Foreground="White" />
                <TextBlock Text="Manage staff records and teams." Foreground="{StaticResource TextSub}" FontSize="13" Margin="0,4,0,0"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="Add Employee" Style="{StaticResource PrimaryButton}" Command="{Binding AddEmployeeCommand}" Width="140" Height="36"/>
            </StackPanel>
        </Grid>

        <!-- Compact Filters & Stats Line -->
        <Border Grid.Row="1" Background="{StaticResource GlassBackground}" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1" CornerRadius="10" Padding="15,10" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" /> <!-- Search Icon -->
                    <ColumnDefinition Width="200" />  <!-- Search Box -->
                    <ColumnDefinition Width="Auto" /> <!-- Divider -->
                    <ColumnDefinition Width="Auto" /> <!-- Status Filter -->
                    <ColumnDefinition Width="Auto" /> <!-- Branch Filter -->
                    <ColumnDefinition Width="Auto" /> <!-- Columns Button -->
                    <ColumnDefinition Width="*" />    <!-- Spacer -->
                    <ColumnDefinition Width="Auto" /> <!-- Subtle Stats -->
                </Grid.ColumnDefinitions>

                <!-- Search -->
                <Path Grid.Column="0" Data="{StaticResource IconSearch}" Fill="{StaticResource TextSub}" Width="14" Height="14" Margin="5,0,10,0" VerticalAlignment="Center" Stretch="Uniform"/>
                <TextBox Grid.Column="1" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" Tag="Search staff..." Style="{StaticResource ModernInput}" Height="32" BorderThickness="0" Background="Transparent"/>
                
                <Border Grid.Column="2" Width="1" Height="20" Background="{StaticResource GlassBorder}" Margin="15,0" VerticalAlignment="Center"/>

                <!-- Employment Type -->
                <ComboBox Grid.Column="3" SelectedIndex="{Binding SelectedFilterIndex}" Width="130" Height="32" Style="{StaticResource ModernComboBox}" Margin="0,0,10,0">
                    <ComboBoxItem Content="All Types" />
                    <ComboBoxItem Content="Permanent" />
                    <ComboBoxItem Content="Contract" />
                </ComboBox>

                <!-- Branch -->
                <ComboBox Grid.Column="4" SelectedIndex="{Binding SelectedBranchFilterIndex}" Width="140" Height="32" Style="{StaticResource ModernComboBox}" Margin="0,0,10,0">
                    <ComboBoxItem Content="All Branches" />
                    <ComboBoxItem Content="Johannesburg" />
                    <ComboBoxItem Content="Cape Town" />
                </ComboBox>

                <!-- Columns Selection -->
                <Grid Grid.Column="5">
                    <ToggleButton x:Name="ColumnsBtn" Content="Columns " FontFamily="Segoe MDL2 Assets" 
                                  Style="{StaticResource {x:Type ToggleButton}}" 
                                  Width="100" Height="32" Background="Transparent" Foreground="{StaticResource TextSub}" BorderThickness="1" BorderBrush="{StaticResource GlassBorder}">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="ToggleButton">
                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>
                    
                    <Popup IsOpen="{Binding IsChecked, ElementName=ColumnsBtn}" StaysOpen="False" PlacementTarget="{Binding ElementName=ColumnsBtn}" Placement="Bottom" AllowsTransparency="True">
                        <Border Background="{StaticResource GlassBackground}" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,5,0,0">
                            <StackPanel>
                                <TextBlock Text="DISPLAY COLUMNS" FontSize="10" FontWeight="Bold" Foreground="{StaticResource AccentBlue}" Margin="0,0,0,5"/>
                                <CheckBox Content="Employee Number" IsChecked="{Binding IsNumberVisible}" Foreground="White" />
                                <CheckBox Content="Position" IsChecked="{Binding IsPositionVisible}" Foreground="White" />
                                <CheckBox Content="Type" IsChecked="{Binding IsTypeVisible}" Foreground="White" />
                                <CheckBox Content="Branch" IsChecked="{Binding IsBranchVisible}" Foreground="White" />
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>

                <!-- Subtle Stats -->
                <StackPanel Grid.Column="7" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#20FFFFFF" CornerRadius="12" Padding="10,4" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="TOTAL: " FontSize="10" Foreground="{StaticResource TextSub}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding TotalCount}" FontSize="12" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#204099FF" CornerRadius="12" Padding="10,4" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="PERM: " FontSize="10" Foreground="{StaticResource TextSub}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding PermanentCount}" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AccentBlue}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Employee Grid -->
        <Border Grid.Row="2" Background="{StaticResource GlassBackground}" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1" CornerRadius="12" Padding="2">
            <DataGrid ItemsSource="{Binding Employees}" 
                      SelectedItem="{Binding SelectedEmployee}"
                      AutoGenerateColumns="False" 
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="None"
                      Background="Transparent"
                      BorderThickness="0"
                      RowBackground="Transparent"
                      AlternatingRowBackground="#05FFFFFF">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="NUMBER" Binding="{Binding EmployeeNumber}" Width="120" Visibility="{Binding DataContext.IsNumberVisible, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource VisibilityConverter}}" />
                    <DataGridTextColumn Header="EMPLOYEE" Binding="{Binding DisplayName}" Width="*" />
                    <DataGridTextColumn Header="POSITION" Binding="{Binding Role}" Width="180" Visibility="{Binding DataContext.IsPositionVisible, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource VisibilityConverter}}" />
                    <DataGridTextColumn Header="TYPE" Binding="{Binding EmploymentType}" Width="120" Visibility="{Binding DataContext.IsTypeVisible, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource VisibilityConverter}}" />
                    <DataGridTextColumn Header="BRANCH" Binding="{Binding Branch}" Width="150" Visibility="{Binding DataContext.IsBranchVisible, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource VisibilityConverter}}" />
                    
                    <DataGridTemplateColumn Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="" FontFamily="Segoe MDL2 Assets" 
                                            Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextSub}" Margin="0,0,15,0"
                                            Command="{Binding DataContext.EditEmployeeCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" Cursor="Hand" ToolTip="Edit Employee" />
                                    
                                    <Button Content="" FontFamily="Segoe MDL2 Assets" 
                                            Background="Transparent" BorderThickness="0" Foreground="#80FF4B4B"
                                            Command="{Binding DataContext.DeleteEmployeeCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" Cursor="Hand" ToolTip="Delete Employee" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="2" Background="#80000000" CornerRadius="12" Visibility="{Binding IsBusy, Converter={StaticResource VisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Foreground="{StaticResource AccentBlue}" Background="#20FFFFFF"/>
                <TextBlock Text="{Binding BusyText}" Foreground="White" Margin="0,15,0,0" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Detail View Overlay (ContentControl ensures it's only created when DetailViewModel is present) -->
        <ContentControl Grid.Row="0" Grid.RowSpan="3" Content="{Binding DetailViewModel}">
            <ContentControl.Resources>
                <DataTemplate DataType="{x:Type vm:EmployeeDetailViewModel}">
                    <views:EmployeeDetailView />
                </DataTemplate>
            </ContentControl.Resources>
        </ContentControl>
    </Grid>
</UserControl>

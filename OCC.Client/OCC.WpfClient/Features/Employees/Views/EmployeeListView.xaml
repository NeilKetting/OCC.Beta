<UserControl x:Class="OCC.WpfClient.Features.Employees.Views.EmployeeListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:OCC.WpfClient.Features.Employees.ViewModels"
             xmlns:dtos="clr-namespace:OCC.Shared.DTOs;assembly=OCC.Shared"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200"
             d:DataContext="{d:DesignInstance Type=vm:EmployeeListViewModel}">
    
    <Grid Margin="30,20,30,30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Header -->
            <RowDefinition Height="Auto" /> <!-- Filters -->
            <RowDefinition Height="*" />    <!-- Grid -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,25">
            <StackPanel>
                <TextBlock Text="Employee Overview" FontSize="28" FontWeight="Bold" Foreground="White" />
                <TextBlock Text="Manage staff records, positions and teams." Foreground="{StaticResource TextSub}" FontSize="14" Margin="0,5,0,0"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                <Button Content="Add Employee" Style="{StaticResource PrimaryButton}" Command="{Binding AddEmployeeCommand}" Width="150" Height="40"/>
                <Button Content="Import" Style="{StaticResource SecondaryButton}" Command="{Binding ImportEmployeesCommand}" Width="100" Height="40" Margin="15,0,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Filters & Stats -->
        <Border Grid.Row="1" Background="{StaticResource GlassBackground}" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" /> <!-- Search -->
                    <ColumnDefinition Width="Auto" /> <!-- Employment Type -->
                    <ColumnDefinition Width="Auto" /> <!-- Branch -->
                    <ColumnDefinition Width="*" />    <!-- Spacer -->
                    <ColumnDefinition Width="Auto" /> <!-- Stats -->
                </Grid.ColumnDefinitions>

                <!-- Search -->
                <StackPanel Grid.Column="0" Width="250" Margin="0,0,20,0">
                    <TextBlock Text="SEARCH" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSub}" Margin="0,0,0,8"/>
                    <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" Tag="Search employees..." Style="{StaticResource ModernInput}" Height="35"/>
                </StackPanel>

                <!-- Employment Type -->
                <StackPanel Grid.Column="1" Width="150" Margin="0,0,20,0">
                    <TextBlock Text="EMPLOYMENT TYPE" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSub}" Margin="0,0,0,8"/>
                    <ComboBox SelectedIndex="{Binding SelectedFilterIndex}" Height="35" Style="{StaticResource ModernComboBox}">
                        <ComboBoxItem>Everyone</ComboBoxItem>
                        <ComboBoxItem>Permanent</ComboBoxItem>
                        <ComboBoxItem>Contract</ComboBoxItem>
                    </ComboBox>
                </StackPanel>

                <!-- Branch -->
                <StackPanel Grid.Column="2" Width="150">
                    <TextBlock Text="BRANCH" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSub}" Margin="0,0,0,8"/>
                    <ComboBox SelectedIndex="{Binding SelectedBranchFilterIndex}" Height="35" Style="{StaticResource ModernComboBox}">
                        <ComboBoxItem>All Branches</ComboBoxItem>
                        <ComboBoxItem>Johannesburg</ComboBoxItem>
                        <ComboBoxItem>Cape Town</ComboBoxItem>
                    </ComboBox>
                </StackPanel>

                <!-- Stats -->
                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Margin="0,0,30,0">
                        <TextBlock Text="TOTAL" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSub}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalCount}" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,30,0">
                        <TextBlock Text="PERMANENT" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSub}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding PermanentCount}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentBlue}" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="CONTRACT" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSub}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding ContractCount}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource SecondaryGold}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Employee Grid -->
        <Border Grid.Row="2" Background="{StaticResource GlassBackground}" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1" CornerRadius="12" Padding="2">
            <DataGrid ItemsSource="{Binding Employees}" 
                      SelectedItem="{Binding SelectedEmployee}"
                      AutoGenerateColumns="False" 
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="None"
                      Background="Transparent"
                      BorderThickness="0"
                      RowBackground="Transparent"
                      AlternatingRowBackground="#05FFFFFF">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="NUMBER" Binding="{Binding EmployeeNumber}" Width="120" />
                    <DataGridTextColumn Header="EMPLOYEE" Binding="{Binding DisplayName}" Width="*" />
                    <DataGridTextColumn Header="POSITION" Binding="{Binding Role}" Width="200" />
                    <DataGridTextColumn Header="TYPE" Binding="{Binding EmploymentType}" Width="150" />
                    <DataGridTemplateColumn Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="" FontFamily="Segoe MDL2 Assets" 
                                        Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextSub}"
                                        Command="{Binding DataContext.EditEmployeeCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Cursor="Hand">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="2" Background="#80000000" CornerRadius="12" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Foreground="{StaticResource AccentBlue}" Background="#20FFFFFF"/>
                <TextBlock Text="{Binding BusyText}" Foreground="White" Margin="0,15,0,0" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

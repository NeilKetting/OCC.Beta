<UserControl x:Class="OCC.WpfClient.Features.CustomerHub.Views.CustomerListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:OCC.WpfClient.Features.CustomerHub.ViewModels"
             xmlns:views="clr-namespace:OCC.WpfClient.Features.CustomerHub.Views"
             xmlns:ap="clr-namespace:OCC.WpfClient.Infrastructure.AttachedProperties"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200"
             d:DataContext="{d:DesignInstance Type=vm:CustomerListViewModel}">

    <UserControl.Resources>
        <DataTemplate DataType="{x:Type vm:CustomerDetailViewModel}">
            <views:CustomerDetailView />
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="0" Background="{StaticResource AppBackground}">
        <!-- Main Background Content -->
        <Grid>
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsOverlayActive}" Value="True">
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <BlurEffect Radius="15"/>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Opacity" Value="0.4"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- Header -->
                <RowDefinition Height="Auto" /> <!-- Stats & Search -->
                <RowDefinition Height="*" />    <!-- Grid -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="10">
                <StackPanel>
                    <TextBlock Text="Customer Management" FontSize="26" FontWeight="Bold" Foreground="White" />
                    <TextBlock Text="Manage clients and key contacts." Style="{StaticResource FormLabelText}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Style="{StaticResource PrimaryButton}" Command="{Binding AddCustomerCommand}" Width="150" Height="36" Cursor="Hand">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconPlus}" Fill="White" Width="12" Height="12" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Add Customer" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Stats & Search Line -->
            <Border Grid.Row="1" Style="{StaticResource GlassCard}" Padding="15,10" Margin="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" /> <!-- Search Icon -->
                        <ColumnDefinition Width="200" />  <!-- Search Box -->
                        <ColumnDefinition Width="*" />    <!-- Spacer -->
                        <ColumnDefinition Width="Auto" /> <!-- Stats -->
                    </Grid.ColumnDefinitions>

                    <!-- Search -->
                    <Path Grid.Column="0" Data="{StaticResource IconSearch}" Fill="{StaticResource TextSub}" Width="14" Height="14" Margin="5,0,10,0" VerticalAlignment="Center" Stretch="Uniform"/>
                    <TextBox Grid.Column="1" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource ModernInput}" Height="32" Padding="8,0" BorderThickness="0" Background="Transparent"
                             ap:WatermarkProperties.Watermark="Search customers..."/>

                    <!-- Stats -->
                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel Margin="0,0,30,0">
                            <TextBlock Text="TOTAL CUSTOMERS" FontSize="10" Foreground="{StaticResource TextSub}" FontWeight="Bold"/>
                            <TextBlock Text="{Binding TotalCount}" FontSize="18" Foreground="White" FontWeight="SemiBold"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Customer Grid -->
            <Border Grid.Row="2" Style="{StaticResource GlassCard}" Margin="10,5,10,10" ClipToBounds="True" CornerRadius="0">
                <DataGrid ItemsSource="{Binding Customers}" 
                          SelectedItem="{Binding SelectedCustomer}"
                          AutoGenerateColumns="False" 
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          CanUserAddRows="False">
                    <DataGrid.InputBindings>
                        <MouseBinding MouseAction="LeftDoubleClick" 
                                      Command="{Binding EditCustomerCommand}"
                                      CommandParameter="{Binding SelectedCustomer}" />
                    </DataGrid.InputBindings>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="NAME" Binding="{Binding Name}" Width="*" FontWeight="SemiBold" />
                        <DataGridTextColumn Header="EMAIL" Binding="{Binding Email}" Width="*" Foreground="{StaticResource TextSub}" />
                        <DataGridTextColumn Header="PHONE" Binding="{Binding Phone}" Width="150" />

                        <DataGridTemplateColumn Header="" Width="50">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button x:Name="ActionBtn" 
                                            Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextSub}"
                                            Cursor="Hand" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="10">
                                        <Path Data="{StaticResource IconEllipseVertical}" Fill="{StaticResource TextSub}" Width="16" Height="16" Stretch="Uniform"/>
                                        <Button.ContextMenu>
                                            <ContextMenu Style="{StaticResource ModernContextMenu}">
                                                <MenuItem Header="Edit Customer" Command="{Binding DataContext.EditCustomerCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}"/>
                                                <MenuItem Header="Delete Customer" Command="{Binding DataContext.DeleteCustomerCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" Foreground="{StaticResource ErrorRed}"/>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Loading Overlay -->
            <Border Grid.Row="2" Background="#80000000" CornerRadius="12" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="200" Height="4" Foreground="{StaticResource AccentBlue}" Background="#20FFFFFF"/>
                    <TextBlock Text="{Binding BusyText}" Foreground="White" Margin="0,15,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Detail View Overlay -->
        <ContentControl Content="{Binding OverlayViewModel}" />
    </Grid>
</UserControl>


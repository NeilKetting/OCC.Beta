<UserControl x:Class="OCC.WpfClient.Features.ProcurementHub.Views.InventoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:OCC.WpfClient.Features.ProcurementHub.ViewModels"
             xmlns:ap="clr-namespace:OCC.WpfClient.Infrastructure.AttachedProperties"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1024"
             d:DataContext="{d:DesignInstance Type=vm:InventoryViewModel}">
    
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="VisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="0"  Background="{StaticResource AppBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Header -->
            <RowDefinition Height="Auto" /> <!-- Compact Filters & Stats -->
            <RowDefinition Height="*" />    <!-- Grid -->
        </Grid.RowDefinitions>

        <!-- Header: Title, Subtitle, and Add Button -->
        <Grid Grid.Row="0" Margin="10">
            <StackPanel>
                <TextBlock Text="Inventory Management" FontSize="26" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Track stock levels, reorder points, and warehouse locations." 
                           Style="{StaticResource FormLabelText}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Style="{StaticResource PrimaryButton}" Command="{Binding AddItemCommand}" Width="140" Height="36" Cursor="Hand">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IconPlus}" Fill="White" Width="12" Height="12" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Add Stock Item" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Filters & Search Bar Row (Standardized with Employee Hub) -->
        <Border Grid.Row="1" Style="{StaticResource GlassCard}" Padding="15,10" Margin="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" /> <!-- Search Icon -->
                    <ColumnDefinition Width="200" /> <!-- Search Box -->
                    <ColumnDefinition Width="Auto" /> <!-- Divider -->
                    <ColumnDefinition Width="Auto" /> <!-- Category Filter -->
                    <ColumnDefinition Width="Auto" /> <!-- Status Filter -->
                    <ColumnDefinition Width="*" />    <!-- Spacer -->
                    <ColumnDefinition Width="Auto" /> <!-- Stats Badges -->
                </Grid.ColumnDefinitions>

                <!-- Search -->
                <Path Grid.Column="0" Data="{StaticResource IconSearch}" Fill="{StaticResource TextSub}" 
                      Width="14" Height="14" Margin="5,0,10,0" VerticalAlignment="Center" Stretch="Uniform"/>
                <TextBox Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernInput}" 
                         ap:WatermarkProperties.Watermark="Search items or SKUs..."
                         Height="32" Padding="8,0" BorderThickness="0" Background="Transparent"/>

                <Border Grid.Column="2" Width="1" Height="20" Background="{StaticResource GlassBorder}" Margin="15,0" VerticalAlignment="Center"/>

                <!-- Category Filter (Mockup for UI Consistency) -->
                <ComboBox Grid.Column="3" Width="130" Height="32" Style="{StaticResource ModernComboBox}" Margin="0,0,10,0" SelectedIndex="0">
                    <ComboBoxItem Content="All Categories" />
                    <ComboBoxItem Content="Tools" />
                    <ComboBoxItem Content="Electrical" />
                    <ComboBoxItem Content="Plumbing" />
                    <ComboBoxItem Content="Materials" />
                </ComboBox>

                <!-- Status Filter (Mockup for UI Consistency) -->
                <ComboBox Grid.Column="4" Width="140" Height="32" Style="{StaticResource ModernComboBox}" Margin="0,0,10,0" SelectedIndex="0">
                    <ComboBoxItem Content="All Statuses" />
                    <ComboBoxItem Content="OK" />
                    <ComboBoxItem Content="Low Stock" />
                    <ComboBoxItem Content="Out of Stock" />
                </ComboBox>

                <!-- Stats Badges -->
                <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#20FFFFFF" CornerRadius="12" Padding="10,4" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="TOTAL: " FontSize="10" Foreground="{StaticResource TextSub}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding TotalCount}" FontSize="12" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#20FF4B4B" CornerRadius="12" Padding="10,4" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="LOW STOCK: " FontSize="10" Foreground="{StaticResource TextSub}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding LowStockCount}" FontSize="12" FontWeight="Bold" Foreground="{StaticResource ErrorRed}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- DataGrid Section: Wrapped in reference-compliant border -->
        <Border Grid.Row="2" Style="{StaticResource GlassCard}" Padding="2" ClipToBounds="True"
                Margin="10,0,10,10">
            <DataGrid ItemsSource="{Binding Items}" AutoGenerateColumns="False" 
                      Background="Transparent" BorderThickness="0" CanUserAddRows="False"
                      IsReadOnly="True" ScrollViewer.HorizontalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="SKU" Binding="{Binding Sku}" Width="150"/>
                    <DataGridTextColumn Header="DESCRIPTION" Binding="{Binding Description}" Width="*"/>
                    <DataGridTextColumn Header="CATEGORY" Binding="{Binding Category}" Width="150"/>
                    <DataGridTextColumn Header="QUANTITY" Binding="{Binding QuantityOnHand}" Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLowStock}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource ErrorRed}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="LOCATION" Binding="{Binding Location}" Width="150"/>
                    <DataGridTextColumn Header="STATUS" Binding="{Binding Status}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Loading Overlay -->
        <ContentControl Grid.Row="2" Style="{StaticResource StandardLoadingOverlay}" 
                        Visibility="{Binding IsBusy, Converter={StaticResource VisibilityConverter}}"/>
    </Grid>
</UserControl>

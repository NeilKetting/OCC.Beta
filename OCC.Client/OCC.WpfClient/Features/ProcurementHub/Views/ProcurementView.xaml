<UserControl x:Class="OCC.WpfClient.Features.ProcurementHub.Views.ProcurementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OCC.WpfClient.Features.ProcurementHub.Views"
             xmlns:vm="clr-namespace:OCC.WpfClient.Features.ProcurementHub.ViewModels"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=vm:ProcurementViewModel}"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Border Background="{StaticResource CardBackground}" Padding="10">
            <StackPanel>
                <TextBlock Text="{Binding Title}" FontSize="26" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="This is the new Procurement Hub. Here you will manage Orders, Inventory, and Suppliers." 
                           Style="{StaticResource FormLabelText}" TextWrapping="Wrap"/>
                
                <Grid Margin="0,40,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Placeholder Cards -->
                    <Border Grid.Column="0" Background="#1500FF88" BorderBrush="#00FF88" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,10,0">
                        <StackPanel>
                            <Grid>
                                <TextBlock Text="ORDERS" Foreground="#00FF88" FontWeight="Bold" Margin="0,0,0,10"/>
                                <Button Content="+ New PO" Style="{StaticResource GhostButton}" 
                                        HorizontalAlignment="Right" VerticalAlignment="Top" 
                                        Padding="10,2" Height="25" FontSize="11"
                                        Command="{Binding NavigateToPurchaseOrderCommand}"/>
                            </Grid>
                            <TextBlock Text="12 Active" Foreground="White" FontSize="20"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="#1500FF88" BorderBrush="#00FF88" BorderThickness="1" CornerRadius="8" Padding="20" Margin="10,0,10,0">
                        <StackPanel>
                            <TextBlock Text="INVENTORY" Foreground="#00FF88" FontWeight="Bold" Margin="0,0,0,10"/>
                            <TextBlock Text="5 Low Stock" Foreground="White" FontSize="20"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Background="#1500FF88" BorderBrush="#00FF88" BorderThickness="1" CornerRadius="8" Padding="20" Margin="10,0,0,0">
                        <StackPanel>
                            <TextBlock Text="SUPPLIERS" Foreground="#00FF88" FontWeight="Bold" Margin="0,0,0,10"/>
                            <TextBlock Text="48 Active" Foreground="White" FontSize="20"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

<UserControl x:Class="OCC.WpfClient.Features.ProcurementHub.Views.Dialogs.FindOrderDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OCC.WpfClient.Features.ProcurementHub.Views.Dialogs"
             xmlns:vm="clr-namespace:OCC.WpfClient.Features.ProcurementHub.ViewModels.Dialogs"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900"
             d:DataContext="{d:DesignInstance Type=vm:FindOrderViewModel}">
    
    <Grid Background="#CC000000">
        <Border Style="{StaticResource GlassCard}" Width="850" Height="550" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Title & Tabs -->
                    <RowDefinition Height="Auto"/> <!-- Filters -->
                    <RowDefinition Height="*"/>    <!-- Results -->
                    <RowDefinition Height="Auto"/> <!-- Footer -->
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock Text="Find Transaction" FontSize="20" FontWeight="Bold" Foreground="White"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                         <Button Style="{StaticResource GhostButton}" Command="{Binding CloseCommand}" Padding="5">
                            <Path Data="{StaticResource IconClose}" Fill="White" Width="12" Height="12" Stretch="Uniform"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Filter Panel -->
                <Border Grid.Row="1" Background="#15FFFFFF" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Row 1 -->
                        <StackPanel Grid.Column="0" Margin="0,0,15,10">
                            <TextBlock Text="TRANSACTION TYPE" Style="{StaticResource FormLabelText}"/>
                            <ComboBox ItemsSource="{Binding TransactionTypes}" SelectedItem="{Binding TransactionType}" Style="{StaticResource ModernComboBox}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,15,10">
                            <TextBlock Text="SUPPLIER" Style="{StaticResource FormLabelText}"/>
                            <ComboBox ItemsSource="{Binding Suppliers}" SelectedItem="{Binding SelectedSupplier}" 
                                      DisplayMemberPath="Name" Style="{StaticResource ModernComboBox}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="0,0,15,10">
                            <TextBlock Text="DATE" Style="{StaticResource FormLabelText}"/>
                            <DatePicker SelectedDate="{Binding ToDate}" Style="{StaticResource ModernDatePicker}"/>
                        </StackPanel>

                        <!-- Row 2 -->
                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,15,0">
                            <TextBlock Text="NUMBER" Style="{StaticResource FormLabelText}"/>
                            <TextBox Text="{Binding OrderNumber}" Style="{StaticResource ModernInput}" Height="32"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,15,0">
                            <TextBlock Text="AMOUNT" Style="{StaticResource FormLabelText}"/>
                            <TextBox Text="{Binding Amount}" Style="{StaticResource ModernInput}" Height="32"/>
                        </StackPanel>

                        <!-- Find Button -->
                        <Button Grid.Row="1" Grid.Column="3" Style="{StaticResource PrimaryButton}" 
                                Command="{Binding FindCommand}" Content="Find" Width="100" Height="32" 
                                VerticalAlignment="Bottom"/>
                    </Grid>
                </Border>

                <!-- Results Grid -->
                <Border Grid.Row="2" Background="{StaticResource GlassBackground}" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1" CornerRadius="4">
                    <DataGrid ItemsSource="{Binding SearchResults}" AutoGenerateColumns="False" IsReadOnly="True" 
                              Background="Transparent" BorderThickness="0" SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="DATE" Binding="{Binding OrderDate, StringFormat=d}" Width="100"/>
                            <DataGridTextColumn Header="TYPE" Binding="{Binding OrderType}" Width="120"/>
                            <DataGridTextColumn Header="NUM" Binding="{Binding OrderNumber}" Width="100"/>
                            <DataGridTextColumn Header="NAME" Binding="{Binding SupplierName}" Width="*"/>
                            <DataGridTextColumn Header="MEMO" Binding="{Binding ReferenceNo}" Width="150"/>
                            <DataGridTextColumn Header="AMOUNT" Binding="{Binding TotalAmount, StringFormat=N2}" Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Margin" Value="0,0,10,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                        <DataGrid.InputBindings>
                            <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding GoToOrderCommand}" 
                                          CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=DataGrid}, Path=SelectedItem}"/>
                        </DataGrid.InputBindings>
                    </DataGrid>
                </Border>

                <!-- Footer Buttons -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                    <Button Style="{StaticResource SecondaryButton}" Content="Reset" Command="{Binding ResetCommand}" Margin="0,0,10,0" Width="100"/>
                    <Button Style="{StaticResource PrimaryButton}" Content="Go To" Command="{Binding GoToOrderCommand}" 
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=DataGrid}, Path=SelectedItem}" Width="100"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>

<UserControl x:Class="OCC.WpfClient.Features.ProcurementHub.Views.Dialogs.ItemNotFoundDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:OCC.WpfClient.Features.ProcurementHub.ViewModels.Dialogs"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=vm:ItemNotFoundViewModel}">
    
    <Grid Background="#7F000000">
        <Border Style="{StaticResource DetailViewModalBorder}" 
                VerticalAlignment="Center" HorizontalAlignment="Center" 
                Width="450" Padding="30">
            <StackPanel>
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Question Icon -->
                    <Path Data="{StaticResource IconHelp}" 
                          Fill="{StaticResource AccentBlue}" 
                          Width="48" Height="48" 
                          Stretch="Uniform" Margin="0,0,25,0"/>
                    
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Item Not Found" 
                                   FontSize="20" FontWeight="Bold" Foreground="White" 
                                   Margin="0,0,0,10"/>
                        <TextBlock Foreground="{StaticResource TextMain}" FontSize="14" TextWrapping="Wrap">
                            <Run Text="OCC did not find '"/>
                            <Run Text="{Binding Sku}" FontWeight="Bold"/>
                            <Run Text="' in your list of products and services."/>
                            <LineBreak/><LineBreak/>
                            <Run Text="Would you like to add it now? If not, go back and select an existing product or service."/>
                        </TextBlock>
                    </StackPanel>
                </Grid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Yes" Command="{Binding YesCommand}" 
                            Style="{StaticResource PrimaryButton}" Width="100" Margin="0,0,15,0"/>
                    <Button Content="No" Command="{Binding NoCommand}" 
                            Style="{StaticResource SecondaryButton}" Width="100"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

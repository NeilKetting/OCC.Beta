<UserControl x:Class="OCC.WpfClient.Features.ProcurementHub.Views.PurchaseOrderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:OCC.WpfClient.Features.ProcurementHub.ViewModels"
             xmlns:ap="clr-namespace:OCC.WpfClient.Infrastructure.AttachedProperties"
             xmlns:conv="clr-namespace:OCC.WpfClient.Infrastructure.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200"
             d:DataContext="{d:DesignInstance Type=vm:PurchaseOrderViewModel}">
    
    <UserControl.Resources>
        <conv:VisibilityConverter x:Key="VisibilityConverter"/>
        <conv:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        
        <Style x:Key="CompactLabel" TargetType="TextBlock" BasedOn="{StaticResource FormLabelText}">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>
        
        <Style x:Key="CompactTextBox" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="5,2"/>
        </Style>

        <Style x:Key="CompactComboBox" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="CompactDatePicker" TargetType="DatePicker" BasedOn="{StaticResource {x:Type DatePicker}}">
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </UserControl.Resources>
    
    <Grid Background="{StaticResource BackgroundDark}">
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header Logic -->
                <RowDefinition Height="*"/>    <!-- Grid -->
                <RowDefinition Height="Auto"/> <!-- Totals & SOW -->
                <RowDefinition Height="Auto"/> <!-- Footer Toolbar -->
            </Grid.RowDefinitions>

            <!-- Header: Supplier & Details -->
            <Border Grid.Row="0" Style="{StaticResource GlassCard}" Padding="15" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Column 1: Supplier -->
                    <StackPanel Grid.Column="0" Grid.RowSpan="2" Margin="0,0,15,0">
                        <TextBlock Text="Supplier" Style="{StaticResource CompactLabel}"/>
                        <ComboBox ItemsSource="{Binding Suppliers}" 
                                  SelectedItem="{Binding SelectedSupplier}"
                                  DisplayMemberPath="Name"
                                  Style="{StaticResource CompactComboBox}"
                                  ap:WatermarkProperties.Watermark="Select Supplier..."/>
                        
                        <TextBlock Text="Address" Style="{StaticResource CompactLabel}" Margin="0,8,0,2"/>
                        <TextBox Text="{Binding CurrentOrder.EntityAddress}" 
                                 Style="{StaticResource CompactTextBox}" 
                                 Height="60" AcceptsReturn="True" TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Column 2: Project / Reference -->
                    <StackPanel Grid.Column="1" Grid.RowSpan="2" Margin="0,0,15,0">
                        <TextBlock Text="Project Reference" Style="{StaticResource CompactLabel}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <RadioButton Content="Office" IsChecked="{Binding CurrentOrder.IsOfficeSelected}" Foreground="White" Margin="0,0,15,0"/>
                            <RadioButton Content="Site / Project" IsChecked="{Binding CurrentOrder.IsSiteSelected}" Foreground="White"/>
                        </StackPanel>
                        
                        <ComboBox ItemsSource="{Binding Projects}" 
                                  SelectedItem="{Binding SelectedProject}"
                                  DisplayMemberPath="Name"
                                  Style="{StaticResource CompactComboBox}"
                                  ap:WatermarkProperties.Watermark="Link Project..."
                                  Visibility="{Binding CurrentOrder.IsSiteSelected, Converter={StaticResource VisibilityConverter}}"/>

                        <TextBlock Text="Attention / Contact" Style="{StaticResource CompactLabel}" Margin="0,8,0,2"/>
                        <TextBox Text="{Binding CurrentOrder.Attention}" Style="{StaticResource CompactTextBox}"/>
                    </StackPanel>

                    <!-- Column 3: Dates -->
                    <StackPanel Grid.Column="2" Margin="0,0,15,0">
                        <TextBlock Text="Order Date" Style="{StaticResource CompactLabel}"/>
                        <DatePicker SelectedDate="{Binding CurrentOrder.OrderDate}" Style="{StaticResource CompactDatePicker}"/>

                        <TextBlock Text="Expected Delivery" Style="{StaticResource CompactLabel}" Margin="0,8,0,2"/>
                        <DatePicker SelectedDate="{Binding CurrentOrder.ExpectedDeliveryDate}" Style="{StaticResource CompactDatePicker}"/>
                    </StackPanel>

                    <!-- Column 4: Template & PO No -->
                    <StackPanel Grid.Column="3">
                        <TextBlock Text="Template" Style="{StaticResource CompactLabel}"/>
                        <ComboBox SelectedValue="{Binding CurrentOrder.Template}" Style="{StaticResource CompactComboBox}">
                            <ComboBoxItem Content="Standard PO"/>
                            <ComboBoxItem Content="Materials Only"/>
                            <ComboBoxItem Content="Service Order"/>
                        </ComboBox>

                        <TextBlock Text="P.O. NO." Style="{StaticResource CompactLabel}" Margin="0,8,0,2"/>
                        <TextBox Text="{Binding CurrentOrder.OrderNumber}" Style="{StaticResource CompactTextBox}" IsReadOnly="True" FontWeight="Bold"/>
                    </StackPanel>

                    <!-- Row 3: SOW & Delivery Instructions (Wide) -->
                    <Grid Grid.Row="2" Grid.ColumnSpan="4" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="Scope of Work (SOW)" Style="{StaticResource CompactLabel}"/>
                            <TextBox Text="{Binding CurrentOrder.ScopeOfWork}" Style="{StaticResource CompactTextBox}" ap:WatermarkProperties.Watermark="Brief description..."/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Delivery Instructions" Style="{StaticResource CompactLabel}" Foreground="{StaticResource AccentBlue}"/>
                            <TextBox Text="{Binding CurrentOrder.DeliveryInstructions}" Style="{StaticResource CompactTextBox}" FontWeight="SemiBold" ap:WatermarkProperties.Watermark="e.g. Gate 2, Call Foreman..."/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- Order Items Grid -->
            <Border Grid.Row="1" Style="{StaticResource GlassCard}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <DataGrid ItemsSource="{Binding CurrentOrder.Lines}" 
                              AutoGenerateColumns="False" 
                              Background="Transparent" BorderThickness="0" 
                              CanUserAddRows="False"
                              RowHeaderWidth="0">
                        <DataGrid.Columns>
                            <!-- Searchable Item Column -->
                            <DataGridTemplateColumn Header="ITEM" Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding DataContext.InventoryItems, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  SelectedItem="{Binding ItemCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  DisplayMemberPath="Sku" SelectedValuePath="Sku"
                                                  IsEditable="True"
                                                  Style="{StaticResource CompactComboBox}">
                                            <RadioButton Visibility="Collapsed"/> <!-- Hack to fix focus if needed -->
                                        </ComboBox>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="DESCRIPTION" Binding="{Binding Description}" Width="*" Foreground="{StaticResource TextSub}"/>
                            <DataGridTextColumn Header="REMARKS" Binding="{Binding Remarks}" Width="200"/>
                            <DataGridTextColumn Header="QUANTITY" Binding="{Binding QuantityOrdered}" Width="100"/>
                            <DataGridTextColumn Header="UNIT" Binding="{Binding UnitOfMeasure}" Width="60" IsReadOnly="True"/>
                            <DataGridTextColumn Header="UNIT PRICE" Binding="{Binding UnitPrice, StringFormat='N2'}" Width="100"/>
                            <DataGridTextColumn Header="AMOUNT" Binding="{Binding LineTotal, StringFormat='N2'}" Width="100" IsReadOnly="True"/>
                            
                            <DataGridTemplateColumn Header="ACTIONS" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Delete" Style="{StaticResource CancelButton}" 
                                                Height="22" FontSize="10" Padding="5,0"
                                                Command="{Binding DataContext.RemoveLineCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Button Grid.Row="1" Content="+ Add Line" Style="{StaticResource SecondaryButton}" 
                            HorizontalAlignment="Left" Margin="10" Command="{Binding AddLineCommand}"/>
                </Grid>
            </Border>

            <!-- Totals & Memo -->
            <Grid Grid.Row="2" Margin="0,10,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Reference / Memo" Style="{StaticResource CompactLabel}"/>
                    <TextBox Text="{Binding CurrentOrder.ReferenceNo}" Style="{StaticResource CompactTextBox}" Width="400" HorizontalAlignment="Left" ap:WatermarkProperties.Watermark="Internal reference..."/>
                </StackPanel>

                <Border Grid.Column="1" Style="{StaticResource GlassCard}" Padding="15">
                    <StackPanel>
                        <Grid Margin="0,0,0,5">
                            <TextBlock Text="Sub Total" Foreground="{StaticResource TextSub}"/>
                            <TextBlock Text="{Binding CurrentOrder.SubTotal, StringFormat='R {0:N2}'}" HorizontalAlignment="Right" Foreground="White"/>
                        </Grid>
                        <Grid Margin="0,0,0,5">
                            <TextBlock Text="VAT (15%)" Foreground="{StaticResource TextSub}"/>
                            <TextBlock Text="{Binding CurrentOrder.VatTotal, StringFormat='R {0:N2}'}" HorizontalAlignment="Right" Foreground="White"/>
                        </Grid>
                        <Separator Background="{StaticResource GlassBorder}" Margin="0,5"/>
                        <Grid>
                            <TextBlock Text="TOTAL" FontSize="16" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="{Binding CurrentOrder.TotalAmount, StringFormat='R {0:N2}'}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentBlue}" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Bottom Toolbar -->
            <Grid Grid.Row="3">
                <StackPanel Orientation="Horizontal">
                    <Button Content="Preview" Style="{StaticResource SecondaryButton}" Margin="0,0,10,0" Width="80"/>
                    <Button Content="Print" Style="{StaticResource SecondaryButton}" Margin="0,0,10,0" Width="80"/>
                    <Button Content="Email" Style="{StaticResource SecondaryButton}" Width="80"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Style="{StaticResource SecondaryButton}" Command="{Binding CancelCommand}" Margin="0,0,10,0" Width="100"/>
                    <Button Content="Finalise Order" Style="{StaticResource SecondaryButton}" Margin="0,0,10,0" Width="120"/>
                    <Button Content="CREATE ORDER" Style="{StaticResource PrimaryButton}" Command="{Binding SaveOrderCommand}" Width="150" Height="40"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Busy Overlay -->
        <Border Visibility="{Binding IsBusy, Converter={StaticResource VisibilityConverter}}" Background="#66000000" Margin="1116,0,0,0">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Margin="0,0,0,10"/>
                <TextBlock Text="{Binding BusyText}" Foreground="White" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

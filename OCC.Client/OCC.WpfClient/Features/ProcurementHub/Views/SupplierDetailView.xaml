<UserControl x:Class="OCC.WpfClient.Features.ProcurementHub.Views.SupplierDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:OCC.WpfClient.Features.ProcurementHub.ViewModels"
             xmlns:ap="clr-namespace:OCC.WpfClient.Infrastructure.AttachedProperties"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000"
             d:DataContext="{d:DesignInstance Type=vm:SupplierDetailViewModel}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Detail Modal -->
            <Border Grid.Column="1" Grid.Row="1" Style="{StaticResource DetailViewModalBorder}" Margin="0,20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="5" Opacity="0.5"/>
                </Border.Effect>

                <Grid>
                    <!-- Background Decoration -->
                    <Path Data="{StaticResource IconPersonal}" Fill="White" Opacity="0.02" 
                          Stretch="Uniform" Margin="40" HorizontalAlignment="Right" 
                          VerticalAlignment="Bottom" Width="300" Height="300"/>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Border Grid.Row="0" Style="{StaticResource DetailViewHeader}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}" FontSize="32" FontWeight="Bold" Foreground="White" />
                                    <TextBlock Text="Manage supplier contact information and banking details for procurement." FontSize="14" 
                                               Foreground="{StaticResource TextSub}" Margin="0,4,0,0"/>
                                </StackPanel>

                                <Button Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top" 
                                        Style="{StaticResource WindowCloseButton}" Command="{Binding CancelCommand}"/>
                            </Grid>
                        </Border>

                        <!-- Content -->
                        <ScrollViewer x:Name="MainScrollViewer" Grid.Row="1" Style="{StaticResource DetailViewContentScroll}" Padding="20,20,20,20">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="20" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Left Column: Core Info -->
                                    <StackPanel Grid.Column="0">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                            <Path Data="{StaticResource IconSummary}" Style="{StaticResource SectionIcon}"/>
                                            <TextBlock Text="General Information" Style="{StaticResource SectionHeaderText}"/>
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,15">
                                            <TextBlock Text="Supplier Name" Style="{StaticResource FormLabelText}"/>
                                            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernInput}" ap:WatermarkProperties.Watermark="Enter supplier name..."/>
                                        </StackPanel>
                                        
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="15" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,0,15">
                                                <TextBlock Text="VAT Number" Style="{StaticResource FormLabelText}"/>
                                                <TextBox Text="{Binding VatNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernInput}" ap:WatermarkProperties.Watermark="4XXXXXXXXX"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Margin="0,0,0,15">
                                                <TextBlock Text="Supplier Acc #" Style="{StaticResource FormLabelText}"/>
                                                <TextBox Text="{Binding SupplierAccountNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernInput}" ap:WatermarkProperties.Watermark="Optional..."/>
                                            </StackPanel>
                                        </Grid>

                                        <StackPanel Margin="0,0,0,15">
                                            <TextBlock Text="Physical Address" Style="{StaticResource FormLabelText}"/>
                                            <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernInput}" ap:WatermarkProperties.Watermark="123 Street Name..."/>
                                        </StackPanel>
                                        
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="15" />
                                                <ColumnDefinition Width="120" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,0,15">
                                                <TextBlock Text="City" Style="{StaticResource FormLabelText}"/>
                                                <TextBox Text="{Binding City, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernInput}" ap:WatermarkProperties.Watermark="City..."/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Margin="0,0,0,15">
                                                <TextBlock Text="Postal Code" Style="{StaticResource FormLabelText}"/>
                                                <TextBox Text="{Binding PostalCode, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernInput}" ap:WatermarkProperties.Watermark="Code..."/>
                                            </StackPanel>
                                        </Grid>

                                        <StackPanel Margin="0,0,0,25">
                                            <TextBlock Text="Assigned Branch" Style="{StaticResource FormLabelText}"/>
                                            <ComboBox ItemsSource="{Binding AvailableBranches}" SelectedItem="{Binding SelectedBranch}" Style="{StaticResource ModernComboBox}" Height="36"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Right Column: Contact & Bank Info -->
                                    <StackPanel Grid.Column="2">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                            <Path Data="{StaticResource IconPersonal}" Style="{StaticResource SectionIcon}"/>
                                            <TextBlock Text="Contact Details" Style="{StaticResource SectionHeaderText}"/>
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,15">
                                            <TextBlock Text="Contact Person" Style="{StaticResource FormLabelText}"/>
                                            <TextBox Text="{Binding ContactPerson, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernInput}" ap:WatermarkProperties.Watermark="Name..."/>
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,15">
                                            <TextBlock Text="Email Address" Style="{StaticResource FormLabelText}"/>
                                            <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernInput}" ap:WatermarkProperties.Watermark="supplier@email.com"/>
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,25">
                                            <TextBlock Text="Phone Number" Style="{StaticResource FormLabelText}"/>
                                            <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernInput}" ap:WatermarkProperties.Watermark="+27 ..."/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                            <Path Data="{StaticResource IconFile}" Style="{StaticResource SectionIcon}"/>
                                            <TextBlock Text="Banking Information" Style="{StaticResource SectionHeaderText}"/>
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,15">
                                            <TextBlock Text="Bank Name" Style="{StaticResource FormLabelText}"/>
                                            <ComboBox ItemsSource="{Binding AvailableBanks}" SelectedItem="{Binding SelectedBank}" Style="{StaticResource ModernComboBox}" Height="36"/>
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,15" Visibility="{Binding IsOtherBankSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="Custom Bank Name" Style="{StaticResource FormLabelText}"/>
                                            <TextBox Text="{Binding CustomBankName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernInput}" ap:WatermarkProperties.Watermark="Enter bank name..."/>
                                        </StackPanel>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="15" />
                                                <ColumnDefinition Width="120" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,0,15">
                                                <TextBlock Text="Account Number" Style="{StaticResource FormLabelText}"/>
                                                <TextBox Text="{Binding BankAccountNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernInput}" ap:WatermarkProperties.Watermark="Account #..."/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Margin="0,0,0,15">
                                                <TextBlock Text="Branch Code" Style="{StaticResource FormLabelText}"/>
                                                <TextBox Text="{Binding BranchCode, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernInput}" ap:WatermarkProperties.Watermark="Code..."/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Footer Actions -->
                        <Border Grid.Row="2" Style="{StaticResource DetailViewFooter}">
                            <Grid>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="Cancel" Style="{StaticResource CancelButton}" Command="{Binding CancelCommand}" Width="110" Height="40" Margin="0,0,15,0"/>
                                    <Button Content="Save Supplier" Style="{StaticResource PrimaryButton}" Command="{Binding SaveCommand}" Width="150" Height="40"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Busy Overlay -->
        <Grid Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=False}" Panel.ZIndex="100">
            <Border Background="{StaticResource BackgroundDark}" Opacity="0.7"/>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#33FFFFFF" Foreground="{StaticResource AccentBlue}"/>
                <TextBlock Text="{Binding BusyText}" Margin="0,10" Foreground="White" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>

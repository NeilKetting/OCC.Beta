<UserControl x:Class="OCC.WpfClient.Features.Chat.Views.ChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OCC.WpfClient.Features.Chat.Views"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1024"
             Background="#0f172a"> <!-- Dark slate blue (Tailwind slate-900) -->
    
    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Left Sidebar (Chat List) -->
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="2"/> <!-- Splitter -->
            <!-- Main Chat Area -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Sidebar: Chat Sessions -->
        <Border Grid.Column="0" Background="#1e293b" BorderBrush="#334155" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Background="#0f172a" Padding="15,20">
                    <Grid>
                        <TextBlock Text="Chats" Foreground="White" FontSize="20" FontWeight="Bold"/>
                        <Button x:Name="MenuButton" Click="MenuButton_Click" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" Padding="5">
                            <Path Data="{StaticResource IconEllipseVertical}" Fill="#94a3b8" Width="20" Height="20" Stretch="Uniform"/>
                            
                            <Button.ContextMenu>
                                <ContextMenu Background="Transparent" BorderThickness="0" Padding="10">
                                    <ContextMenu.Template>
                                        <ControlTemplate TargetType="ContextMenu">
                                            <Border Background="#232d36" CornerRadius="12" Padding="0,5" BorderBrush="#3b4a54" BorderThickness="1">
                                                <ItemsPresenter SnapsToDevicePixels="True"/>
                                            </Border>
                                        </ControlTemplate>
                                    </ContextMenu.Template>
                                    <ContextMenu.Resources>
                                        <!-- Clean Dark Theme MenuItem Template -->
                                        <Style TargetType="MenuItem">
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="Height" Value="45"/>
                                            <Setter Property="Padding" Value="15,0"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="MenuItem">
                                                        <Grid x:Name="MenuItemGrid" Background="Transparent" SnapsToDevicePixels="True">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="50" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            
                                                            <!-- Hover background -->
                                                            <Border x:Name="HighlightBorder" Grid.ColumnSpan="2" Background="Transparent" />
                                                            
                                                            <!-- Separator line (Tag="HasSeparator") -->
                                                            <Border x:Name="ItemSeparator" Grid.ColumnSpan="2" BorderBrush="#3b4a54" BorderThickness="0,1,0,0" VerticalAlignment="Top" Visibility="Collapsed" Margin="0,0"/>

                                                            <!-- Icon -->
                                                            <ContentPresenter Grid.Column="0" ContentSource="Icon" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                                            
                                                            <!-- Text -->
                                                            <ContentPresenter Grid.Column="1" ContentSource="Header" VerticalAlignment="Center" Margin="5,0,25,0"/>
                                                        </Grid>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsHighlighted" Value="True">
                                                                <Setter TargetName="HighlightBorder" Property="Background" Value="#182229" />
                                                            </Trigger>
                                                            <Trigger Property="Tag" Value="HasSeparator">
                                                                <Setter TargetName="ItemSeparator" Property="Visibility" Value="Visible" />
                                                                <Setter Property="Height" Value="46"/> <!-- Adjust height to include separator padding -->
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ContextMenu.Resources>
                                    
                                    <MenuItem Header="New group" FontSize="15">
                                        <MenuItem.Icon>
                                            <Path Data="{StaticResource IconNewGroup}" Fill="#8696a0" Width="18" Height="18" Stretch="Uniform"/>
                                        </MenuItem.Icon>
                                    </MenuItem>

                                    <MenuItem Header="Starred messages" FontSize="15">
                                        <MenuItem.Icon>
                                            <Path Data="{StaticResource IconStar}" Fill="#8696a0" Width="18" Height="18" Stretch="Uniform"/>
                                        </MenuItem.Icon>
                                    </MenuItem>

                                    <MenuItem Header="Select chats" FontSize="15">
                                        <MenuItem.Icon>
                                            <Path Data="{StaticResource IconSelectChats}" Fill="#8696a0" Width="18" Height="18" Stretch="Uniform"/>
                                        </MenuItem.Icon>
                                    </MenuItem>

                                    <MenuItem Header="Mark all as read" FontSize="15">
                                        <MenuItem.Icon>
                                            <Path Data="{StaticResource IconMarkAllAsRead}" Fill="#8696a0" Width="18" Height="18" Stretch="Uniform"/>
                                        </MenuItem.Icon>
                                    </MenuItem>

                                    <MenuItem Header="App lock" FontSize="15" Tag="HasSeparator">
                                        <MenuItem.Icon>
                                            <Path Data="{StaticResource IconLock}" Fill="#8696a0" Width="18" Height="18" Stretch="Uniform"/>
                                        </MenuItem.Icon>
                                    </MenuItem>

                                    <MenuItem Header="Log out" FontSize="15" Command="{Binding DataContext.LogoutCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                                        <MenuItem.Icon>
                                            <Path Data="{StaticResource IconLogout}" Fill="#8696a0" Width="18" Height="18" Stretch="Uniform"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </Button.ContextMenu>
                            
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="20" Padding="5">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#334155"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                <!-- Search -->
                <Border Grid.Row="1" Background="#1e293b" Padding="10">
                    <Border Background="#0f172a" CornerRadius="16" Padding="10,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Path Data="{StaticResource IconSearch}" Fill="#64748b" Width="14" Height="14" Stretch="Uniform" Margin="0,0,10,0"/>
                            <TextBlock Text="Search or start new chat" Foreground="#64748b" Grid.Column="1" VerticalAlignment="Center" Visibility="{Binding ElementName=SearchBox, Path=Text.IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            <TextBox x:Name="SearchBox" Grid.Column="1" Background="Transparent" BorderThickness="0" Foreground="White" CaretBrush="White"/>
                        </Grid>
                    </Border>
                </Border>

                <!-- Filters -->
                <Border Grid.Row="2" Background="#1e293b" Padding="10,0,10,10">
                    <StackPanel Orientation="Horizontal">
                        <StackPanel.Resources>
                            <!-- Filter Pill Style -->
                            <Style TargetType="RadioButton">
                                <Setter Property="GroupName" Value="ChatFilters"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="RadioButton">
                                            <Border x:Name="Border" Background="#2b3b4d" CornerRadius="15" Padding="12,6" Margin="0,0,8,0">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="#174f38"/>
                                                    <Setter Property="Foreground" Value="#10b981"/> <!-- Emerald Text -->
                                                </Trigger>
                                                <Trigger Property="IsChecked" Value="False">
                                                    <Setter Property="Foreground" Value="#94a3b8"/> <!-- Slate text -->
                                                </Trigger>
                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="IsMouseOver" Value="True"/>
                                                        <Condition Property="IsChecked" Value="False"/>
                                                    </MultiTrigger.Conditions>
                                                    <Setter TargetName="Border" Property="Background" Value="#334155"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </MultiTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </StackPanel.Resources>

                        <RadioButton Content="All" IsChecked="{Binding IsAllFilterSelected}" Command="{Binding SetFilterCommand}" CommandParameter="All" FontSize="13" FontWeight="SemiBold"/>
                        <RadioButton Content="Unread" IsChecked="{Binding IsUnreadFilterSelected}" Command="{Binding SetFilterCommand}" CommandParameter="Unread" FontSize="13" FontWeight="SemiBold"/>
                        <RadioButton Content="Favourites" IsChecked="{Binding IsFavouritesFilterSelected}" Command="{Binding SetFilterCommand}" CommandParameter="Favourites" FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <!-- List of Chats -->
                <ListView x:Name="ChatsListView" Grid.Row="3" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ItemsSource="{Binding SessionsView}" SelectedItem="{Binding SelectedSession}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10" Margin="0,2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <Ellipse Grid.Column="0" Width="40" Height="40" Fill="#334155" HorizontalAlignment="Left" />
                                    
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                                        <TextBlock Text="{Binding Name}" Foreground="White" FontSize="15" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding LastMessagePreview}" Foreground="#94a3b8" FontSize="13" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    
                                    <Grid Grid.Column="2" VerticalAlignment="Stretch" Margin="0,2,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="{Binding LastMessageTime, StringFormat='HH:mm'}" Foreground="#64748b" FontSize="11" HorizontalAlignment="Right"/>
                                        
                                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,5,0,0">
                                            
                                            <!-- Favourite Toggle -->
                                            <Button Command="{Binding DataContext.ToggleFavouriteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Background="Transparent" BorderThickness="0" Padding="0" Margin="0,0,5,0" Width="16" Height="16">
                                                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="&#xE734;" /> <!-- Outline Star -->
                                                            <Setter Property="Foreground" Value="#64748b" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsFavourite}" Value="True">
                                                                    <Setter Property="Text" Value="&#xE735;" /> <!-- Solid Star -->
                                                                    <Setter Property="Foreground" Value="#eab308" /> <!-- Yellow -->
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <!-- Simple button style strip -->
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <ContentPresenter/>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </Button.Style>
                                            </Button>

                                            <!-- Unread Bubble -->
                                            <Border Background="#10b981" CornerRadius="10" MinWidth="20" Height="20" Padding="5,0"
                                                    Visibility="{Binding UnreadCount, Converter={StaticResource VisibilityConverter}}">
                                                <TextBlock Text="{Binding UnreadCount}" Foreground="#0f172a" FontSize="11" FontWeight="Bold" 
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding UnreadCount}" Value="0">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Cursor="Hand">
                                            <ContentPresenter/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#334155"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#0f172a"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
            </Grid>
        </Border>

        <!-- New Chat Overlay -->
        <!-- Visibility toggled via BooleanToVisibilityConverter which is globally registered in App or native -->
        <Border Grid.Column="0" Background="#111b21" Visibility="{Binding IsNewChatVisible, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Background="#202c33" Padding="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Command="{Binding HideNewChatCommand}" Background="Transparent" BorderThickness="0" Padding="0,0,20,0" Cursor="Hand" VerticalAlignment="Center">
                            <Path Data="M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z" Fill="#00a884" Stretch="Uniform" Width="24" Height="24"/>
                        </Button>
                        <TextBlock Grid.Column="1" Text="New chat" Foreground="White" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Search -->
                <Border Grid.Row="1" Background="#111b21" Padding="12">
                    <Border Background="#202c33" CornerRadius="8" Padding="12,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Path Data="{StaticResource IconSearch}" Fill="#8696a0" Width="14" Height="14" Stretch="Uniform" Margin="0,0,15,0"/>
                            <TextBlock Text="Search name or email" Foreground="#8696a0" Grid.Column="1" VerticalAlignment="Center" Visibility="{Binding ElementName=NewChatSearchBox, Path=Text.IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}" FontSize="14"/>
                            <TextBox x:Name="NewChatSearchBox" Text="{Binding SearchContactsText, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1" Background="Transparent" BorderThickness="0" Foreground="White" CaretBrush="White" FontSize="14"/>
                        </Grid>
                    </Border>
                </Border>

                <!-- Contacts List -->
                <ListView Grid.Row="2" Background="Transparent" BorderThickness="0" ItemsSource="{Binding ContactsView}" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="15,12">
                                <Button Command="{Binding DataContext.StartNewChatCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Stretch">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <ContentPresenter/>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Grid.Column="0" Width="48" Height="48" Fill="#00a884" HorizontalAlignment="Left" />
                                        <TextBlock Grid.Column="0" Text="{Binding FirstName[0]}" Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="16,0,0,0" IsHitTestVisible="False"/>
                                        
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="5,0">
                                            <TextBlock Foreground="White" FontSize="16" TextTrimming="CharacterEllipsis">
                                                <Run Text="{Binding FirstName}"/> <Run Text="{Binding LastName}"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Email}" Foreground="#8696a0" FontSize="14" TextTrimming="CharacterEllipsis" Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#202c33"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
            </Grid>
        </Border>

        <GridSplitter Grid.Column="1" Width="2" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="#334155"/>

        <!-- Main Chat Area -->
        <Grid Grid.Column="2" Background="#0f172a"> <!-- WhatsApp-style dark background -->
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Active Chat Header -->
            <Border Grid.Row="0" Background="#1e293b" BorderBrush="#334155" BorderThickness="0,0,0,1" Padding="15"
                    Visibility="{Binding SelectedSession, Converter={StaticResource VisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Ellipse Width="40" Height="40" Fill="#334155" />
                    
                    <StackPanel Grid.Column="1" Margin="15,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding SelectedSession.Name}" Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding SelectedSession.Users.Count, StringFormat='{}{0} participants'}" Foreground="#10b981" FontSize="12" Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
            
            <TextBlock Grid.Row="0" Grid.RowSpan="3" Text="Select a chat to start messaging" Foreground="#64748b" FontSize="16" 
                       HorizontalAlignment="Center" VerticalAlignment="Center" 
                       Visibility="{Binding SelectedSession, Converter={StaticResource VisibilityConverter}, ConverterParameter='Invert'}"/>

            <!-- Message Area -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" 
                          Visibility="{Binding SelectedSession, Converter={StaticResource VisibilityConverter}}">
                <ItemsControl Margin="20" ItemsSource="{Binding SelectedSession.Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Layout logic for IsMine -->
                            <Grid Margin="0,10">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="HorizontalAlignment" Value="Left"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMine}" Value="True">
                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                
                                <Border CornerRadius="8" Padding="12,8" MaxWidth="500">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#334155"/> <!-- Received Message Color -->
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMine}" Value="True">
                                                    <Setter Property="Background" Value="#059669"/> <!-- Sent Message Color -->
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="{Binding SenderName}" Foreground="#10b981" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,5"
                                                   Visibility="{Binding IsMine, Converter={StaticResource VisibilityConverter}, ConverterParameter='Invert'}"/>
                                        
                                        <!-- Attachment Preview (simplified) -->
                                        <Border CornerRadius="6" Background="#1e293b" Padding="10" Margin="0,0,0,5"
                                                Visibility="{Binding HasAttachment, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Path Data="{StaticResource IconFile}" Fill="#94a3b8" Width="24" Height="24" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,10,0" />
                                                <TextBlock Grid.Column="1" Text="{Binding Dto.Attachments[0].FileName, FallbackValue='Attachment'}" Foreground="White" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                            </Grid>
                                        </Border>

                                        <TextBlock Text="{Binding Content}" Foreground="White" FontSize="14" TextWrapping="Wrap" LineHeight="20"/>
                                        <TextBlock Text="{Binding DisplayTime}" Foreground="#cbd5e1" FontSize="10" HorizontalAlignment="Right" Margin="0,5,0,0" Opacity="0.8"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Input Area -->
            <Border Grid.Row="2" Background="#1e293b" Padding="15"
                    Visibility="{Binding SelectedSession, Converter={StaticResource VisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Attachment -->
                    <Button Grid.Column="0" Background="Transparent" BorderThickness="0" Padding="10">
                        <Path Data="{StaticResource IconFile}" Fill="#64748b" Width="20" Height="20" Stretch="Uniform"/>
                    </Button>
                    
                    <Border Grid.Column="2" Background="#334155" CornerRadius="20" Margin="10,0">
                        <Grid>
                            <TextBlock Text="Type a message" Foreground="#94a3b8" Margin="15,0,0,0" VerticalAlignment="Center"
                                       Visibility="{Binding ElementName=MessageTextBox, Path=Text.IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            <TextBox x:Name="MessageTextBox" Text="{Binding MessageInput, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" BorderThickness="0" Foreground="White" Padding="15,10" CaretBrush="White" VerticalContentAlignment="Center">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter" Command="{Binding SendMessageCommand}" />
                                </TextBox.InputBindings>
                            </TextBox>
                        </Grid>
                    </Border>

                    <!-- Send Button -->
                    <Button Grid.Column="3" Background="#10b981" BorderThickness="0" Width="40" Height="40" x:Name="SendButton"
                            Command="{Binding SendMessageCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="20">
                                    <Path Data="{StaticResource IconCheck}" Fill="White" Width="18" Height="18" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>

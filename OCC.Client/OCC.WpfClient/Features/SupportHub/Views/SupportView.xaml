<UserControl x:Class="OCC.WpfClient.Features.SupportHub.Views.SupportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OCC.WpfClient.Features.SupportHub.ViewModels"
             xmlns:ap="clr-namespace:OCC.WpfClient.Infrastructure.AttachedProperties"
             Background="Transparent">

    <Grid>
        <!-- Background Overlay / Margin -->
        <Border Margin="30,20,30,30" Background="{StaticResource GlassBackground}" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1" CornerRadius="15" ClipToBounds="True">
            <Grid>
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsOverlayActive}" Value="True">
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <BlurEffect Radius="15" />
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Opacity" Value="0.4" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="350" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- LEFT PANEL: ISSUE LIST -->
                <Border Grid.Column="0" BorderBrush="{StaticResource GlassBorderUltraLight}" BorderThickness="0,0,1,0" Background="#05FFFFFF">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- List Header & Filters -->
                        <Border Padding="20,15" BorderBrush="{StaticResource GlassBorderUltraLight}" BorderThickness="0,0,0,1">
                            <StackPanel>
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Support Hub" FontSize="22" FontFamily="{StaticResource MichromaFont}" Foreground="White" />
                                    <Button Grid.Column="1" HorizontalAlignment="Right" Command="{Binding LoadBugsCommand}" Style="{StaticResource RoundIconButtonStyle}" Width="32" Height="32" Padding="0">
                                        <Path Data="{StaticResource IconHistory}" Fill="White" Stretch="Uniform" Width="14" Height="14" />
                                    </Button>
                                </Grid>

                                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{StaticResource ModernInput}" 
                                         Margin="0,0,0,10" />

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <ComboBox ItemsSource="{Binding StatusFilters}" SelectedItem="{Binding StatusFilter}" 
                                              Style="{StaticResource ModernComboBox}" Margin="0,0,5,0" />
                                    <ComboBox Grid.Column="1" ItemsSource="{Binding SortOptions}" SelectedItem="{Binding SortOption}" 
                                              Style="{StaticResource ModernComboBox}" Margin="5,0,0,0" />
                                </Grid>

                                <CheckBox IsChecked="{Binding ShowOnlyMyBugs}" Content="My Reported Bugs" 
                                          Foreground="White" FontSize="12" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <!-- Grouped List -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding GroupedBugs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <Border Background="#10FFFFFF" Padding="15,4" BorderBrush="{StaticResource GlassBorderUltraLight}" BorderThickness="0,1">
                                                <TextBlock Text="{Binding Title, Converter={StaticResource FriendlyEnumConverter}}" FontWeight="Bold" FontSize="11" Foreground="{StaticResource OrangeBrush}" />
                                            </Border>

                                            <ItemsControl ItemsSource="{Binding Items}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Background="Transparent" BorderThickness="0" Padding="0" HorizontalContentAlignment="Stretch"
                                                                Command="{Binding DataContext.SelectBugCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}" Style="{StaticResource ListActionButtonStyle}">
                                                            <Border Padding="15,12" BorderBrush="{StaticResource GlassBorderUltraLight}" BorderThickness="0,0,0,1">
                                                                <Grid>
                                                                    <!-- Selection Indicator -->
                                                                    <Border Width="4" HorizontalAlignment="Left" Margin="-15,-12,0,-12" Background="{StaticResource OrangeBrush}">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Value="True">
                                                                                        <DataTrigger.Binding>
                                                                                            <MultiBinding Converter="{StaticResource EqualityConverter}">
                                                                                                <Binding Path="DataContext.SelectedBug.Id" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                                                                                <Binding Path="Id" />
                                                                                            </MultiBinding>
                                                                                        </DataTrigger.Binding>
                                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                    </Border>

                                                                    <StackPanel>
                                                                        <Grid Margin="0,0,0,5">
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="*" />
                                                                                <ColumnDefinition Width="Auto" />
                                                                            </Grid.ColumnDefinitions>
                                                                            <TextBlock Text="{Binding ReporterName}" FontWeight="SemiBold" FontSize="14" Foreground="White" TextTrimming="CharacterEllipsis" />
                                                                            <Border Grid.Column="1" HorizontalAlignment="Right" CornerRadius="4" Padding="6,2" 
                                                                                    Background="{Binding Converter={StaticResource BugStatusBadgeConverter}, ConverterParameter='Background'}">
                                                                                <TextBlock Text="{Binding Status}" Foreground="White" FontSize="10" FontWeight="Bold" />
                                                                            </Border>
                                                                        </Grid>
                                                                        <TextBlock Text="{Binding ViewName}" FontSize="12" Foreground="{StaticResource OrangeBrush}" Opacity="0.8" Margin="0,0,0,3" />
                                                                        <TextBlock Text="{Binding Description}" FontSize="13" Foreground="White" Opacity="0.6" TextTrimming="CharacterEllipsis" TextWrapping="Wrap" MaxHeight="40" />
                                                                        <TextBlock Text="{Binding ReportedDate, StringFormat='{}{0:MMM dd, HH:mm}'}" FontSize="10" Foreground="White" Opacity="0.3" Margin="0,5,0,0" HorizontalAlignment="Right" />
                                                                    </StackPanel>
                                                                </Grid>
                                                            </Border>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- RIGHT PANEL: DETAILS & DISCUSSION -->
                <Grid Grid.Column="1">
                    <!-- Empty State -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedBug}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Path Data="{StaticResource IconBug}" Fill="White" Opacity="0.1" Width="64" Height="64" Stretch="Uniform" />
                        <TextBlock Text="Select an issue to view details" Foreground="White" Opacity="0.3" Margin="0,15,0,0" />
                    </StackPanel>

                    <!-- Detailed View -->
                    <Grid Visibility="{Binding SelectedBug, Converter={StaticResource VisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Detail Header -->
                        <Border Padding="25,20" BorderBrush="{StaticResource GlassBorderUltraLight}" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,15,0">
                                <TextBlock Text="{Binding SelectedBug.ViewName, StringFormat='Issue in {0}'}" FontSize="24" FontFamily="{StaticResource MichromaFont}" Foreground="White" Margin="0,0,0,5" TextWrapping="Wrap" />
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconUserOnline}" Fill="White" Opacity="0.4" Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding SelectedBug.ReporterName}" Foreground="White" Opacity="0.6" FontSize="13" Margin="5,0,20,0" />
                                    <Path Data="{StaticResource IconTime}" Fill="White" Opacity="0.4" Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding SelectedBug.ReportedDate, StringFormat='{}{0:MMM dd, yyyy HH:mm}'}" Foreground="White" Opacity="0.6" FontSize="13" Margin="5,0,0,0" />
                                </StackPanel>
                            </StackPanel>
                            <Border Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top" CornerRadius="6" Padding="15,6" 
                                    Background="{Binding SelectedBug, Converter={StaticResource BugStatusBadgeConverter}, ConverterParameter='Background'}">
                                <TextBlock Text="{Binding SelectedBug.Status}" Foreground="White" FontSize="12" FontWeight="Bold" />
                            </Border>
                        </Grid>
                        </Border>

                        <!-- Scrollable Detail Content -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <Border Padding="30">
                                <StackPanel>
                                    <TextBlock Text="DESCRIPTION" FontSize="11" FontWeight="Bold" Foreground="{StaticResource OrangeBrush}" Margin="0,0,0,10" />
                                    <TextBlock Text="{Binding SelectedBug.Description}" Foreground="White" FontSize="16" TextWrapping="Wrap" LineHeight="24" Margin="0,0,0,30" />

                                    <!-- Screenshot -->
                                    <Border Margin="0,0,0,30" Visibility="{Binding SelectedBug.ScreenshotBase64, Converter={StaticResource VisibilityConverter}}">
                                        <StackPanel>
                                            <TextBlock Text="SCREENSHOT" FontSize="11" FontWeight="Bold" Foreground="{StaticResource OrangeBrush}" Margin="0,0,0,10" />
                                            <Border CornerRadius="8" ClipToBounds="True" BorderBrush="{StaticResource GlassBorderUltraLight}" BorderThickness="1" HorizontalAlignment="Left" MaxWidth="800">
                                                <Image Source="{Binding SelectedBug.ScreenshotBase64, Converter={StaticResource Base64ToImageConverter}}" Stretch="Uniform" />
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <Separator Background="{StaticResource GlassBorderUltraLight}" Margin="0,0,0,30" />

                                    <!-- Discussion & Solutions -->
                                    <TextBlock Text="DISCUSSION &amp; SOLUTIONS" FontSize="11" FontWeight="Bold" Foreground="{StaticResource OrangeBrush}" Margin="0,0,0,20" />

                                    <ItemsControl ItemsSource="{Binding SelectedBug.Comments}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,20" CornerRadius="0,12,12,12">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#08FFFFFF" />
                                                            <Setter Property="BorderBrush" Value="{StaticResource GlassBorderUltraLight}" />
                                                            <Setter Property="BorderThickness" Value="1" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSolution}" Value="True">
                                                                    <Setter Property="Background" Value="#1500FF88" />
                                                                    <Setter Property="BorderBrush" Value="#00FF88" />
                                                                    <Setter Property="BorderThickness" Value="2" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsDevComment}" Value="True">
                                                                    <Setter Property="BorderBrush" Value="{StaticResource OrangeBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Border Padding="15">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="40" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>

                                                            <!-- Avatar -->
                                                            <Border Width="32" Height="32" CornerRadius="16" Background="#20FFFFFF" VerticalAlignment="Top">
                                                                <TextBlock Text="{Binding Initials}" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                            </Border>

                                                            <!-- Content -->
                                                            <StackPanel Grid.Column="1" Margin="15,0,0,0">
                                                                <Grid Margin="0,0,0,5">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="{Binding AuthorName}" Foreground="White" FontWeight="Bold" FontSize="14" />
                                                                        <Border Margin="10,0,0,0" VerticalAlignment="Center" CornerRadius="2" Padding="4,0" Background="#EEF2FF" Visibility="{Binding IsDevComment, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                            <TextBlock Text="DEV" FontSize="9" FontWeight="Bold" Foreground="#4F46E5" />
                                                                        </Border>
                                                                        <Border Margin="10,0,0,0" VerticalAlignment="Center" CornerRadius="2" Padding="4,0" Background="#00FF88" Visibility="{Binding IsSolution, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                            <TextBlock Text="SOLUTION" FontSize="9" FontWeight="Bold" Foreground="Black" />
                                                                        </Border>
                                                                    </StackPanel>
                                                                    <TextBlock HorizontalAlignment="Right" Text="{Binding CreatedAtUtc, StringFormat='{}{0:MMM dd, HH:mm}'}" Foreground="White" Opacity="0.3" FontSize="11" />
                                                                </Grid>
                                                                <TextBlock Text="{Binding Content}" Foreground="White" Opacity="0.9" FontSize="14" TextWrapping="Wrap" />
                                                            </StackPanel>

                                                            <!-- Actions -->
                                                            <StackPanel Grid.Column="2" VerticalAlignment="Top" Margin="10,0,0,0">
                                                                <Button Style="{StaticResource RoundIconButtonStyle}" Width="32" Height="32" Padding="0"
                                                                        Command="{Binding DataContext.MarkAsSolutionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                        CommandParameter="{Binding}"
                                                                        Visibility="{Binding DataContext.IsDev, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                        ToolTip="Mark as Solution">
                                                                    <Path Data="{StaticResource IconCheck}" Fill="#00FF88" Stretch="Uniform" Width="14" Height="14" />
                                                                </Button>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Reply Input -->
                                    <Border Margin="0,20,0,0" Padding="20" Background="#05FFFFFF" BorderBrush="{StaticResource GlassBorderUltraLight}" BorderThickness="1" CornerRadius="12">
                                        <StackPanel>
                                            <TextBlock Text="POST A REPLY" FontSize="11" FontWeight="Bold" Foreground="{StaticResource OrangeBrush}" Margin="0,0,0,10" />
                                            <TextBox Text="{Binding NewCommentText, UpdateSourceTrigger=PropertyChanged}" 
                                                     Style="{StaticResource ModernInput}" 
                                                     AcceptsReturn="True" MinHeight="100" VerticalAlignment="Top" />
                                            <Button Command="{Binding SendCommentCommand}" Style="{StaticResource PrimaryButton}" Content="Post Comment" HorizontalAlignment="Right" Margin="0,15,0,0" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </ScrollViewer>

                        <!-- Footer Actions -->
                        <Border Grid.Row="2" Padding="30,15" BorderBrush="{StaticResource GlassBorderUltraLight}" BorderThickness="0,1,0,0" Background="#08FFFFFF"
                                Visibility="{Binding IsDev, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Command="{Binding RequestInfoCommand}" Style="{StaticResource SecondaryButton}" Content="Request Info" Margin="0,0,10,0" />
                                <Button Command="{Binding MarkFixedCommand}" Style="{StaticResource SecondaryButton}" Content="Mark Fixed" Margin="0,0,10,0" Foreground="#00FF88" />
                                <Button Command="{Binding CloseBugCommand}" Style="{StaticResource SecondaryButton}" Content="Close Bug" Margin="0,0,20,0" />
                                <Button Command="{Binding DeleteBugCommand}" Style="{StaticResource CancelButton}" Content="Delete Bug" />
                            </StackPanel>
                        </Border>
                    </Grid>
                    
                    <!-- Loading Overlay -->
                    <Border Background="#40000000" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <ProgressBar IsIndeterminate="True" Width="200" Height="4" Foreground="{StaticResource OrangeBrush}" Background="Transparent" BorderThickness="0" />
                            <TextBlock Text="{Binding BusyText}" Foreground="White" HorizontalAlignment="Center" Margin="0,10,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>


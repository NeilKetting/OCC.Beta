<Window x:Class="OCC.WpfClient.Features.Splash.Views.SplashView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Loading..." Height="450" Width="400"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display">
    <Window.Resources>
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.8"/>
        </Storyboard>
    </Window.Resources>
    
    <Border Margin="10" CornerRadius="20" Background="{StaticResource BackgroundDark}" BorderBrush="{StaticResource AccentBlue}" BorderThickness="1">
        <Grid>
            <!-- Background Glow -->
            <Ellipse Fill="{StaticResource AccentBlue}" Opacity="0.05" Margin="50">
                <Ellipse.Effect>
                    <BlurEffect Radius="100"/>
                </Ellipse.Effect>
            </Ellipse>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <!-- Logo -->
                <Image Source="/Assets/Images/occ_logo2.png" Width="200" Margin="0,0,0,40" RenderOptions.BitmapScalingMode="HighQuality"/>
                
                <!-- Loading Animation -->
                <Grid Width="60" Height="60">
                    <Path x:Name="spinnerPath" 
                          Data="M 30 5 A 25 25 0 1 0 55 30" 
                          Stroke="{StaticResource AccentBlue}" 
                          StrokeThickness="4" 
                          StrokeStartLineCap="Round" 
                          StrokeEndLineCap="Round"
                          RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <RotateTransform x:Name="spinnerTransform" Angle="0" />
                        </Path.RenderTransform>
                    </Path>
                </Grid>

                <TextBlock Text="INITIALIZING SYSTEMS" 
                           Foreground="{StaticResource TextSub}" 
                           FontFamily="{StaticResource MichromaFont}" 
                           FontSize="{StaticResource FontSizeSmall}" 
                           HorizontalAlignment="Center" 
                           Margin="0,30,0,5" />

                <!-- Dynamic Status Message -->
                <TextBlock Text="{Binding LoadingStatus}" 
                           Foreground="{StaticResource AccentBlue}" 
                           FontSize="{StaticResource FontSizeSmall}" 
                           HorizontalAlignment="Center" 
                           Opacity="0.8"
                           FontStyle="Italic"
                           Margin="0,0,0,20"/>

                <!-- Progress Bar (Visible during updates) -->
                <ProgressBar x:Name="updateProgress" 
                             Width="200" Height="4" 
                             Background="{StaticResource LoadingProgressBackground}" 
                             BorderThickness="0"
                             Foreground="{StaticResource AccentBlue}"
                             Value="{Binding ProgressValue}"
                             Visibility="{Binding IsUpdateDownloading, Converter={StaticResource VisibilityConverter}}" />
            </StackPanel>
        </Grid>
    </Border>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource FadeIn}"/>
            <BeginStoryboard>
                <Storyboard RepeatBehavior="Forever">
                    <DoubleAnimation Storyboard.TargetName="spinnerTransform"
                                     Storyboard.TargetProperty="Angle"
                                     From="0" To="360" Duration="0:0:1.5" />
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
</Window>


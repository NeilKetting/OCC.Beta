<UserControl x:Class="OCC.WpfClient.Features.SettingsHub.Views.CompanySettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OCC.WpfClient.Features.SettingsHub.Views"
             xmlns:vm="clr-namespace:OCC.WpfClient.Features.SettingsHub.ViewModels"
             xmlns:ap="clr-namespace:OCC.WpfClient.Infrastructure.AttachedProperties"
             xmlns:conv="clr-namespace:OCC.WpfClient.Infrastructure.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000"
             d:DataContext="{d:DesignInstance Type=vm:CompanySettingsViewModel, IsDesignTimeCreatable=True}">
    
    <Grid Margin="20">

        <Border Background="{StaticResource CardBackground}" 
                CornerRadius="16" 
                BorderBrush="{StaticResource GlassBorder}" 
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.3" Color="Black"/>
            </Border.Effect>
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Padding="24" BorderBrush="{StaticResource GlassBorder}" BorderThickness="0,0,0,1">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="System Settings" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextMain}"/>
                            <TextBlock Text="Configure global system preferences and financial defaults." Margin="0,4,0,0" Foreground="{StaticResource TextSub}"/>
                        </StackPanel>
                        
                        <Button HorizontalAlignment="Right" VerticalAlignment="Top" 
                                Command="{Binding CloseCommand}" 
                                Style="{StaticResource GhostButton}">

                            <Path Data="{StaticResource IconClose}" Fill="{StaticResource TextSub}" Stretch="Uniform" Width="12" Height="12"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- Content -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="24" MaxWidth="800" HorizontalAlignment="Left">

                        
                        <!-- Financial Settings -->
                        <Border Background="{StaticResource InputBackground}" CornerRadius="12" Padding="24" Visibility="{Binding IsAdmin, Converter={StaticResource VisibilityConverter}}" Margin="0,0,0,32">

                            <StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                    <Path Data="{StaticResource IconBank}" Fill="{StaticResource AccentBlue}" Stretch="Uniform" Width="20" Height="20"/>
                                    <TextBlock Text="Financial Settings" Margin="12,0,0,0" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextMain}" VerticalAlignment="Center"/>
                                </StackPanel>

                                
                                <StackPanel>

                                    <TextBlock Text="Global Loan Interest Rate (%)" Style="{StaticResource FormLabelText}"/>
                                    <TextBox Text="{Binding CompanyDetails.GlobalLoanInterestRate, StringFormat='N2'}" 
                                             Style="{StaticResource ModernInput}" 
                                             Width="200" HorizontalAlignment="Left"
                                             ap:WatermarkProperties.Watermark="e.g. 5.00"
                                             Margin="0,8"/>

                                    <TextBlock Text="This rate will be the default for new employee loans, but can be overridden per loan." FontSize="12" Foreground="{StaticResource TextSub}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        
                        <Border Background="{StaticResource InputBackground}" CornerRadius="12" Padding="24" Visibility="{Binding IsAdmin, Converter={StaticResource VisibilityConverter}}">

                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,24">

                                    <Path Data="{StaticResource IconGear}" Fill="{StaticResource AccentBlue}" Stretch="Uniform" Width="20" Height="20"/>
                                    <TextBlock Text="Automated Workflows" Margin="12,0,0,0" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextMain}" VerticalAlignment="Center"/>
                                </StackPanel>

                                
                                <!-- Toggle -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <CheckBox IsChecked="{Binding CompanyDetails.AutoClockInEnabled}" 
                                              Style="{StaticResource ModernToggleSwitch}" 
                                              VerticalAlignment="Top"/>
                                    
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                        <TextBlock Text="Automatic Daily Clock-In" FontWeight="SemiBold" Foreground="{StaticResource TextMain}"/>
                                        <TextBlock Text="Automatically clocks in active employees based on their shift start time." FontSize="12" Foreground="{StaticResource TextSub}" TextWrapping="Wrap" Margin="0,4,0,24"/>
                                    </StackPanel>
                                </Grid>


                                <!-- Days Selection -->
                                <StackPanel Visibility="{Binding CompanyDetails.AutoClockInEnabled, Converter={StaticResource VisibilityConverter}}">


                                    <TextBlock Text="Enable for the following days:" Style="{StaticResource FormLabelText}" Margin="0,0,0,12"/>

                                    <WrapPanel>
                                        <CheckBox Content="Monday" IsChecked="{Binding IsMondayEnabled}" Style="{StaticResource ModernCheckBox}" Margin="0,0,24,12"/>
                                        <CheckBox Content="Tuesday" IsChecked="{Binding IsTuesdayEnabled}" Style="{StaticResource ModernCheckBox}" Margin="0,0,24,12"/>
                                        <CheckBox Content="Wednesday" IsChecked="{Binding IsWednesdayEnabled}" Style="{StaticResource ModernCheckBox}" Margin="0,0,24,12"/>
                                        <CheckBox Content="Thursday" IsChecked="{Binding IsThursdayEnabled}" Style="{StaticResource ModernCheckBox}" Margin="0,0,24,12"/>
                                        <CheckBox Content="Friday" IsChecked="{Binding IsFridayEnabled}" Style="{StaticResource ModernCheckBox}" Margin="0,0,24,12"/>
                                        <CheckBox Content="Saturday" IsChecked="{Binding IsSaturdayEnabled}" Style="{StaticResource ModernCheckBox}" Margin="0,0,24,12"/>
                                        <CheckBox Content="Sunday" IsChecked="{Binding IsSundayEnabled}" Style="{StaticResource ModernCheckBox}" Margin="0,0,24,12"/>
                                    </WrapPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Footer -->
                <Border Grid.Row="2" Padding="24" BorderBrush="{StaticResource GlassBorder}" BorderThickness="0,1,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Close" Command="{Binding CloseCommand}" Style="{StaticResource GhostButton}" Width="100" Margin="0,0,12,0"/>
                        <Button Content="Save Settings" Command="{Binding SaveSettingsAsyncCommand}" Style="{StaticResource PrimaryButton}" Width="150" IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBooleanConverter}}"/>
                    </StackPanel>

                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>

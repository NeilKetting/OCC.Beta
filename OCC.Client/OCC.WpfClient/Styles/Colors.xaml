<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Primary Colors -->
    <Color x:Key="BackgroundDarkColor">#0F172A</Color>
    <Color x:Key="BackgroundDarkerColor">#080E1A</Color>
    <Color x:Key="CardBackgroundColor">#1A1F2B</Color>
    <Color x:Key="AccentBlueColor">#2E9DFF</Color>
    <Color x:Key="AccentBlueHoverColor">#49AEFF</Color>
    <Color x:Key="AccentBluePressedColor">#1E80D6</Color>
    
    <!-- Input Colors -->
    <Color x:Key="InputBackgroundColor">#33475A6B</Color>
    <Color x:Key="InputBackgroundHoverColor">#4D475A6B</Color>
    <Color x:Key="InputBorderColor">#4A5B6F</Color>
    <Color x:Key="InputBorderHoverColor">#6A7B8F</Color>
    
    <!-- Text & UI Colors -->
    <Color x:Key="TextMainColor">#FFFFFF</Color>
    <Color x:Key="TextSubColor">#A0FFFFFF</Color>
    <Color x:Key="ErrorRedColor">#FF4B4B</Color>
    <Color x:Key="TransparencyColor">#00000000</Color>
    <Color x:Key="GlassBackgroundColor">#B30F172A</Color>
    <Color x:Key="GlassBorderColor">#40FFFFFF</Color>
    <Color x:Key="AuthGradientStartColor">#B300252E</Color>
    <Color x:Key="AuthGradientEndColor">#D90F172A</Color>
    <Color x:Key="Orange">#FF8F00</Color>
    <Color x:Key="SidebarBackgroundColor">#1A0F172A</Color>
    <Color x:Key="SidebarItemHoverColor">#1AFFFFFF</Color>
    <Color x:Key="SidebarItemActiveColor">#2E9DFF</Color>
    <Color x:Key="GlassBorderLightColor">#4DFFFFFF</Color>
    <Color x:Key="GlassBorderUltraLightColor">#1AFFFFFF</Color>
    <Color x:Key="GlassBackgroundVibrantColor">#B31A1F2B</Color>
    <Color x:Key="GlassBackgroundSubtleColor">#330F172A</Color>
    <Color x:Key="SecondaryGoldColor">#FFC107</Color>
    <Color x:Key="SuccessGreenColor">#00C853</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BackgroundDark" Color="{StaticResource BackgroundDarkColor}" />
    <SolidColorBrush x:Key="BackgroundDarker" Color="{StaticResource BackgroundDarkerColor}" />
    <SolidColorBrush x:Key="CardBackground" Color="{StaticResource CardBackgroundColor}" />
    <SolidColorBrush x:Key="AccentBlue" Color="{StaticResource AccentBlueColor}" />
    <SolidColorBrush x:Key="AccentBlueHover" Color="{StaticResource AccentBlueHoverColor}" />
    <SolidColorBrush x:Key="AccentBluePressed" Color="{StaticResource AccentBluePressedColor}" />
    
    <SolidColorBrush x:Key="InputBackground" Color="{StaticResource InputBackgroundColor}" />
    <SolidColorBrush x:Key="InputBackgroundHover" Color="{StaticResource InputBackgroundHoverColor}" />
    <SolidColorBrush x:Key="InputBorder" Color="{StaticResource InputBorderColor}" />
    <SolidColorBrush x:Key="InputBorderHover" Color="{StaticResource InputBorderHoverColor}" />
    
    <SolidColorBrush x:Key="TextMain" Color="{StaticResource TextMainColor}" />
    <SolidColorBrush x:Key="TextSub" Color="{StaticResource TextSubColor}" />
    <SolidColorBrush x:Key="ErrorRed" Color="{StaticResource ErrorRedColor}" />
    <SolidColorBrush x:Key="TransparentBrush" Color="{StaticResource TransparencyColor}" />
    <SolidColorBrush x:Key="GlassBackground" Color="{StaticResource GlassBackgroundColor}" />
    <SolidColorBrush x:Key="GlassBorder" Color="{StaticResource GlassBorderColor}" />
    <SolidColorBrush x:Key="AuthGradientStart" Color="{StaticResource AuthGradientStartColor}" />
    <SolidColorBrush x:Key="AuthGradientEnd" Color="{StaticResource AuthGradientEndColor}" />
    <SolidColorBrush x:Key="LoadingProgressBackground" Color="#1AFFFFFF" />
    <SolidColorBrush x:Key="OrangeBrush" Color="{StaticResource Orange}" />

    <SolidColorBrush x:Key="SidebarBackground" Color="{StaticResource SidebarBackgroundColor}" />
    <SolidColorBrush x:Key="SidebarItemHover" Color="{StaticResource SidebarItemHoverColor}" />
    <SolidColorBrush x:Key="SidebarItemActive" Color="{StaticResource SidebarItemActiveColor}" />
    <SolidColorBrush x:Key="GlassBorderLight" Color="{StaticResource GlassBorderLightColor}" />
    <SolidColorBrush x:Key="GlassBorderUltraLight" Color="{StaticResource GlassBorderUltraLightColor}" />
    <SolidColorBrush x:Key="GlassBackgroundVibrant" Color="{StaticResource GlassBackgroundVibrantColor}" />
    <SolidColorBrush x:Key="GlassBackgroundSubtle" Color="{StaticResource GlassBackgroundSubtleColor}" />
    <SolidColorBrush x:Key="SecondaryGold" Color="{StaticResource SecondaryGoldColor}" />

    <!-- New Workspace Resources -->
    <SolidColorBrush x:Key="GlassBorderMedium" Color="#66FFFFFF" />
    <LinearGradientBrush x:Key="SidebarActiveGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#4D2E9DFF" Offset="0" />
        <GradientStop Color="#1A2E9DFF" Offset="1" />
    </LinearGradientBrush>

    <!-- Glass Interactive Colors -->
    <SolidColorBrush x:Key="GlassBackgroundHover" Color="#33FFFFFF" />
    <SolidColorBrush x:Key="GlassBackgroundPressed" Color="#4DFFFFFF" />

    <!-- Ported from Avalonia LightMode.axaml -->
    <SolidColorBrush x:Key="PrimaryTeal" Color="#00b5ad" />
    <SolidColorBrush x:Key="PrimaryTealHover" Color="#00a39c" />
    <SolidColorBrush x:Key="PrimaryTealLight" Color="#e0f2f1" />

    <LinearGradientBrush x:Key="TopMenuGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#BF00252E" Offset="0.0" />
        <GradientStop Color="#800F172A" Offset="0.5" />
        <GradientStop Color="#B3FF8F00" Offset="1.0" />
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="PremiumGlassGlow" x:Shared="False" StartPoint="0,0" EndPoint="1,1">
        <LinearGradientBrush.RelativeTransform>
            <TranslateTransform X="0" Y="0" />
        </LinearGradientBrush.RelativeTransform>
        <GradientStop Color="#40FFFFFF" Offset="0" />
        <GradientStop Color="#00FFFFFF" Offset="1" />
    </LinearGradientBrush>

    <SolidColorBrush x:Key="SuccessGreen" Color="{StaticResource SuccessGreenColor}" />
    <SolidColorBrush x:Key="AppBackground" Color="{StaticResource BackgroundDarkColor}" />

</ResourceDictionary>

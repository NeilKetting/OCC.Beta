<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:conv="clr-namespace:OCC.WpfClient.Infrastructure.Converters">

    <!-- Global Converters -->
    <conv:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
    <conv:VisibilityConverter x:Key="VisibilityConverter" />
    <conv:FriendlyEnumConverter x:Key="FriendlyEnumConverter" />
    <conv:EnumToBooleanConverter x:Key="EnumToBoolConverter" />
    <conv:Base64ToImageConverter x:Key="Base64ToImageConverter" />
    <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
    <conv:HalfValueConverter x:Key="HalfValueConverter" />
    <conv:BugStatusBadgeConverter x:Key="BugStatusBadgeConverter" />
    <conv:EqualityConverter x:Key="EqualityConverter" />
    <conv:InverseBooleanConverter x:Key="InverseBooleanConverter" />
    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

</ResourceDictionary>

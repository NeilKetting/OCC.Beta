<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:models="clr-namespace:OCC.WpfClient.Models">

    <!-- Toast Container Style -->
    <Style x:Key="ToastContainerStyle" TargetType="ItemsControl">
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Vertical" VerticalAlignment="Bottom" HorizontalAlignment="Right"/>
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Toast Item Template -->
    <DataTemplate DataType="{x:Type models:ToastMessage}">
        <DataTemplate.Resources>
            <Storyboard x:Key="EnterAnim">
                <DoubleAnimation Storyboard.TargetName="ToastBorder" 
                                 Storyboard.TargetProperty="Opacity" 
                                 From="0" To="1" Duration="0:0:0.3"/>
                <DoubleAnimation Storyboard.TargetName="ToastBorder" 
                                 Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.X)" 
                                 From="100" To="0" Duration="0:0:0.4">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>
        </DataTemplate.Resources>

        <Border x:Name="ToastBorder" 
                MinWidth="300" MaxWidth="400" 
                Margin="0,0,20,15" 
                Padding="15" 
                CornerRadius="12" 
                BorderThickness="1"
                Background="{StaticResource GlassBackgroundVibrant}"
                BorderBrush="{StaticResource GlassBorderUltraLight}"
                Opacity="0"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <TransformGroup>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                    <TranslateTransform X="0" Y="0"/>
                </TransformGroup>
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.4"/>
            </Border.Effect>
            
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Icon -->
                <Viewbox Width="24" Height="24" Margin="0,0,15,0" VerticalAlignment="Top">
                    <Path x:Name="IconPath" Fill="White" Stretch="Uniform"/>
                </Viewbox>

                <!-- Content -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,0,0,2"/>
                    <TextBlock Text="{Binding Message}" Foreground="{StaticResource TextSub}" FontSize="12" TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>

        <DataTemplate.Triggers>
            <!-- Entrance Animation Trigger -->
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard Storyboard="{StaticResource EnterAnim}"/>
            </EventTrigger>

            <!-- Success Type -->
            <DataTrigger Binding="{Binding Type}" Value="Success">
                <Setter TargetName="IconPath" Property="Data" Value="{StaticResource IconSummary}"/>
                <Setter TargetName="IconPath" Property="Fill" Value="#10B981"/>
                <Setter TargetName="ToastBorder" Property="BorderBrush" Value="#4010B981"/>
            </DataTrigger>
            
            <!-- Error Type -->
            <DataTrigger Binding="{Binding Type}" Value="Error">
                <Setter TargetName="IconPath" Property="Data" Value="{StaticResource IconAlert}"/>
                <Setter TargetName="IconPath" Property="Fill" Value="{StaticResource ErrorRed}"/>
                <Setter TargetName="ToastBorder" Property="BorderBrush" Value="#40FF3B30"/>
            </DataTrigger>
            
            <!-- Warning Type -->
            <DataTrigger Binding="{Binding Type}" Value="Warning">
                <Setter TargetName="IconPath" Property="Data" Value="{StaticResource IconAlert}"/>
                <Setter TargetName="IconPath" Property="Fill" Value="{StaticResource SecondaryGold}"/>
                <Setter TargetName="ToastBorder" Property="BorderBrush" Value="#40F59E0B"/>
            </DataTrigger>
            
            <!-- Info Type -->
            <DataTrigger Binding="{Binding Type}" Value="Info">
                <Setter TargetName="IconPath" Property="Data" Value="{StaticResource IconSummary}"/>
                <Setter TargetName="IconPath" Property="Fill" Value="{StaticResource AccentBlue}"/>
                <Setter TargetName="ToastBorder" Property="BorderBrush" Value="#403B82F6"/>
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>
</ResourceDictionary>

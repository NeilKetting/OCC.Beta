<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:s="clr-namespace:System;assembly=mscorlib">

    <!-- Primary Font Family -->
    <FontFamily x:Key="MichromaFont">/Assets/Fonts/#Michroma</FontFamily>

    <!-- Semantic Font Sizes -->
    <s:Double x:Key="FontSizeSmall">12</s:Double>
    <s:Double x:Key="FontSizeRegular">14</s:Double>
    <s:Double x:Key="FontSizeLarge">18</s:Double>
    <s:Double x:Key="FontSizeHeader">25</s:Double>

    <!-- Standard Label Style -->
    <Style x:Key="LabelText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextSub}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Standard Form Input Label -->
    <Style x:Key="FormLabelText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextSub}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

</ResourceDictionary>
